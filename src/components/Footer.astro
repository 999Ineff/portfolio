---
const currentYear = new Date().getFullYear();

const serviceLinks = [
  { label: 'Custom Automation', href: '/automation' },
  { label: 'Tailored Websites', href: '/websites' },
  { label: 'Custom Platforms', href: '/platforms' },
  { label: 'Digital Marketing', href: '/marketing' },
  { label: 'Consulting', href: '/consulting' },
];

const companyLinks = [
  { label: 'Work', href: '/case-studies' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Resources', href: '/resources' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'Accessibility', href: '/accessibility' },
];
---

<footer class="footer">
  <div class="footer-content container">
    <div class="footer-top">
      <!-- Brand + newsletter -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-mark"></span>
          <span>Ineffable</span>
        </a>
        <p class="footer-tagline">Custom Software. Tailored Websites. Zero Busywork.</p>

        <!-- Newsletter — Netlify Forms (Track E: wired up) -->
        <form
          class="footer-newsletter"
          name="newsletter"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          id="footer-newsletter-form"
          novalidate
        >
          <!-- Netlify honeypot (spam filter) -->
          <input type="hidden" name="form-name" value="newsletter">
          <p class="sr-only" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label>
          </p>

          <label for="footer-email" class="sr-only">Email address</label>
          <input
            type="email"
            id="footer-email"
            name="email"
            placeholder="your@email.com"
            class="footer-email-input"
            autocomplete="email"
            required
            aria-required="true"
          >
          <button type="submit" class="footer-subscribe-btn" aria-label="Subscribe to newsletter">
            Subscribe
          </button>
        </form>

        <!-- Success state (shown by JS after submit) -->
        <p class="footer-newsletter-success" id="footer-newsletter-success" aria-live="polite" hidden>
          You're in. Talk soon.
        </p>
      </div>

      <!-- Link columns -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <h4 class="footer-col-title">Services</h4>
          {serviceLinks.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Company</h4>
          {companyLinks.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
          <a href="https://calendly.com/luis-aviles-khn" class="footer-link" target="_blank" rel="noopener noreferrer">Book a Call</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Connect</h4>
          <a href="https://www.linkedin.com/in/luis-aviles-0b969235a/" class="footer-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:luisaviles@ineffablesolutions.net" class="footer-link">Email Luis</a>
          <span class="footer-bilingual">🌎 Hablamos español</span>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Location</h4>
          <address class="footer-address">
            Ineffable Solutions<br>
            Tegucigalpa, Col. San Ignacio<br>
            Honduras 11101
          </address>
        </div>
      </nav>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {currentYear} Ineffable. All rights reserved.</p>
      <div class="footer-legal">
        {legalLinks.map(link => (
          <a href={link.href} class="footer-legal-link">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) 0 var(--space-md);
    background: var(--bg-deep);
    position: relative;
    overflow: hidden;
  }

  /* Gold gradient top border */
  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 193, 59, 0.3), transparent);
  }

  .footer::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 200px;
    background: radial-gradient(ellipse at top, rgba(255, 193, 59, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-xl);
    position: relative;
    z-index: 2;
  }

  /* ── Brand ──────────────────────────────────────────────── */
  .footer-brand {
    max-width: 380px;
    flex-shrink: 0;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--text-primary);
    text-decoration: none;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .footer-logo .logo-mark {
    width: 10px;
    height: 10px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(255, 193, 59, 0.4);
    flex-shrink: 0;
  }

  .footer-tagline {
    font-size: var(--text-base);
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  /* ── Newsletter ─────────────────────────────────────────── */
  .footer-newsletter {
    display: flex;
    gap: 0;
    max-width: 340px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .footer-email-input {
    flex: 1;
    padding: 0.6rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem; /* 16px min — prevents iOS auto-zoom on focus */
    outline: none;
    transition: border-color 0.3s var(--ease-out);
  }

  .footer-email-input::placeholder {
    color: var(--text-muted);
  }

  .footer-email-input:focus {
    border-color: var(--gold-dim);
  }

  .footer-subscribe-btn {
    padding: 0.6rem 1.25rem;
    background: var(--gradient-gold);
    color: var(--bg-deep);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s var(--ease-out);
  }

  .footer-subscribe-btn:hover {
    opacity: 0.9;
  }

  .footer-newsletter-success {
    font-size: var(--text-sm);
    color: var(--green);
    padding: 0.5rem 0;
    font-family: var(--font-body);
  }

  /* ── Nav Columns ─────────────────────────────────────────── */
  .footer-nav {
    display: flex;
    gap: 4rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.3s var(--ease-out);
    position: relative;
    display: inline-block;
    width: fit-content;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.3s var(--ease-spring);
  }

  .footer-link:hover {
    color: var(--text-primary);
    transform: translateX(4px);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  /* ── Bottom Bar ──────────────────────────────────────────── */
  .footer-divider {
    height: 1px;
    background: var(--border);
    margin: var(--space-xl) 0 var(--space-md);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal-link {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s var(--ease-out);
  }

  .footer-legal-link:hover {
    color: var(--text-secondary);
  }

  /* ── Address ────────────────────────────────────────────── */
  .footer-address {
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── Bilingual badge ─────────────────────────────────────── */
  .footer-bilingual {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(255, 193, 59, 0.08);
    border: 1px solid rgba(255, 193, 59, 0.2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--gold);
    letter-spacing: 0.02em;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .footer-nav { gap: 3rem; }
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: var(--space-xl);
    }
    .footer-brand {
      max-width: 100%;
    }
    .footer-newsletter {
      max-width: 100%;
    }
    .footer-nav {
      flex-wrap: wrap;
      gap: var(--space-lg);
    }
    .footer-col {
      min-width: 140px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    .footer-legal {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('footer-newsletter-form');
    var successMsg = document.getElementById('footer-newsletter-success');
    if (!form || !successMsg) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var emailInput = form.querySelector('input[name="email"]');
      if (!emailInput || !emailInput.value || !emailInput.validity.valid) {
        emailInput && emailInput.focus();
        return;
      }

      var data = new FormData(form);

      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data).toString(),
      })
        .then(function (res) {
          if (res.ok) {
            form.style.display = 'none';
            successMsg.removeAttribute('hidden');
            // Fire Plausible event if available
            if (typeof window.plausible === 'function') {
              window.plausible('Newsletter-Submit');
            }
          } else {
            console.warn('Newsletter form submission failed:', res.status);
          }
        })
        .catch(function (err) {
          console.warn('Newsletter form error:', err);
        });
    });
  })();
</script>
