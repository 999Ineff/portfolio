---
/**
 * Navigation — Phase 1 Architecture
 * [IS Logo] Services▾  Work  Pricing  About  Blog  [Book a Call →]
 *
 * Services dropdown: Custom Automation, Tailored Websites, Custom Platforms, Consulting
 * Brand: "Ineffable" (not "Ineffable Solutions" per brand decision)
 */

const serviceLinks = [
  { href: '/automation', label: 'Custom Automation', desc: 'Scripts, macros & integrations' },
  { href: '/websites', label: 'Tailored Websites', desc: 'Design, build & SEO' },
  { href: '/platforms', label: 'Custom Platforms', desc: 'Dashboards, CRMs & SaaS' },
  { href: '/marketing', label: 'Digital Marketing', desc: 'Google Ads, SEO & analytics' },
  { href: '/consulting', label: 'Consulting', desc: 'AI, ops & automation strategy' },
];

const navLinks = [
  { href: '/case-studies', label: 'Work' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/resources', label: 'Resources' },
];

const currentPath = Astro.url.pathname;
const isServicePage = serviceLinks.some(s =>
  currentPath === s.href || currentPath.startsWith(s.href + '/')
);
---

<nav class="nav" id="mainNav" aria-label="Main navigation">
  <div class="nav-content">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Ineffable Home">
      <span class="logo-mark"></span>
      <span class="logo-text">Ineffable</span>
    </a>

    <!-- Desktop links -->
    <div class="nav-links">
      <!-- Services dropdown -->
      <div class="nav-dropdown-wrap" id="servicesDropdown">
        <button
          class:list={['nav-link', 'nav-dropdown-trigger', { active: isServicePage }]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Services
          <svg class="dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="nav-dropdown" role="menu">
          <div class="nav-dropdown-inner">
            {serviceLinks.map(link => (
              <a
                href={link.href}
                class:list={['dropdown-item', { active: currentPath === link.href }]}
                role="menuitem"
              >
                <span class="dropdown-item-label">{link.label}</span>
                <span class="dropdown-item-desc">{link.desc}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Flat links -->
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || currentPath.startsWith(link.href + '/') }]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <a href="https://calendly.com/luis-aviles-khn" class="nav-cta" target="_blank" rel="noopener">
      Book a Call
    </a>

    <!-- Hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile Floating CTA — persists outside the hamburger menu overlay -->
<a
  href="https://calendly.com/luis-aviles-khn"
  class="mobile-float-cta"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Book a free call"
>
  Book a Call
</a>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu" aria-label="Navigation menu" aria-hidden="true">
  <div class="mobile-menu-inner">
    <p class="mobile-section-label">Services</p>
    {serviceLinks.map((link, i) => (
      <a href={link.href} class="mobile-link" style={`--i: ${i}`}>
        {link.label}
      </a>
    ))}
    <div class="mobile-divider"></div>
    {navLinks.map((link, i) => (
      <a href={link.href} class="mobile-link" style={`--i: ${i + serviceLinks.length}`}>
        {link.label}
      </a>
    ))}
    <a
      href="https://calendly.com/luis-aviles-khn"
      class="mobile-cta btn-primary"
      target="_blank"
      rel="noopener"
      style={`--i: ${serviceLinks.length + navLinks.length}`}
    >
      Book a Call
    </a>
  </div>
</div>

<style>
  /* ── Nav Shell ─────────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 2rem);
    max-width: 1100px;
    z-index: 100;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 18, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      top 0.5s var(--ease-out),
      padding 0.5s var(--ease-out),
      max-width 0.5s var(--ease-out),
      background 0.5s var(--ease-out);
  }

  .nav.scrolled {
    top: 0.5rem;
    padding: 0.6rem 1.5rem;
    max-width: 1000px;
    background: rgba(10, 10, 18, 0.85);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  /* ── Logo ──────────────────────────────────────────────── */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    z-index: 101;
    flex-shrink: 0;
    transition: transform 0.3s var(--ease-out);
  }

  .nav-logo:hover {
    transform: scale(1.03);
  }

  .logo-mark {
    width: 8px;
    height: 8px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--gold-glow);
    animation: logoPulse 3s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes logoPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 5px 0 var(--gold-glow); }
    50% { opacity: 0.7; box-shadow: 0 0 15px 5px var(--gold-glow); }
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  /* ── Nav Links ─────────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .nav-link {
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.4rem 0.75rem;
    border-radius: 20px;
    transition: color 0.3s var(--ease-out);
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    opacity: 0;
    transform: scale(0.9);
    transition: all 0.3s var(--ease-spring);
    z-index: -1;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
  }

  .nav-link:hover::before,
  .nav-link.active::before {
    opacity: 1;
    transform: scale(1);
  }

  .nav-link.active::before {
    background: rgba(255, 193, 59, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 193, 59, 0.15);
  }

  /* ── Services Dropdown ────────────────────────────────── */
  .nav-dropdown-wrap {
    position: relative;
  }

  .dropdown-chevron {
    transition: transform 0.3s var(--ease-out);
    width: 10px;
    height: 6px;
  }

  .nav-dropdown-wrap:hover .dropdown-chevron,
  .nav-dropdown-wrap.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: min(280px, calc(100vw - 2rem));
    max-width: min(320px, calc(100vw - 2rem));
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s var(--ease-out);
    pointer-events: none;
    z-index: 200;
  }

  /* Bridge — prevents dropdown from closing when moving mouse to it */
  .nav-dropdown::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }

  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown-wrap.open .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .nav-dropdown-inner {
    background: var(--bg-elevated);
    border: 1px solid var(--border-hover);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s var(--ease-out);
  }

  .dropdown-item:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .dropdown-item.active {
    background: rgba(255, 193, 59, 0.06);
  }

  .dropdown-item-label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .dropdown-item-desc {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ── CTA Button ───────────────────────────────────────── */
  .nav-cta {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    border-radius: var(--radius-pill);
    overflow: hidden;
    position: relative;
    background: var(--bg-glass);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 193, 59, 0.35);
    color: var(--gold);
    flex-shrink: 0;
    white-space: nowrap;
    transition:
      color 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out),
      transform 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
  }

  .nav-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--gradient-gold);
    transition: left 0.4s var(--ease-out);
    z-index: -1;
  }

  .nav-cta:hover {
    color: var(--bg-deep);
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 193, 59, 0.25);
  }

  .nav-cta:hover::before {
    left: 0;
  }

  /* ── Hamburger ─────────────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    z-index: 101;
    background: none;
    border: none;
    padding: 0;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--gold);
    transition: all 0.3s var(--ease-out);
    transform-origin: center;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ── Mobile Menu ───────────────────────────────────────── */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 18, 0.98);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    z-index: 99;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s var(--ease-out);
  }

  .mobile-menu.active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    gap: 1.25rem;
  }

  .mobile-section-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0;
    transform: translateY(20px);
  }

  .mobile-menu.active .mobile-section-label {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.4s var(--ease-out) 0.05s;
  }

  .mobile-divider {
    width: 40px;
    height: 1px;
    background: var(--border-hover);
    opacity: 0;
  }

  .mobile-menu.active .mobile-divider {
    opacity: 1;
    transition: opacity 0.3s var(--ease-out) 0.2s;
  }

  .mobile-link {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.3s var(--ease-out);
    opacity: 0;
    transform: translateY(20px);
  }

  .mobile-menu.active .mobile-link {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.4s var(--ease-out) calc(var(--i) * 0.04s + 0.08s),
      transform 0.4s var(--ease-out) calc(var(--i) * 0.04s + 0.08s),
      color 0.3s var(--ease-out);
  }

  .mobile-link:hover {
    color: var(--gold);
  }

  .mobile-cta {
    margin-top: 1rem;
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px);
  }

  .mobile-menu.active .mobile-cta {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.4s var(--ease-out) calc(var(--i) * 0.04s + 0.08s),
      transform 0.4s var(--ease-out) calc(var(--i) * 0.04s + 0.08s);
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
  }

  @media (min-width: 1025px) and (max-width: 1120px) {
    .nav-dropdown {
      left: 0;
      transform: translateY(8px);
    }

    .nav-dropdown-wrap:hover .nav-dropdown,
    .nav-dropdown-wrap.open .nav-dropdown {
      transform: translateY(0);
    }
  }

  @media (max-width: 480px) {
    .nav {
      padding: 0.6rem 1rem;
    }
    .logo-text {
      font-size: 0.85rem;
    }
  }

  /* ── Mobile Floating "Book a Call" CTA ─────────────────── */
  .mobile-float-cta {
    display: none;
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    padding: 0.75rem 1.25rem;
    background: var(--gradient-gold);
    color: var(--bg-deep);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: var(--radius-full, 999px);
    text-decoration: none;
    z-index: 999;
    box-shadow: 0 4px 20px rgba(255, 193, 59, 0.3);
    transition:
      transform 0.2s var(--ease-out),
      box-shadow 0.2s var(--ease-out);
  }

  .mobile-float-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(255, 193, 59, 0.4);
  }

  @media (max-width: 1024px) {
    .mobile-float-cta { display: block; }
  }

  @media (min-width: 1025px) {
    .mobile-float-cta { display: none; }
  }

  /* Hide during intro animation — class-based so CSS media queries still work after removal */
  .mobile-float-cta.intro-hidden { display: none !important; }
</style>

<script>
  function initNav() {
    const nav = document.getElementById('mainNav');
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    const dropdown = document.getElementById('servicesDropdown');
    const trigger = dropdown?.querySelector('.nav-dropdown-trigger');
    const floatCta = document.querySelector<HTMLElement>('.mobile-float-cta');

    // Hide float CTA during intro overlay to prevent z-index collision with Skip button
    if (floatCta) {
      const introOverlay = document.getElementById('intro-overlay');
      if (introOverlay) {
        floatCta.classList.add('intro-hidden');
        let introResolved = false;
        const showAfterIntro = () => {
          if (introResolved) return;
          introResolved = true;
          floatCta.classList.remove('intro-hidden');
        };
        // Watch for intro overlay removal (childList only — intro-overlay is a direct child of body)
        const obs = new MutationObserver(() => {
          if (!document.getElementById('intro-overlay')) { showAfterIntro(); obs.disconnect(); }
        });
        obs.observe(document.body, { childList: true });
        // Safety: show after 8s max
        setTimeout(showAfterIntro, 8000);
      }
    }

    // Scroll behavior — shrink on scroll
    window.addEventListener('scroll', () => {
      if (!nav) return;
      nav.classList.toggle('scrolled', window.scrollY > 50);
    }, { passive: true });

    // Services dropdown — toggle on click (supplements CSS :hover)
    trigger?.addEventListener('click', () => {
      const isOpen = dropdown!.classList.toggle('open');
      trigger.setAttribute('aria-expanded', String(isOpen));
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (dropdown && !dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('open');
        trigger?.setAttribute('aria-expanded', 'false');
      }
    });

    // Mobile menu toggle
    hamburger?.addEventListener('click', () => {
      const isActive = hamburger.classList.toggle('active');
      hamburger.setAttribute('aria-expanded', String(isActive));
      mobileMenu?.classList.toggle('active');
      mobileMenu?.setAttribute('aria-hidden', String(!isActive));
      document.body.style.overflow = isActive ? 'hidden' : '';
    });

    // Close mobile on link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburger?.classList.remove('active');
        hamburger?.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.remove('active');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
