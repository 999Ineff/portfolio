---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function estimateReadingTime(body: string): number {
  const words = (body || '').trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const categories = [...new Set(posts.map(p => p.data.category))];
---

<BaseLayout
  title="Blog — Automation, AI & Business Systems"
  description="Practical insights on automation, web design, AI, and operations — written for business owners and operators who want results, not jargon."
>
  <!-- Hero -->
  <!-- D25: Reframed for business owner audience, not developers -->
  <section class="hero section-lg">
    <div class="container hero-inner">
      <SectionLabel text="Insights" />
      <h1 class="text-heading reveal">
        Practical ideas for<br />
        <span class="text-gold">running a tighter operation</span>
      </h1>
      <p class="hero-sub reveal" data-delay="0.1">
        Automation, web design, AI tools, and operations — written for business
        owners and managers who want results, not jargon.
      </p>
      <!-- D3: Content pillars as credibility signal above fold -->
      <div class="content-pillars reveal" data-delay="0.2">
        <span class="pillar font-mono">Automation</span>
        <span class="pillar-dot" aria-hidden="true">·</span>
        <span class="pillar font-mono">Web Design</span>
        <span class="pillar-dot" aria-hidden="true">·</span>
        <span class="pillar font-mono">AI Tools</span>
        <span class="pillar-dot" aria-hidden="true">·</span>
        <span class="pillar font-mono">Operations</span>
      </div>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar reveal">
        <button class="filter-btn filter-btn--active" data-filter="all">All Posts</button>
        {categories.map(cat => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="section" id="posts">
    <div class="container">
      <div class="blog-grid" id="blog-grid">
        {posts.map((post, i) => {
          const readingTime = estimateReadingTime(post.body || '');
          return (
            <a
              href={`/blog/${post.id}`}
              class="blog-card card reveal"
              data-delay={`${i * 0.08}`}
              data-category={post.data.category}
              transition:name={`blog-card-${post.id}`}
            >
              <div class="blog-card-inner">
                <div class="blog-card-meta">
                  <span class={`blog-category tag tag-${post.data.categoryColor === 'gold' ? '' : post.data.categoryColor}`}>
                    {post.data.category}
                  </span>
                  <div class="blog-meta-right">
                    <span class="blog-date font-mono">{formatDate(post.data.date)}</span>
                    <span class="blog-reading font-mono">
                      <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
                        <path d="M6 3.5V6L7.5 7.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      </svg>
                      {readingTime} min
                    </span>
                  </div>
                </div>

                <h3 class="blog-card-title" transition:name={`blog-title-${post.id}`}>
                  {post.data.title}
                </h3>

                <p class="blog-card-excerpt">{post.data.excerpt}</p>

                <span class="read-more font-mono">
                  Read article <span class="read-arrow">→</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Empty state -->
      <div class="empty-state" id="empty-state" aria-hidden="true">
        <p>No posts in this category yet.</p>
      </div>
    </div>
  </section>

  <!-- More Coming — D25: Business owner framing -->
  <section class="section">
    <div class="container-narrow">
      <div class="more-coming reveal">
        <p class="more-coming-text">
          New posts published regularly — automation case studies, web design breakdowns,
          and AI tools that actually move the needle. Follow on
          <a
            href="https://www.linkedin.com/in/luis-aviles-0b969235a/"
            target="_blank"
            rel="noopener"
            class="linkedin-link"
          >
            LinkedIn
          </a>
          for the latest.
        </p>
      </div>
    </div>
  </section>

  <CTA
    heading="Skip the blog — just tell me your problem."
    subtext="Reading takes time. A 15-minute call gets you a specific answer for your specific situation."
    buttonText="Book a 15-Min Call"
    buttonLink="https://calendly.com/luis-aviles-khn"
    secondaryText="See case studies"
    secondaryLink="/case-studies"
  />
</BaseLayout>

<script>
  function initFilter() {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.blog-card');
    const emptyState = document.getElementById('empty-state');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter!;

        filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
        btn.classList.add('filter-btn--active');

        let visible = 0;
        cards.forEach(card => {
          const category = card.dataset.category;
          const show = filter === 'all' || category === filter;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (emptyState) {
          emptyState.style.display = visible === 0 ? 'block' : 'none';
          emptyState.setAttribute('aria-hidden', visible === 0 ? 'false' : 'true');
        }
      });
    });
  }

  initFilter();
  document.addEventListener('astro:after-swap', initFilter);
</script>

<style>
  /* Hero */
  .hero {
    min-height: auto;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-lg);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    max-width: 660px; /* D1: constrained for readability */
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--text-dim);
    max-width: 540px;
    line-height: 1.7;
  }

  /* D3: Content pillars as above-fold credibility */
  .content-pillars {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }

  .pillar {
    font-size: var(--text-xs);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pillar-dot {
    color: var(--border-hover);
    font-size: var(--text-sm);
  }

  /* Filter */
  .filter-section {
    padding-bottom: var(--space-md);
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .filter-btn:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }

  .filter-btn--active {
    border-color: rgba(255, 193, 59, 0.4);
    color: var(--gold);
    background: var(--gold-subtle);
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  /* Blog Card */
  .blog-card {
    display: block;
    cursor: pointer;
  }

  .blog-card-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    padding: var(--space-md);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .blog-category {
    font-size: 0.6rem;
    padding: 0.25rem 0.65rem;
    letter-spacing: 0.1em;
  }

  .blog-meta-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .blog-date {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .blog-reading {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .blog-card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.3;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .blog-card:hover .blog-card-title {
    color: var(--gold);
  }

  .blog-card-excerpt {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: 1.7;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-source {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.05em;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .source-dot {
    width: 6px;
    height: 6px;
    background: #0a66c2;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* D audit: read-more was always opacity:0 — accessibility violation.
     Now always visible, with gold color enhancement on hover. */
  .read-more {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color var(--duration-base) var(--ease-out);
  }

  .blog-card:hover .read-more {
    color: var(--gold);
  }

  .read-arrow {
    display: inline-block;
    transition: transform 0.3s var(--ease-out);
  }

  .blog-card:hover .read-arrow {
    transform: translateX(3px);
  }

  /* Empty State */
  .empty-state {
    display: none;
    text-align: center;
    padding: var(--space-xl) 0;
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  /* More Coming */
  .more-coming {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    border: 1px dashed var(--border-hover);
    background: var(--bg-card);
  }

  .more-coming-text {
    font-size: var(--text-base);
    color: var(--text-dim);
    line-height: 1.7;
  }

  .linkedin-link {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--duration-fast);
  }

  .linkedin-link:hover {
    color: #ffcf5e;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--nav-height) + var(--space-lg));
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .blog-card-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .content-pillars {
      gap: 0.5rem;
    }
  }

  /* Accessibility: Show content when scripting is disabled */
  @media (scripting: none) {
    .reveal,
    .reveal-left,
    .reveal-right,
    .reveal-scale {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
