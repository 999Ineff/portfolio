---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout
  title="Consulting"
  description="Not sure what you need? Let's figure it out together — no commitment, no pitch. AI strategy, operations optimization, and automation roadmapping from someone who builds."
>
  <!-- Hero -->
  <section class="hero section-lg">
    <div class="container hero-inner">
      <SectionLabel text="Consulting" />
      <h1 class="hero-title reveal" data-delay="0.1">
        Not Sure What You Need?<br />
        <span class="text-gold">Let's Figure It Out Together.</span>
      </h1>
      <p class="hero-sub reveal" data-delay="0.2">
        Nine years of operations leadership means I don't just understand the tech —
        I understand the pain points, the politics, and the real reason things don't get fixed.
        No commitment. No pitch. Just clarity.
      </p>
      <div class="hero-actions reveal" data-delay="0.3">
        <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">
          Book a Discovery Call
        </a>
        <a href="#who-its-for" class="btn btn-secondary">Is This for Me?</a>
      </div>
    </div>
  </section>

  <!-- Narrative Animation: Tangled Process → Clear Decision Tree -->
  <section class="section narrative-section" id="animation">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="The Clarity Process" color="cyan" />
        <h2 class="text-heading reveal">From "I don't know where to start" to a clear path forward</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 600px;">
          Most operations problems look complicated. They're usually not. Watch the tangle become a decision tree.
        </p>
      </div>

      <div class="narrative-stage reveal" data-delay="0.2" id="consulting-animation">
        <svg
          class="narrative-svg"
          viewBox="0 0 800 360"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Animation showing a tangled process flowchart transforming into a clear decision tree"
          role="img"
        >
          <rect width="800" height="360" fill="#0a0a12"/>

          <!-- BEFORE: Tangled mess of connections -->
          <g id="tangled">
            <!-- Scattered nodes with chaotic connections -->
            <circle cx="80" cy="80" r="22" fill="#141420" stroke="rgba(255,71,87,0.4)" stroke-width="1"/>
            <text x="80" y="84" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="200" cy="60" r="22" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <text x="200" y="64" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="120" cy="160" r="22" fill="#141420" stroke="rgba(255,71,87,0.4)" stroke-width="1"/>
            <text x="120" y="164" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="260" cy="140" r="22" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <text x="260" y="144" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="60" cy="240" r="22" fill="#141420" stroke="rgba(255,71,87,0.4)" stroke-width="1"/>
            <text x="60" y="244" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="190" cy="260" r="22" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <text x="190" y="264" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="300" cy="220" r="22" fill="#141420" stroke="rgba(255,71,87,0.4)" stroke-width="1"/>
            <text x="300" y="224" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <circle cx="150" cy="310" r="22" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <text x="150" y="314" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">?</text>

            <!-- Chaotic connections (spaghetti lines) -->
            <line x1="80" y1="80" x2="200" y2="60" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="80" y1="80" x2="120" y2="160" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="80" y1="80" x2="260" y2="140" stroke="rgba(255,71,87,0.2)" stroke-width="1"/>
            <line x1="200" y1="60" x2="120" y2="160" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="200" y1="60" x2="300" y2="220" stroke="rgba(255,71,87,0.2)" stroke-width="1"/>
            <line x1="120" y1="160" x2="60" y2="240" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="120" y1="160" x2="190" y2="260" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="260" y1="140" x2="300" y2="220" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="260" y1="140" x2="60" y2="240" stroke="rgba(255,71,87,0.2)" stroke-width="1"/>
            <line x1="60" y1="240" x2="150" y2="310" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="190" y1="260" x2="150" y2="310" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>
            <line x1="300" y1="220" x2="150" y2="310" stroke="rgba(255,71,87,0.2)" stroke-width="1"/>
            <line x1="190" y1="260" x2="300" y2="220" stroke="rgba(255,71,87,0.3)" stroke-width="1"/>

            <text x="185" y="340" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#ff4757">Before: no clear path, no priority</text>
          </g>

          <!-- AFTER: Clear Decision Tree (hidden initially) -->
          <g id="clear-tree" opacity="0">
            <!-- Root node -->
            <rect x="450" y="20" width="130" height="36" rx="4" fill="#141420" stroke="rgba(255,193,59,0.4)" stroke-width="1"/>
            <text x="515" y="42" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#ffc13b">What's the pain?</text>

            <!-- Branch lines from root -->
            <line id="branch-l" x1="515" y1="56" x2="460" y2="110" stroke="#ffc13b" stroke-width="1" opacity="0" stroke-dasharray="100" stroke-dashoffset="100"/>
            <line id="branch-r" x1="515" y1="56" x2="570" y2="110" stroke="#ffc13b" stroke-width="1" opacity="0" stroke-dasharray="100" stroke-dashoffset="100"/>

            <!-- Level 2: Time vs Money vs Decisions -->
            <rect x="395" y="110" width="110" height="32" rx="4" fill="#141420" stroke="rgba(0,229,255,0.3)" stroke-width="1" opacity="0" id="node-time"/>
            <text x="450" y="130" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#00e5ff">Wasted time</text>

            <rect x="515" y="110" width="110" height="32" rx="4" fill="#141420" stroke="rgba(0,229,255,0.3)" stroke-width="1" opacity="0" id="node-money"/>
            <text x="570" y="130" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#00e5ff">Bad decisions</text>

            <!-- Branch lines level 2 -->
            <line id="bl2a" x1="450" y1="142" x2="430" y2="190" stroke="#00e5ff" stroke-width="1" opacity="0"/>
            <line id="bl2b" x1="450" y1="142" x2="480" y2="190" stroke="#00e5ff" stroke-width="1" opacity="0"/>
            <line id="bl2c" x1="570" y1="142" x2="550" y2="190" stroke="#00e5ff" stroke-width="1" opacity="0"/>
            <line id="bl2d" x1="570" y1="142" x2="610" y2="190" stroke="#00e5ff" stroke-width="1" opacity="0"/>

            <!-- Level 3: Solutions -->
            <rect x="390" y="190" width="80" height="30" rx="4" fill="#0f0f1a" stroke="rgba(0,255,136,0.4)" stroke-width="1" opacity="0" id="sol1"/>
            <text x="430" y="209" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">Automate</text>

            <rect x="478" y="190" width="80" height="30" rx="4" fill="#0f0f1a" stroke="rgba(0,255,136,0.4)" stroke-width="1" opacity="0" id="sol2"/>
            <text x="518" y="209" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">Redesign</text>

            <rect x="508" y="190" width="80" height="30" rx="4" fill="#0f0f1a" stroke="rgba(0,255,136,0.4)" stroke-width="1" opacity="0" id="sol3"/>
            <text x="548" y="209" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">Dashboard</text>

            <rect x="570" y="190" width="80" height="30" rx="4" fill="#0f0f1a" stroke="rgba(0,255,136,0.4)" stroke-width="1" opacity="0" id="sol4"/>
            <text x="610" y="209" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">Platform</text>

            <!-- Priority indicators -->
            <g id="priority-group" opacity="0">
              <rect x="390" y="230" width="80" height="18" rx="2" fill="rgba(0,255,136,0.1)"/>
              <text x="430" y="242" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#00ff88">DO FIRST</text>

              <rect x="478" y="230" width="80" height="18" rx="2" fill="rgba(0,229,255,0.1)"/>
              <text x="518" y="242" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#00e5ff">MONTH 2</text>

              <rect x="508" y="230" width="80" height="18" rx="2" fill="rgba(255,193,59,0.1)"/>
              <text x="548" y="242" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#ffc13b">MONTH 3</text>

              <rect x="570" y="230" width="80" height="18" rx="2" fill="rgba(255,193,59,0.08)"/>
              <text x="610" y="242" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#ffc13b">FUTURE</text>
            </g>

            <!-- ROI row -->
            <g id="roi-group" opacity="0">
              <text x="430" y="270" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">$350–$700</text>
              <text x="518" y="270" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00e5ff">$4.2K–$5.6K</text>
              <text x="548" y="270" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ffc13b">$10.5K–$14K</text>
              <text x="610" y="270" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ffc13b">$28K–$42K</text>

              <!-- Roadmap label -->
              <rect x="390" y="295" width="280" height="30" rx="4" fill="#0a0a12" stroke="rgba(255,193,59,0.2)" stroke-width="0.5"/>
              <text x="530" y="315" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ffc13b">Your roadmap: clear priorities + real ROI</text>
            </g>
          </g>
        </svg>

        <div class="animation-labels">
          <div class="anim-label">
            <span class="anim-label-dot" style="background: var(--red);"></span>
            <span class="font-mono">Before: overwhelming, no priority</span>
          </div>
          <div class="anim-label">
            <span class="anim-label-dot" style="background: var(--gold);"></span>
            <span class="font-mono">After: clear path, priced and sequenced</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Cover -->
  <section class="section" id="what-i-cover">
    <div class="container">
      <div class="section-header">
        <SectionLabel text="What I Cover" color="cyan" />
        <h2 class="text-heading reveal">Strategy meets execution</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 700px;">
          Most consultants tell you what's possible. I tell you what's worth doing — and then I can build it.
        </p>
      </div>

      <div class="consulting-grid">
        {[
          { icon: '&#9670;', color: 'gold', title: 'AI Strategy', desc: 'Where AI actually adds value in your operations — not where the hype says it should. Practical implementation plans, not slide decks.' },
          { icon: '&#9881;', color: 'cyan', title: 'Operations Optimization', desc: 'Find the bottlenecks costing you the most time and money. Redesign workflows so the same team produces more with less friction.' },
          { icon: '&#9776;', color: 'green', title: 'Automation Roadmapping', desc: 'Prioritized plan for what to automate first, second, and never. ROI-driven sequencing so every dollar spent compounds.' },
          { icon: '&#9733;', color: 'gold', title: 'Team Alignment', desc: 'Translate between technical and non-technical teams. Get everyone building in the same direction — before you invest.' },
          { icon: '&#9874;', color: 'cyan', title: 'Tool Selection', desc: 'Cut through the noise. Pick the right platforms, vendors, and integrations based on what your team will actually use.' },
          { icon: '&#9635;', color: 'green', title: 'Process Design', desc: 'Build processes that survive contact with reality. SOPs, handoff procedures, and accountability structures that stick.' },
        ].map((item, i) => (
          <div class="consulting-card card reveal" data-delay={`${i * 0.06}`}>
            <div class={`consulting-icon text-${item.color}`} set:html={item.icon}></div>
            <h3 class="consulting-card-title">{item.title}</h3>
            <p class="consulting-card-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="section-lg persona-section" id="who-its-for">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Who It's For" color="gold" />
        <h2 class="text-heading reveal">Find yourself here?</h2>
      </div>

      <div class="persona-grid">
        {[
          {
            icon: '&#9632;', color: 'green', role: 'Employee',
            pain: '"I waste hours on tasks that should take minutes."',
            points: ['Copy-pasting between systems all day', 'Rebuilding the same reports every week', 'Manually tracking things that should update themselves'],
            solution: 'I identify which tasks to eliminate and build the tools to do it.'
          },
          {
            icon: '&#9632;', color: 'cyan', role: 'Manager',
            pain: '"My team\'s output doesn\'t match their effort."',
            points: ['Good people stuck in bad processes', 'Visibility gaps between teams', 'No way to measure what\'s actually working'],
            solution: 'I redesign workflows so effort translates to results.'
          },
          {
            icon: '&#9632;', color: 'gold', role: 'C-Suite',
            pain: '"I know tech could help but I don\'t know where to start."',
            points: ['Vendors pitch solutions to problems you\'re not sure you have', 'Every team wants different tools', 'Past investments haven\'t delivered promised ROI'],
            solution: 'I translate business goals into a tech roadmap that actually delivers.'
          },
          {
            icon: '&#9670;', color: 'gold', role: 'Owner',
            pain: '"I\'m running everything and building nothing."',
            points: ['Trapped in day-to-day operations you built', 'Can\'t step away without things breaking', 'Growth means more of your time, not less'],
            solution: 'I build the systems that let you work on the business, not in it.'
          },
        ].map((persona, i) => (
          <div class="persona-card card reveal" data-delay={`${i * 0.1}`}>
            <div class="persona-role">
              <span class={`persona-icon text-${persona.color}`} set:html={persona.icon}></span>
              <span class="persona-title font-mono">{persona.role}</span>
            </div>
            <p class="persona-pain">{persona.pain}</p>
            <ul class="persona-points">
              {persona.points.map(pt => <li>{pt}</li>)}
            </ul>
            <p class="persona-solution">
              <span class="text-gold font-mono">//</span> {persona.solution}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section" id="how-it-works">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="How It Works" color="cyan" />
        <h2 class="text-heading reveal">Four steps. No fluff.</h2>
      </div>

      <div class="process-grid">
        {[
          { num: '01', color: 'gold', title: 'Discovery Call', desc: '30 minutes. You tell me where it hurts. I ask the questions most consultants don\'t think to ask.' },
          { num: '02', color: 'gold', title: 'Assessment', desc: 'I map your current workflows, data flow, and team structure. Find the gaps between where you are and where you want to be.' },
          { num: '03', color: 'gold', title: 'Roadmap', desc: 'Prioritized action plan with clear ROI projections. What to fix first, what to defer, and what to skip entirely.' },
          { num: '04', color: 'cyan', title: 'Build (optional)', desc: 'If the roadmap calls for custom software, I can build it too. Strategy and execution from the same person — no handoff gaps.' },
        ].map((step, i) => (
          <div class="process-step reveal" data-delay={`${i * 0.1}`}>
            <div class={`process-number font-mono text-${step.color}`}>{step.num}</div>
            <div class="process-line"></div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tiers & Pricing -->
  <section class="section-lg pricing-section" id="pricing">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Pricing" color="gold" />
        <h2 class="text-heading reveal">What consulting actually costs</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 650px;">
          Structured engagements or hourly — whatever fits your situation. Transparent from the start.
        </p>
      </div>

      <div class="consulting-tiers">
        <div class="consulting-tier card reveal" data-delay="0">
          <div class="ctier-label tag font-mono">Strategy Session</div>
          <h3 class="ctier-name">Single Session</h3>
          <div class="ctier-price font-mono text-gold">$150 – $300</div>
          <p class="ctier-desc">One focused session: 90 minutes. I audit your situation, answer your questions, give you a clear next step. No fluff, no upsell pressure.</p>
          <ul class="ctier-features">
            <li class="ctier-feature"><span class="text-gold">&#10003;</span> 90-minute working session</li>
            <li class="ctier-feature"><span class="text-gold">&#10003;</span> Written summary + recommendations</li>
            <li class="ctier-feature"><span class="text-gold">&#10003;</span> Honest assessment: build, buy, or skip</li>
            <li class="ctier-feature"><span class="text-gold">&#10003;</span> No commitment beyond this session</li>
          </ul>
          <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">Book a Session</a>
        </div>

        <div class="consulting-tier consulting-tier--featured card reveal" data-delay="0.1">
          <div class="ctier-label tag tag-cyan font-mono">Roadmap</div>
          <h3 class="ctier-name">Technology Audit + Roadmap</h3>
          <div class="ctier-price font-mono text-gold">$1,500 – $3,000</div>
          <div class="ctier-billing font-mono text-dim">Project scoped</div>
          <p class="ctier-desc">Full workflow audit, tool assessment, and a prioritized 90-day roadmap with ROI projections. Exactly what to do, in what order, and why.</p>
          <ul class="ctier-features">
            <li class="ctier-feature"><span class="text-cyan">&#10003;</span> Workflow & tool audit (2–3 sessions)</li>
            <li class="ctier-feature"><span class="text-cyan">&#10003;</span> Bottleneck identification</li>
            <li class="ctier-feature"><span class="text-cyan">&#10003;</span> 90-day prioritized roadmap</li>
            <li class="ctier-feature"><span class="text-cyan">&#10003;</span> ROI projections for each initiative</li>
            <li class="ctier-feature"><span class="text-cyan">&#10003;</span> Vendor & tool recommendations</li>
            <li class="ctier-feature"><span class="text-cyan">&#10003;</span> Presentation-ready deliverable</li>
          </ul>
          <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">Schedule Discovery</a>
        </div>

        <div class="consulting-tier card reveal" data-delay="0.2">
          <div class="ctier-label tag tag-green font-mono">Ongoing</div>
          <h3 class="ctier-name">Monthly Advisory</h3>
          <div class="ctier-price font-mono text-green">$500 – $1,500/mo</div>
          <p class="ctier-desc">Ongoing strategic partner. Monthly check-ins, project oversight, team coaching, and decision support. Cancel anytime.</p>
          <ul class="ctier-features">
            <li class="ctier-feature"><span class="text-green">&#10003;</span> 2–4 sessions per month</li>
            <li class="ctier-feature"><span class="text-green">&#10003;</span> Async support (Slack/email)</li>
            <li class="ctier-feature"><span class="text-green">&#10003;</span> Project review & guidance</li>
            <li class="ctier-feature"><span class="text-green">&#10003;</span> Team coaching support</li>
            <li class="ctier-feature"><span class="text-green">&#10003;</span> Cancel anytime, no lock-in</li>
          </ul>
          <a href="https://calendly.com/luis-aviles-khn" class="btn btn-secondary" target="_blank" rel="noopener">Ask About Advisory</a>
        </div>
      </div>
      <div class="launch-banner reveal" data-delay="0.3">
        <span class="launch-banner__icon mono">◈</span>
        <span>Pre-portfolio rates. Pricing increases with each completed case study.</span>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section-lg comparison-section">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Compare" color="gold" />
        <h2 class="text-heading reveal">Consulting firm vs in-house vs Ineffable</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 650px;">
          The difference isn't just price. It's who's actually in the room with you.
        </p>
      </div>

      <div class="comparison-table reveal" data-delay="0.2">
        <div class="comparison-header">
          <div class="comparison-col comparison-col--label"></div>
          <div class="comparison-col comparison-col--option">
            <span class="comparison-option-name font-mono">Consulting Firm</span>
            <span class="comparison-option-sub font-mono text-dim">Big 4 / boutique</span>
          </div>
          <div class="comparison-col comparison-col--option">
            <span class="comparison-option-name font-mono">In-House Hire</span>
            <span class="comparison-option-sub font-mono text-dim">FTE hire</span>
          </div>
          <div class="comparison-col comparison-col--featured">
            <span class="comparison-option-name font-mono text-gold">Ineffable</span>
            <span class="comparison-option-sub font-mono text-dim">Founder-operator</span>
          </div>
        </div>

        {[
          { label: 'Cost', a: '$300–$600/hr billed', b: '$80K–$150K/year + benefits', c: '$150–$300/session or project' },
          { label: 'Who advises you', a: 'Senior partner pitches, junior executes', b: 'One person, limited context', c: 'I advise and I build — same person' },
          { label: 'Time to start', a: '4–8 weeks setup', b: '3–6 months to hire', c: 'This week' },
          { label: 'Can execute the plan', a: 'Rarely (not their business)', b: 'Sometimes', c: 'Yes — strategy + execution together' },
