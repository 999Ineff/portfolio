<script>
  // Consulting animation: tangled → clear decision tree
  (function() {
    const stage = document.getElementById('consulting-animation');
    if (!stage) return;

    let animated = false;

    function runAnimation() {
      if (animated) return;
      animated = true;

      const gsap = (window as any).gsap;
      if (!gsap) return;

      const tl = gsap.timeline();

      // Phase 1: Tangled mess dims
      tl.to('#tangled', {
        opacity: 0.3,
        duration: 0.8,
        ease: 'power2.out',
      }, 0.5);

      // Phase 2: Clear tree root appears
      tl.to('#clear-tree', {
        opacity: 1,
        duration: 0.5,
        ease: 'power2.out',
      }, 1.0);

      // Phase 3: Branch lines draw
      tl.to(['#branch-l', '#branch-r'], {
        opacity: 0.8,
        strokeDashoffset: 0,
        duration: 0.4,
        stagger: 0.1,
        ease: 'power2.out',
      }, 1.5);

      // Phase 4: Level 2 nodes appear
      tl.to(['#node-time', '#node-money'], {
        opacity: 1,
        duration: 0.3,
        stagger: 0.1,
        ease: 'power2.out',
      }, 2.0);

      // Phase 5: Branch lines level 2
      tl.to(['#bl2a', '#bl2b', '#bl2c', '#bl2d'], {
        opacity: 0.6,
        duration: 0.3,
        stagger: 0.05,
        ease: 'power2.out',
      }, 2.4);

      // Phase 6: Solution nodes appear
      tl.to(['#sol1', '#sol2', '#sol3', '#sol4'], {
        opacity: 1,
        duration: 0.25,
        stagger: 0.08,
        ease: 'power2.out',
      }, 2.8);

      // Phase 7: Priority and ROI labels
      tl.to('#priority-group', {
        opacity: 1,
        duration: 0.4,
        ease: 'power2.out',
      }, 3.3);

      tl.to('#roi-group', {
        opacity: 1,
        duration: 0.4,
        ease: 'power2.out',
      }, 3.7);

      // Phase 8: Tangled disappears
      tl.to('#tangled', {
        opacity: 0.08,
        duration: 0.5,
        ease: 'power2.in',
      }, 3.5);
    }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runAnimation();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      observer.observe(stage);
    } else {
      setTimeout(runAnimation, 1000);
    }
  })();
</script>
