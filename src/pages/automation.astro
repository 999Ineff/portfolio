<script>
  // Narrative animation: fires when scrolled into view
  (function() {
    const stage = document.getElementById('automation-animation');
    if (!stage) return;

    let animated = false;

    function runAnimation() {
      if (animated) return;
      animated = true;

      const gsap = (window as any).gsap;
      if (!gsap) return;

      const tl = gsap.timeline();

      // Phase 1: Highlight errors in before-panel
      tl.to(['#err1', '#err2', '#err3', '#err4'], {
        opacity: 1,
        duration: 0.3,
        stagger: 0.15,
        ease: 'power2.out',
      }, 0.5);

      // Phase 2: Trigger group appears
      tl.to('#trigger-group', {
        opacity: 1,
        duration: 0.5,
        ease: 'power2.out',
      }, 1.5);

      // Phase 3: Flow arrows appear
      tl.to(['#flow-arrow-left', '#flow-arrow-right'], {
        opacity: 1,
        duration: 0.3,
        stagger: 0.1,
        ease: 'power2.out',
      }, 2.2);

      // Phase 4: Particles flow left to right
      const particles = document.querySelectorAll('#automation-animation .particle');
      particles.forEach((p, i) => {
        tl.to(p, {
          attr: { cx: 470, opacity: 0.8 },
          duration: 0.8,
          ease: 'power1.inOut',
          delay: i * 0.1,
        }, 2.4);
        tl.to(p, { opacity: 0, duration: 0.2, ease: 'power1.in' }, '+=0');
      });

      // Phase 5: After panel appears
      tl.to('#after-panel', {
        opacity: 1,
        duration: 0.6,
        ease: 'power3.out',
      }, 3.2);

      // Phase 6: Before panel errors fade
      tl.to(['#err1', '#err2', '#err3', '#err4'], {
        opacity: 0.3,
        duration: 0.4,
        ease: 'power2.out',
      }, 3.6);
    }

    // Use IntersectionObserver to trigger on scroll
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runAnimation();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );
      observer.observe(stage);
    } else {
      // Fallback: run immediately
      setTimeout(runAnimation, 1000);
    }
  })();
</script>
