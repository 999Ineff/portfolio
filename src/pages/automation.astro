---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CTA from '../components/CTA.astro';
import { quickWins } from '../data/stats';
import ROICalculator from '../components/islands/ROICalculator';
---

<BaseLayout
  title="Custom Automation"
  description="Stop losing hours to tasks a script could handle in seconds. Python scripts, Excel macros, API integrations, and full automation systems — built fast, running forever."
>
  <!-- Hero Section -->
  <section class="hero section-lg">
    <div class="container hero-inner">
      <SectionLabel text="Custom Automation" />

      <h1 class="hero-title reveal" data-delay="0.1">
        Stop Losing Hours to Tasks<br />
        <span class="text-gold">a Script Could Do in Seconds</span>
      </h1>

      <p class="hero-sub reveal" data-delay="0.2">
        Every repetitive task you do manually is money left on the table. I build automations that
        give that time back — starting from day one, running forever.
      </p>

      <div class="hero-actions reveal" data-delay="0.3">
        <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">
          Tell Me Your Task
        </a>
        <a href="#tiers" class="btn btn-secondary">See the Automation Ladder</a>
      </div>
    </div>
  </section>

  <!-- Narrative Animation: Data Transformation -->
  <section class="section narrative-section" id="animation">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="See It Happen" color="gold" />
        <h2 class="text-heading reveal">From chaos to clean — automatically</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 600px; margin: 1rem auto 0;">
          This is what it looks like when a macro fires. Watch your scattered data become structured output.
        </p>
      </div>

      <!-- SVG Narrative Animation -->
      <div class="narrative-stage reveal" data-delay="0.2" id="automation-animation">
        <svg
          class="narrative-svg"
          viewBox="0 0 800 360"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Animation showing automation transforming messy data into clean structured output"
          role="img"
        >
          <!-- Background -->
          <rect width="800" height="360" fill="#0a0a12"/>

          <!-- LEFT PANEL: Messy spreadsheet (before state) -->
          <g id="before-panel">
            <!-- Panel background -->
            <rect x="20" y="20" width="340" height="320" rx="6" fill="#141420" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <!-- Panel header -->
            <rect x="20" y="20" width="340" height="36" rx="6" fill="#1a1a28"/>
            <text x="36" y="43" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b7280">spreadsheet.xlsx — BEFORE</text>
            <!-- Grid lines (messy, off-color) -->
            <line x1="20" y1="56" x2="360" y2="56" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>

            <!-- Column headers -->
            <text x="32" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#4a4a5c">NAME</text>
            <text x="120" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#4a4a5c">DATE</text>
            <text x="200" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#4a4a5c">AMOUNT</text>
            <text x="280" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#4a4a5c">STATUS</text>

            <!-- Row 1 - random case, no formatting -->
            <text x="32" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">john smith</text>
            <text x="120" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">03/04/26</text>
            <text x="200" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">1200</text>
            <text x="280" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">???</text>

            <!-- Row 2 - inconsistent date format -->
            <text x="32" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">SARAH K.</text>
            <text x="120" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">March 4</text>
            <text x="200" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">$850.00</text>
            <text x="280" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">pend</text>

            <!-- Row 3 - empty cells -->
            <text x="32" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">Martinez, R</text>
            <text x="120" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">—</text>
            <text x="200" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">2100.5</text>
            <text x="280" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">DONE</text>

            <!-- Row 4 - duplicate, wrong amount format -->
            <text x="32" y="164" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">john smith</text>
            <text x="120" y="164" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">3/4/2026</text>
            <text x="200" y="164" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">1.2K</text>
            <text x="280" y="164" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">unknown</text>

            <!-- Row 5 -->
            <text x="32" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">T. Williams</text>
            <text x="120" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">04-03-26</text>
            <text x="200" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">475</text>
            <text x="280" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">complete</text>

            <!-- Error highlight boxes -->
            <rect id="err1" x="270" y="88" width="80" height="16" rx="2" fill="rgba(255,71,87,0.15)" opacity="0"/>
            <rect id="err2" x="270" y="110" width="80" height="16" rx="2" fill="rgba(255,71,87,0.15)" opacity="0"/>
            <rect id="err3" x="110" y="132" width="70" height="16" rx="2" fill="rgba(255,71,87,0.15)" opacity="0"/>
            <rect id="err4" x="190" y="154" width="70" height="16" rx="2" fill="rgba(255,71,87,0.15)" opacity="0"/>
          </g>

          <!-- CENTER: Script trigger -->
          <g id="trigger-group" opacity="0">
            <!-- Script box -->
            <rect x="340" y="80" width="120" height="200" rx="8" fill="#0f0f1a" stroke="rgba(255,193,59,0.3)" stroke-width="1"/>
            <rect x="340" y="80" width="120" height="32" rx="8" fill="#1a1a28"/>
            <rect x="340" y="96" width="120" height="16" rx="0" fill="#1a1a28"/>
            <text x="355" y="100" font-family="JetBrains Mono, monospace" font-size="9" fill="#ffc13b">macro.py</text>

            <!-- Code lines -->
            <text x="352" y="126" font-family="JetBrains Mono, monospace" font-size="8" fill="#a0a8bb">import pandas</text>
            <text x="352" y="140" font-family="JetBrains Mono, monospace" font-size="8" fill="#a0a8bb">clean(df)</text>
            <text x="352" y="154" font-family="JetBrains Mono, monospace" font-size="8" fill="#a0a8bb">dedupe(df)</text>
            <text x="352" y="168" font-family="JetBrains Mono, monospace" font-size="8" fill="#a0a8bb">format(df)</text>
            <text x="352" y="182" font-family="JetBrains Mono, monospace" font-size="8" fill="#a0a8bb">export(df)</text>

            <!-- Run button -->
            <rect x="356" y="220" width="88" height="28" rx="4" fill="rgba(255,193,59,0.15)" stroke="rgba(255,193,59,0.4)" stroke-width="1"/>
            <text x="400" y="239" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#ffc13b">RUN</text>

            <!-- Data flow arrows -->
            <path id="flow-arrow-left" d="M 340 180 L 365 180" stroke="#ffc13b" stroke-width="1.5" stroke-dasharray="4 2" opacity="0"/>
            <path id="flow-arrow-right" d="M 460 180 L 440 180" stroke="#00e5ff" stroke-width="1.5" stroke-dasharray="4 2" opacity="0"/>
          </g>

          <!-- RIGHT PANEL: Clean output (after state) -->
          <g id="after-panel" opacity="0">
            <rect x="460" y="20" width="320" height="320" rx="6" fill="#141420" stroke="rgba(0,229,255,0.15)" stroke-width="1"/>
            <rect x="460" y="20" width="320" height="36" rx="6" fill="#1a1a28"/>
            <text x="476" y="43" font-family="JetBrains Mono, monospace" font-size="11" fill="#00e5ff">output_clean.xlsx — AFTER</text>
            <line x1="460" y1="56" x2="780" y2="56" stroke="rgba(0,229,255,0.08)" stroke-width="1"/>

            <!-- Column headers -->
            <text x="472" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#a0a8bb">NAME</text>
            <text x="570" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#a0a8bb">DATE</text>
            <text x="650" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#a0a8bb">AMOUNT</text>
            <text x="730" y="75" font-family="JetBrains Mono, monospace" font-size="9" fill="#a0a8bb">STATUS</text>

            <!-- Clean rows -->
            <text x="472" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">John Smith</text>
            <text x="570" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">2026-03-04</text>
            <text x="650" y="98" font-family="JetBrains Mono, monospace" font-size="9" fill="#00ff88">$1,200.00</text>
            <rect x="725" y="87" width="55" height="16" rx="3" fill="rgba(0,255,136,0.12)"/>
            <text x="752" y="98" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">COMPLETE</text>

            <text x="472" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">Sarah K.</text>
            <text x="570" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">2026-03-04</text>
            <text x="650" y="120" font-family="JetBrains Mono, monospace" font-size="9" fill="#00ff88">$850.00</text>
            <rect x="725" y="109" width="55" height="16" rx="3" fill="rgba(255,193,59,0.12)"/>
            <text x="752" y="120" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ffc13b">PENDING</text>

            <text x="472" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">R. Martinez</text>
            <text x="570" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">2026-03-04</text>
            <text x="650" y="142" font-family="JetBrains Mono, monospace" font-size="9" fill="#00ff88">$2,100.50</text>
            <rect x="725" y="131" width="55" height="16" rx="3" fill="rgba(0,255,136,0.12)"/>
            <text x="752" y="142" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">COMPLETE</text>

            <text x="472" y="164" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280" text-decoration="line-through">john smith (dup)</text>
            <text x="600" y="164" font-family="JetBrains Mono, monospace" font-size="8" fill="#ff4757">— removed</text>

            <text x="472" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">T. Williams</text>
            <text x="570" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#e8eaf0">2026-03-04</text>
            <text x="650" y="186" font-family="JetBrains Mono, monospace" font-size="9" fill="#00ff88">$475.00</text>
            <rect x="725" y="175" width="55" height="16" rx="3" fill="rgba(0,255,136,0.12)"/>
            <text x="752" y="186" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">COMPLETE</text>

            <!-- Summary bar -->
            <rect x="460" y="270" width="320" height="70" rx="0" fill="#0f0f1a" stroke="rgba(0,229,255,0.08)" stroke-width="1" stroke-dasharray="0"/>
            <text x="476" y="293" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b7280">SUMMARY</text>
            <text x="476" y="313" font-family="JetBrains Mono, monospace" font-size="10" fill="#00ff88">4 rows cleaned</text>
            <text x="580" y="313" font-family="JetBrains Mono, monospace" font-size="10" fill="#ffc13b">1 duplicate removed</text>
            <text x="476" y="328" font-family="JetBrains Mono, monospace" font-size="10" fill="#00e5ff">$4,625.50 total verified</text>
          </g>

          <!-- Flowing data particles (cyan dots moving right during animation) -->
          <g id="particles">
            <circle class="particle" cx="0" cy="155" r="3" fill="#ffc13b" opacity="0"/>
            <circle class="particle" cx="0" cy="170" r="2" fill="#00e5ff" opacity="0"/>
            <circle class="particle" cx="0" cy="185" r="2.5" fill="#ffc13b" opacity="0"/>
            <circle class="particle" cx="0" cy="200" r="2" fill="#00e5ff" opacity="0"/>
          </g>
        </svg>

        <!-- Animation labels -->
        <div class="animation-labels">
          <div class="anim-label anim-label--before">
            <span class="anim-label-dot" style="background: var(--red);"></span>
            <span class="font-mono">Manual / Inconsistent</span>
          </div>
          <div class="anim-label anim-label--script">
            <span class="anim-label-dot" style="background: var(--gold);"></span>
            <span class="font-mono">Script Fires</span>
          </div>
          <div class="anim-label anim-label--after">
            <span class="anim-label-dot" style="background: var(--cyan);"></span>
            <span class="font-mono">Clean / Verified</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem: Pain Points (D16 loss aversion) -->
  <section class="section-lg problem-section">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Sound Familiar?" />
        <h2 class="text-heading reveal">
          Every hour you spend on this is<br /><span class="text-red">an hour you can't get back</span>
        </h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 650px; margin: 1rem auto 0;">
          These aren't minor inconveniences. Across a year, they're days of your life — and your team's — spent on work a script should handle.
        </p>
      </div>

      <div class="problems-grid">
        <div class="problem-card card reveal" data-delay="0">
          <div class="problem-cost font-mono text-red">2.5 hrs/week</div>
          <h4 class="problem-title">Manual Report Building</h4>
          <p class="problem-desc">Pulling numbers from three systems every Monday. Copy, paste, format, repeat. Then doing it again next week.</p>
          <div class="problem-loss"><span class="font-mono text-dim">That's</span> <span class="font-mono text-red">130 hrs/year</span> <span class="font-mono text-dim">on one task</span></div>
        </div>
        <div class="problem-card card reveal" data-delay="0.08">
          <div class="problem-cost font-mono text-red">1.5 hrs/day</div>
          <h4 class="problem-title">Data Entry Between Systems</h4>
          <p class="problem-desc">Copying info from emails into your CRM, then your spreadsheet, then your invoicing tool. Every system wants the same data twice.</p>
          <div class="problem-loss"><span class="font-mono text-dim">That's</span> <span class="font-mono text-red">390 hrs/year</span> <span class="font-mono text-dim">per person</span></div>
        </div>
        <div class="problem-card card reveal" data-delay="0.16">
          <div class="problem-cost font-mono text-red">45 min/day</div>
          <h4 class="problem-title">File Sorting & Cleanup</h4>
          <p class="problem-desc">Renaming downloads, organizing by client or date, converting formats. Tedious work that never quite stays done.</p>
          <div class="problem-loss"><span class="font-mono text-dim">That's</span> <span class="font-mono text-red">195 hrs/year</span> <span class="font-mono text-dim">of button-clicking</span></div>
        </div>
        <div class="problem-card card reveal" data-delay="0.24">
          <div class="problem-cost font-mono text-red">3 hrs/week</div>
          <h4 class="problem-title">Status Update Rounds</h4>
          <p class="problem-desc">Chasing team members for updates, compiling them, formatting a summary, sending it to leadership. Every. Single. Week.</p>
          <div class="problem-loss"><span class="font-mono text-dim">That's</span> <span class="font-mono text-red">156 hrs/year</span> <span class="font-mono text-dim">of status theater</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three-Tier Automation Ladder -->
  <section class="section-lg" id="tiers">
    <div class="container">
      <div class="section-header">
        <SectionLabel text="The Automation Ladder" color="cyan" />
        <h2 class="text-heading reveal">Three levels of freedom from manual work</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1">
          Not every problem needs a full platform. Some need a 20-line script. The key is matching the right level of automation to the right problem.
        </p>
      </div>

      <div class="tiers-grid">
        <!-- Tier 1 -->
        <div class="tier-card tier-card--gold card reveal" data-delay="0">
          <div class="tier-header">
            <span class="tier-number font-mono text-gold">01</span>
            <span class="tier-badge font-mono tag">Quick Win</span>
          </div>
          <h3 class="tier-title">Quick Scripts</h3>
          <div class="tier-price-group">
            <p class="tier-price font-mono text-gold">$350 – $700</p>
            <p class="tier-market font-mono">Market: <s>$500 – $1,000</s></p>
          </div>
          <p class="tier-desc text-body">
            Small, targeted fixes that kill one repetitive task dead. Built in a day, saving time forever.
          </p>
          <ul class="tier-examples">
            <li class="tier-example"><span class="tier-dot tier-dot--gold"></span>Excel macros & formatters</li>
            <li class="tier-example"><span class="tier-dot tier-dot--gold"></span>File sorters & renamers</li>
            <li class="tier-example"><span class="tier-dot tier-dot--gold"></span>Email template generators</li>
            <li class="tier-example"><span class="tier-dot tier-dot--gold"></span>Data cleanup scripts</li>
          </ul>
          <div class="tier-savings">
            <span class="tier-savings-value font-mono text-gold">30 min/day saved</span>
            <span class="tier-savings-label">per automation — for free from here on</span>
          </div>
        </div>

        <!-- Tier 2 -->
        <div class="tier-card tier-card--cyan card reveal" data-delay="0.1">
          <div class="tier-header">
            <span class="tier-number font-mono text-cyan">02</span>
            <span class="tier-badge font-mono tag tag-cyan">Growth Build</span>
          </div>
          <h3 class="tier-title">Connected Automations</h3>
          <div class="tier-price-group">
            <p class="tier-price font-mono text-cyan">$4,200 – $5,600</p>
            <p class="tier-market font-mono">Market: <s>$6,000 – $8,000</s></p>
          </div>
          <p class="tier-desc text-body">
            Multiple tools talking to each other. Data flows between systems without anyone touching it.
          </p>
          <ul class="tier-examples">
            <li class="tier-example"><span class="tier-dot tier-dot--cyan"></span>API integrations & syncs</li>
            <li class="tier-example"><span class="tier-dot tier-dot--cyan"></span>Web scrapers & data pipelines</li>
            <li class="tier-example"><span class="tier-dot tier-dot--cyan"></span>Multi-tool workflow chains</li>
            <li class="tier-example"><span class="tier-dot tier-dot--cyan"></span>Scheduled report generation</li>
          </ul>
          <div class="tier-savings">
            <span class="tier-savings-value font-mono text-cyan">Hours/day saved</span>
            <span class="tier-savings-label">across your team — workflows run while you sleep</span>
          </div>
        </div>

        <!-- Tier 3 -->
        <div class="tier-card tier-card--green card reveal" data-delay="0.2">
          <div class="tier-header">
            <span class="tier-number font-mono text-green">03</span>
            <span class="tier-badge font-mono tag tag-green">Full System</span>
          </div>
          <h3 class="tier-title">Full Automation Systems</h3>
          <div class="tier-price-group">
            <p class="tier-price font-mono text-green">$10,500 – $14,000</p>
            <p class="tier-market font-mono">Market: <s>$15,000 – $20,000</s></p>
          </div>
          <p class="tier-desc text-body">
            End-to-end systems that replace entire manual processes. AI-integrated, self-running, self-reporting.
          </p>
          <ul class="tier-examples">
            <li class="tier-example"><span class="tier-dot tier-dot--green"></span>End-to-end process automation</li>
            <li class="tier-example"><span class="tier-dot tier-dot--green"></span>AI-powered decision engines</li>
            <li class="tier-example"><span class="tier-dot tier-dot--green"></span>Self-monitoring dashboards</li>
            <li class="tier-example"><span class="tier-dot tier-dot--green"></span>Complete operational platforms</li>
          </ul>
          <div class="tier-savings">
            <span class="tier-savings-value font-mono text-green">Entire roles freed</span>
            <span class="tier-savings-label">full process replacement — not just faster, eliminated</span>
          </div>
        </div>
      </div>
      <div class="launch-banner reveal" data-delay="0.3">
        <span class="launch-banner__icon mono">◈</span>
        <span>Pre-portfolio rates. Pricing increases with each completed case study.</span>
      </div>
    </div>
  </section>

  <!-- Common Use Cases Grid -->
  <section class="section-lg usecases-section">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="What Gets Automated" />
        <h2 class="text-heading reveal">Things you didn't know could be automated</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 650px;">
          Most people don't realize how much of their day is automatable. If you recognize any of these, let's talk.
        </p>
      </div>

      <div class="usecases-grid">
        {[
          { icon: '01', title: 'Building Reports Manually', desc: 'Pulling numbers from three systems, pasting into a spreadsheet, formatting it every Monday morning.' },
          { icon: '02', title: 'Data Entry Between Systems', desc: 'Copying info from emails into your CRM, then into your spreadsheet, then into your invoicing tool.' },
          { icon: '03', title: 'Copy-Paste Workflows', desc: 'Moving data between tabs, apps, or documents because nothing talks to anything else.' },
          { icon: '04', title: 'File Formatting & Sorting', desc: 'Renaming downloads, converting formats, organizing into folders by date or client name.' },
          { icon: '05', title: 'Repetitive Email Responses', desc: 'Sending the same confirmation, follow-up, or status update dozens of times per week.' },
          { icon: '06', title: 'Scheduling & Coordination', desc: 'Back-and-forth emails to find meeting times, manually updating shared calendars, sending reminders.' },
          { icon: '07', title: 'Invoice Processing', desc: 'Manually entering invoice data, matching POs, chasing approvals, updating your books.' },
          { icon: '08', title: 'Inventory Tracking', desc: 'Counting stock by hand, updating spreadsheets, reordering when levels drop below thresholds.' },
          { icon: '09', title: 'Research & Data Gathering', desc: 'Visiting the same sites daily to check prices, leads, or competitor info and logging it manually.' },
