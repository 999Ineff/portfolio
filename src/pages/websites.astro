<script>
  // Scale preset iframes
  function scalePreviewIframes() {
    document.querySelectorAll('.preset-preview').forEach((container) => {
      const width = container.clientWidth;
      if (width > 0) {
        const scale = width / 1280;
        (container as HTMLElement).style.setProperty('--preview-scale', String(scale));
      }
    });
  }

  scalePreviewIframes();
  window.addEventListener('resize', scalePreviewIframes);
  document.addEventListener('astro:after-swap', scalePreviewIframes);

  // Website transformation animation
  (function() {
    const stage = document.getElementById('website-animation');
    if (!stage) return;

    let animated = false;

    function runAnimation() {
      if (animated) return;
      animated = true;

      const gsap = (window as any).gsap;
      if (!gsap) return;

      const tl = gsap.timeline();

      // Phase 1: Transform arrow appears
      tl.to('#transform-arrow', {
        opacity: 1,
        duration: 0.5,
        ease: 'power2.out',
      }, 0.8);

      // Phase 2: Before group dims
      tl.to('#before-group', {
        opacity: 0.4,
        duration: 0.6,
        ease: 'power2.out',
      }, 1.4);

      // Phase 3: After group fades in
      tl.to('#after-group', {
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
      }, 1.8);

      // Phase 4: Before completely fades
      tl.to('#before-group', {
        opacity: 0.15,
        duration: 0.4,
        ease: 'power2.in',
      }, 2.4);
    }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runAnimation();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      observer.observe(stage);
    } else {
      setTimeout(runAnimation, 1000);
    }
  })();
</script>
