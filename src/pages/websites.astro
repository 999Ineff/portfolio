  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height) + var(--space-md));
    padding-bottom: var(--space-lg);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 800px;
  }

  .hero-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    text-align: left;
