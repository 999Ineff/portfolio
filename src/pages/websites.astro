---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CTA from '../components/CTA.astro';
import ComingSoon from '../components/ComingSoon.astro';

const stylePresets = [
  { name: 'bold-playful', label: 'Bold & Playful', description: 'High-energy colors, chunky type, and playful geometry for brands that refuse to blend in.' },
  { name: 'corporate-saas', label: 'Corporate SaaS', description: 'Clean grids, confident spacing, and trust-building layouts for B2B products and platforms.' },
  { name: 'dark-tech', label: 'Dark Tech', description: 'Deep backgrounds, neon accents, and sharp edges for dev tools, AI, and modern tech.' },
  { name: 'editorial', label: 'Editorial', description: 'Typography-driven layouts with generous whitespace, perfect for long-form content and storytelling.' },
  { name: 'luxury', label: 'Luxury', description: 'Refined serif type, muted palettes, and slow transitions for premium and high-end brands.' },
  { name: 'minimal', label: 'Minimal', description: 'Stripped to essentials. Maximum breathing room, invisible grids, and quiet confidence.' },
  { name: 'tierra-developer', label: 'Tierra Developer', description: 'Warm earth tones meet developer precision. Terminal aesthetics with an organic twist.' },
  { name: 'warm-organic', label: 'Warm Organic', description: 'Soft gradients, rounded shapes, and earthy colors for wellness, food, and lifestyle brands.' },
  { name: 'warm-vibrant', label: 'Warm Vibrant', description: 'Sunset palettes, bold gradients, and energetic layouts for creative studios and agencies.' },
];

const processSteps = [
  { icon: '01', title: 'Discovery', desc: 'I learn your brand, goals, and audience. You show me what you love.' },
  { icon: '02', title: 'Design', desc: 'Style preset or custom vision — I craft the look before a single line of code.' },
  { icon: '03', title: 'Build', desc: 'Production-grade code. Fast, accessible, SEO-ready from day one.' },
  { icon: '04', title: 'SEO', desc: 'Technical audit, on-page optimization, schema markup, and performance tuning.' },
  { icon: '05', title: 'Launch', desc: 'Deployment, DNS, SSL, analytics — everything handled. You just share the link.' },
  { icon: '06', title: 'Maintain', desc: 'Ongoing updates, monitoring, and support. Your site stays fast and current.' },
];
---

<BaseLayout
  title="Tailored Websites"
  description="A website that works as hard as you do — not a template with your logo slapped on it. Premium custom web design with built-in SEO and personality."
>
  <!-- Hero Section -->
  <section class="hero section-lg">
    <div class="container hero-inner">
      <SectionLabel text="Tailored Websites" />

      <h1 class="hero-title reveal" data-delay="0.1">
        A Website That Works as Hard<br />
        <span class="text-gold">as You Do</span>
      </h1>

      <p class="hero-sub reveal" data-delay="0.2">
        Not a template. Not a page builder. A production-grade site that's unmistakably yours — built to convert, built to last.
      </p>

      <div class="hero-actions reveal" data-delay="0.3">
        <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">
          Book a 15-Min Call
        </a>
        <a href="#styles" class="btn btn-secondary">Browse Style Presets</a>
      </div>
    </div>
  </section>

  <!-- Narrative Animation: Template → Custom Transformation (D22 before/after) -->
  <section class="section narrative-section" id="transformation">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="The Transformation" color="cyan" />
        <h2 class="text-heading reveal">From template to unmistakable</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 600px;">
          Watch what happens when a generic template gets replaced with a site built around your brand — on every device, at every breakpoint.
        </p>
      </div>

      <!-- SVG Narrative Animation: Device transformation -->
      <div class="narrative-stage reveal" data-delay="0.2" id="website-animation">
        <svg
          class="narrative-svg"
          viewBox="0 0 800 380"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Animation showing transformation from generic template to custom branded website across desktop, tablet, and mobile"
          role="img"
        >
          <rect width="800" height="380" fill="#0a0a12"/>

          <!-- BEFORE: Generic Template (left) -->
          <g id="before-group">
            <!-- Desktop frame (boring gray) -->
            <rect x="20" y="20" width="340" height="220" rx="6" fill="#141420" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <!-- Browser bar -->
            <rect x="20" y="20" width="340" height="28" rx="6" fill="#1a1a28"/>
            <rect x="20" y="36" width="340" height="12" rx="0" fill="#1a1a28"/>
            <circle cx="36" cy="33" r="4" fill="#ff4757" opacity="0.5"/>
            <circle cx="50" cy="33" r="4" fill="#ffc13b" opacity="0.5"/>
            <circle cx="64" cy="33" r="4" fill="#00ff88" opacity="0.3"/>
            <rect x="80" y="28" width="200" height="10" rx="2" fill="#222233"/>
            <text x="180" y="36" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">yourwebsite.com</text>

            <!-- Nav bar: boring gray -->
            <rect x="20" y="48" width="340" height="30" fill="#1a1a28"/>
            <rect x="30" y="55" width="40" height="10" rx="2" fill="#2a2a3a"/>
            <rect x="200" y="57" width="25" height="6" rx="1" fill="#2a2a3a"/>
            <rect x="235" y="57" width="25" height="6" rx="1" fill="#2a2a3a"/>
            <rect x="270" y="57" width="25" height="6" rx="1" fill="#2a2a3a"/>
            <rect x="310" y="54" width="40" height="12" rx="2" fill="#2a2a3a"/>

            <!-- Hero: gray blob -->
            <rect x="20" y="78" width="340" height="90" fill="#12121e"/>
            <rect x="60" y="95" width="160" height="12" rx="2" fill="#2a2a3a"/>
            <rect x="60" y="113" width="200" height="8" rx="2" fill="#1e1e2e"/>
            <rect x="60" y="127" width="150" height="8" rx="2" fill="#1e1e2e"/>
            <rect x="60" y="145" width="70" height="18" rx="3" fill="#2a2a3a"/>
            <rect x="140" y="145" width="70" height="18" rx="3" fill="#222233"/>
            <!-- Stock photo placeholder -->
            <rect x="230" y="85" width="120" height="75" rx="4" fill="#1a1a28" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <text x="290" y="126" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#2a2a3a">photo.jpg</text>

            <!-- Services row: cookie-cutter cards -->
            <rect x="25" y="178" width="100" height="50" rx="2" fill="#12121e" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <rect x="135" y="178" width="100" height="50" rx="2" fill="#12121e" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <rect x="245" y="178" width="100" height="50" rx="2" fill="#12121e" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <text x="75" y="208" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#2a2a3a">Service 1</text>
            <text x="185" y="208" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#2a2a3a">Service 2</text>
            <text x="295" y="208" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#2a2a3a">Service 3</text>

            <!-- Mobile (broken) -->
            <rect x="50" y="252" width="80" height="110" rx="6" fill="#141420" stroke="rgba(255,71,87,0.2)" stroke-width="1"/>
            <rect x="50" y="252" width="80" height="20" rx="6" fill="#1a1a28"/>
            <rect x="50" y="262" width="80" height="10" rx="0" fill="#1a1a28"/>
            <rect x="56" y="280" width="68" height="8" rx="1" fill="#1a1a28"/>
            <!-- overflow text -->
            <text x="130" y="290" font-family="JetBrains Mono, monospace" font-size="6" fill="#ff4757">overflow</text>
            <rect x="56" y="295" width="80" height="6" rx="1" fill="#1a1a28"/>
            <rect x="56" y="308" width="80" height="6" rx="1" fill="#1a1a28"/>
            <rect x="56" y="322" width="50" height="18" rx="2" fill="#2a2a3a"/>

            <!-- Tablet (overlapping content) -->
            <rect x="200" y="252" width="140" height="110" rx="6" fill="#141420" stroke="rgba(255,71,87,0.2)" stroke-width="1"/>
            <rect x="200" y="252" width="140" height="20" rx="6" fill="#1a1a28"/>
            <rect x="200" y="262" width="140" height="10" rx="0" fill="#1a1a28"/>
            <rect x="206" y="278" width="128" height="10" rx="1" fill="#1a1a28"/>
            <rect x="206" y="294" width="60" height="40" rx="2" fill="#1a1a28"/>
            <rect x="274" y="294" width="60" height="40" rx="2" fill="#1a1a28"/>
            <!-- Broken element badge -->
            <text x="290" y="322" font-family="JetBrains Mono, monospace" font-size="6" fill="#ff4757" transform="rotate(-15, 290, 322)">broken</text>

            <!-- BEFORE labels -->
            <text x="190" y="248" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">TEMPLATE — NOT MOBILE-READY</text>
          </g>

          <!-- Center arrow/transform indicator -->
          <g id="transform-arrow" opacity="0">
            <rect x="368" y="155" width="64" height="64" rx="32" fill="#0a0a12" stroke="rgba(255,193,59,0.3)" stroke-width="1"/>
            <text x="400" y="192" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="18" fill="#ffc13b">&#x2192;</text>
            <text x="400" y="140" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ffc13b">CUSTOM</text>
            <text x="400" y="152" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ffc13b">BUILD</text>
          </g>

          <!-- AFTER: Custom Branded Site (right) -->
          <g id="after-group" opacity="0">
            <!-- Desktop frame: polished -->
            <rect x="440" y="20" width="340" height="220" rx="6" fill="#141420" stroke="rgba(0,229,255,0.2)" stroke-width="1"/>
            <rect x="440" y="20" width="340" height="28" rx="6" fill="#1a1a28"/>
            <rect x="440" y="36" width="340" height="12" rx="0" fill="#1a1a28"/>
            <circle cx="456" cy="33" r="4" fill="#ff4757" opacity="0.7"/>
            <circle cx="470" cy="33" r="4" fill="#ffc13b" opacity="0.7"/>
            <circle cx="484" cy="33" r="4" fill="#00ff88" opacity="0.7"/>
            <rect x="500" y="28" width="200" height="10" rx="2" fill="#1e1e2e"/>
            <text x="600" y="36" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">yourbrand.com</text>

            <!-- Nav: branded with gold accent -->
            <rect x="440" y="48" width="340" height="30" fill="#0f0f1a"/>
            <rect x="452" y="54" width="50" height="12" rx="2" fill="rgba(255,193,59,0.15)" stroke="rgba(255,193,59,0.3)" stroke-width="0.5"/>
            <text x="477" y="63" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#ffc13b">BRAND</text>
            <text x="580" y="63" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">Work</text>
            <text x="615" y="63" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">About</text>
            <text x="650" y="63" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">Contact</text>
            <rect x="720" y="54" width="50" height="18" rx="3" fill="rgba(255,193,59,0.15)" stroke="rgba(255,193,59,0.4)" stroke-width="0.5"/>
            <text x="745" y="66" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#ffc13b">Book Call</text>

            <!-- Hero: premium layout -->
            <rect x="440" y="78" width="340" height="90" fill="#0a0a12"/>
            <!-- Gradient orb (subtle) -->
            <ellipse cx="730" cy="100" rx="80" ry="50" fill="rgba(0,229,255,0.04)"/>
            <ellipse cx="550" cy="130" rx="60" ry="35" fill="rgba(255,193,59,0.03)"/>

            <rect x="452" y="88" width="120" height="14" rx="2" fill="rgba(255,193,59,0.2)"/>
            <text x="512" y="99" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ffc13b">YOUR BRAND TAGLINE</text>
            <rect x="452" y="108" width="200" height="10" rx="2" fill="#222233"/>
            <rect x="452" y="124" width="160" height="8" rx="2" fill="#1e1e2e"/>
            <rect x="452" y="140" width="70" height="20" rx="4" fill="rgba(255,193,59,0.2)" stroke="rgba(255,193,59,0.5)" stroke-width="0.5"/>
            <text x="487" y="153" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ffc13b">Get Started</text>
            <rect x="530" y="140" width="70" height="20" rx="4" stroke="rgba(0,229,255,0.4)" stroke-width="0.5" fill="transparent"/>
            <text x="565" y="153" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00e5ff">See Work</text>

            <!-- Premium service cards -->
            <rect x="445" y="178" width="102" height="50" rx="4" fill="#141420" stroke="rgba(255,193,59,0.15)" stroke-width="0.5"/>
            <rect x="555" y="178" width="102" height="50" rx="4" fill="#141420" stroke="rgba(0,229,255,0.15)" stroke-width="0.5"/>
            <rect x="665" y="178" width="102" height="50" rx="4" fill="#141420" stroke="rgba(0,255,136,0.15)" stroke-width="0.5"/>
            <text x="496" y="200" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#ffc13b">Automation</text>
            <text x="606" y="200" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00e5ff">Websites</text>
            <text x="716" y="200" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">Platforms</text>
            <text x="496" y="214" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#6b7280">from $350</text>
            <text x="606" y="214" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#6b7280">from $4,200</text>
            <text x="716" y="214" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#6b7280">from $10,500</text>

            <!-- Mobile: perfect responsive -->
            <rect x="470" y="252" width="80" height="110" rx="6" fill="#141420" stroke="rgba(0,229,255,0.2)" stroke-width="0.75"/>
            <rect x="470" y="252" width="80" height="20" rx="6" fill="#0f0f1a"/>
            <rect x="470" y="262" width="80" height="10" rx="0" fill="#0f0f1a"/>
            <text x="510" y="269" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="#ffc13b">BRAND</text>
            <rect x="476" y="280" width="68" height="8" rx="2" fill="rgba(255,193,59,0.15)"/>
            <rect x="476" y="293" width="68" height="6" rx="1" fill="#1a1a28"/>
            <rect x="476" y="304" width="55" height="6" rx="1" fill="#1a1a28"/>
            <rect x="476" y="318" width="40" height="14" rx="3" fill="rgba(255,193,59,0.2)"/>
            <text x="496" y="328" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="#ffc13b">Book</text>

            <!-- Tablet: perfect responsive -->
            <rect x="580" y="252" width="160" height="110" rx="6" fill="#141420" stroke="rgba(0,229,255,0.2)" stroke-width="0.75"/>
            <rect x="580" y="252" width="160" height="20" rx="6" fill="#0f0f1a"/>
            <rect x="580" y="262" width="160" height="10" rx="0" fill="#0f0f1a"/>
            <text x="660" y="269" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="#a0a8bb">BRAND   Work   About</text>
            <rect x="586" y="278" width="148" height="12" rx="2" fill="rgba(255,193,59,0.1)"/>
            <rect x="586" y="295" width="148" height="8" rx="1" fill="#1a1a28"/>
            <rect x="586" y="308" width="120" height="6" rx="1" fill="#1a1a28"/>
            <rect x="586" y="318" width="65" height="16" rx="3" fill="rgba(255,193,59,0.15)" stroke="rgba(255,193,59,0.4)" stroke-width="0.5"/>
            <rect x="659" y="318" width="75" height="16" rx="3" stroke="rgba(0,229,255,0.3)" stroke-width="0.5" fill="transparent"/>
            <text x="618" y="329" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="#ffc13b">Get Started</text>
            <text x="696" y="329" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="#00e5ff">See Work</text>

            <!-- AFTER labels -->
            <text x="610" y="248" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#00e5ff">CUSTOM — PIXEL-PERFECT ON ALL DEVICES</text>
          </g>
        </svg>

        <div class="animation-labels">
          <div class="anim-label">
            <span class="anim-label-dot" style="background: var(--red);"></span>
            <span class="font-mono">Generic Template</span>
          </div>
          <div class="anim-label">
            <span class="anim-label-dot" style="background: var(--cyan);"></span>
            <span class="font-mono">Custom Build — Every Device</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem: Why templates fail (D16 loss aversion, D22 before/after) -->
  <section class="section-lg problem-section">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="The Real Cost" />
        <h2 class="text-heading reveal">
          What a bad website<br /><span class="text-red">actually costs you</span>
        </h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 650px;">
          You're not just paying for a site. You're betting on whether people trust you enough to become customers. A cheap site costs money every day it exists.
        </p>
      </div>

      <div class="problems-grid">
        <div class="problem-card card reveal" data-delay="0">
          <div class="problem-before">Template / DIY</div>
          <h4 class="problem-title">Looks like 10,000 other sites</h4>
          <p class="problem-desc">Page builders pull from the same theme libraries. Your "unique" site is visually identical to your competitors'. There is no design differentiation at all.</p>
          <div class="problem-loss">
            <span class="font-mono text-dim">Outcome:</span>
            <span class="font-mono text-red"> Forgettable. Next.</span>
          </div>
        </div>
        <div class="problem-card card reveal" data-delay="0.08">
          <div class="problem-before">Template / DIY</div>
          <h4 class="problem-title">Breaks on mobile</h4>
          <p class="problem-desc">Over 60% of web traffic is mobile. Templates "responsive" mode means stacked columns and tiny buttons. That's not mobile-first — it's mobile-tolerated.</p>
          <div class="problem-loss">
            <span class="font-mono text-dim">Outcome:</span>
            <span class="font-mono text-red"> 60% of visitors leave immediately</span>
          </div>
        </div>
        <div class="problem-card card reveal" data-delay="0.16">
          <div class="problem-before">Template / DIY</div>
          <h4 class="problem-title">Loads in 4+ seconds</h4>
          <p class="problem-desc">Page builders load every plugin, every font, every unoptimized image. Google's ranking algorithm penalizes slow sites. You're paying in rankings every month.</p>
          <div class="problem-loss">
            <span class="font-mono text-dim">Outcome:</span>
            <span class="font-mono text-red"> Page 2 on Google — invisible</span>
          </div>
        </div>
        <div class="problem-card card reveal" data-delay="0.24">
          <div class="problem-before">Template / DIY</div>
          <h4 class="problem-title">No conversion path</h4>
          <p class="problem-desc">Templates are designed to look complete, not to convert. There's no CTA hierarchy, no trust-building flow, no persona-appropriate message. Just content in boxes.</p>
          <div class="problem-loss">
            <span class="font-mono text-dim">Outcome:</span>
            <span class="font-mono text-red"> Visitors leave without acting</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Style Presets Gallery -->
  <section class="section-lg" id="styles">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Style Presets" color="cyan" />
        <h2 class="text-heading reveal">Pick a Style. I'll Build It for You.</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 650px;">
          Nine real, working style demos you can browse right now. Find the vibe that fits your brand — or use them as a starting point for something entirely yours.
        </p>
      </div>

      <div class="presets-grid">
        {stylePresets.map((preset, i) => (
          <a
            href={`/styles/${preset.name}.html`}
            class="preset-card card reveal"
            data-delay={`${(i % 3) * 0.1}`}
          >
            <div class="preset-preview">
              <iframe
                src={`/styles/${preset.name}.html`}
                loading="lazy"
                tabindex="-1"
                aria-hidden="true"
                class="preset-iframe"
                title={`${preset.label} preview`}
              ></iframe>
              <div class="preset-preview-overlay"></div>
            </div>
            <div class="preset-info">
              <div class="preset-name-row">
                <span class="preset-name font-mono">{preset.label}</span>
                <span class="preset-slug font-mono text-dim">/{preset.name}</span>
              </div>
              <p class="preset-desc">{preset.description}</p>
              <div class="preset-hover-cta">
                <span class="font-mono">View Live Demo</span>
                <span class="preset-arrow">&rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider container"></div>

  <!-- Tiers -->
  <section class="section-lg" id="tiers">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Pricing" color="gold" />
        <h2 class="text-heading reveal">Transparent pricing. No surprises.</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 650px;">
          Custom sites shouldn't be a mystery. Here's exactly what each tier includes and what it costs. Market rate shown for context.
        </p>
      </div>

      <div class="website-tiers-grid">
        <div class="website-tier card reveal" data-delay="0">
          <div class="tier-label tag tag-cyan font-mono">Growth Build</div>
          <h3 class="tier-name">Custom Website</h3>
          <div class="tier-pricing">
            <span class="tier-price font-mono text-gold">$4,200 – $5,600</span>
            <span class="tier-market font-mono text-dim">Market: $6,000 – $8,000</span>
          </div>
          <p class="tier-desc text-body">A fully custom-designed, mobile-first website. No templates, no page builders. Built to rank, built to convert.</p>
          <ul class="tier-features">
            <li class="tier-feature"><span class="feature-check text-gold">&#10003;</span>Custom design (no templates)</li>
            <li class="tier-feature"><span class="feature-check text-gold">&#10003;</span>Mobile-first, pixel-perfect</li>
