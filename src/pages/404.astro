---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="This page doesn't exist — but your next project could. Head back to Ineffable."
>
  <section class="error-section" aria-label="Page not found">
    <!-- Animated background glitch lines -->
    <div class="glitch-grid" aria-hidden="true">
      {Array.from({ length: 8 }).map((_, i) => (
        <div class="glitch-line" style={`--delay: ${i * 0.15}s; --width: ${30 + Math.random() * 50}%`}></div>
      ))}
    </div>

    <div class="container error-inner">
      <!-- The 404 number — large, gold, animated -->
      <div class="error-number-wrap" aria-hidden="true">
        <span class="error-number">4</span>
        <span class="error-zero">
          <span class="zero-ring"></span>
          <span class="zero-core">0</span>
        </span>
        <span class="error-number">4</span>
      </div>

      <div class="error-content">
        <h1 class="error-title">This page doesn't exist.</h1>
        <p class="error-subtext">But your next project could.</p>
        <p class="error-desc">
          You took a wrong turn — or maybe a link broke. Either way, there's nothing here.
          What <em>is</em> here: custom software, automation systems, and websites built to
          actually work.
        </p>
      </div>

      <div class="error-actions">
        <a href="/" class="btn btn-primary">Go Home</a>
        <a href="/automation" class="btn btn-secondary">See What I Build</a>
      </div>

      <!-- Subtle status line, like a terminal -->
      <div class="error-terminal" aria-hidden="true">
        <span class="terminal-prompt">$</span>
        <span class="terminal-text">GET /??? — 404 Not Found</span>
        <span class="terminal-cursor"></span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: calc(var(--nav-height) + var(--space-xl)) var(--space-sm) var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  /* ── Animated glitch grid lines ─────────────────────────── */
  .glitch-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .glitch-line {
    position: absolute;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 193, 59, 0.12), transparent);
    animation: glitch-sweep 4s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    width: var(--width, 40%);
    top: calc(10% + (var(--delay, 0s) / 4s) * 80%);
    will-change: transform, opacity;
  }

  @keyframes glitch-sweep {
    0%   { transform: translateX(-100%); opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateX(200vw); opacity: 0; }
  }

  /* ── Main content ────────────────────────────────────────── */
  .error-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    max-width: 640px;
    position: relative;
    z-index: 1;
  }

  /* ── 404 Number ──────────────────────────────────────────── */
  .error-number-wrap {
    display: flex;
    align-items: center;
    gap: 0.1em;
    line-height: 1;
    user-select: none;
  }

  .error-number {
    font-family: var(--font-display);
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    background: var(--gradient-gold);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.25;
  }

  /* The 0 in the middle — has a ring animation */
  .error-zero {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 900;
    letter-spacing: -0.05em;
  }

  .zero-core {
    background: var(--gradient-gold);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.25;
    position: relative;
    z-index: 1;
  }

  /* Rotating ring around the 0 */
  .zero-ring {
    position: absolute;
    inset: 0.05em;
    border-radius: 50%;
    border: 2px solid transparent;
    border-top-color: rgba(255, 193, 59, 0.4);
    border-right-color: rgba(255, 193, 59, 0.15);
    animation: ring-spin 3s linear infinite;
    will-change: transform;
  }

  @keyframes ring-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Text Content ────────────────────────────────────────── */
  .error-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .error-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .error-subtext {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--gold);
    margin-bottom: var(--space-xs);
  }

  .error-desc {
    font-size: var(--text-base);
    color: var(--text-dim);
    line-height: 1.75;
    max-width: 480px;
    margin: 0 auto;
  }

  .error-desc em {
    font-style: italic;
    color: var(--text-secondary);
  }

  /* ── CTAs ────────────────────────────────────────────────── */
  .error-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Terminal line ───────────────────────────────────────── */
  .error-terminal {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-md);
    padding: 0.5rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .terminal-prompt {
    color: var(--green);
    font-weight: 600;
  }

  .terminal-text {
    color: var(--text-dim);
  }

  /* Blinking cursor */
  .terminal-cursor {
    display: inline-block;
    width: 7px;
    height: 1em;
    background: var(--gold);
    opacity: 0.7;
    animation: blink 1.1s step-end infinite;
    will-change: opacity;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.7; }
    50%       { opacity: 0; }
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 480px) {
    .error-actions {
      flex-direction: column;
      width: 100%;
    }

    .error-actions .btn {
      width: 100%;
    }

    .error-terminal {
      font-size: 0.65rem;
      flex-wrap: wrap;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .glitch-line,
    .zero-ring,
    .terminal-cursor {
      animation: none;
    }
    .zero-ring {
      border-color: rgba(255, 193, 59, 0.25);
    }
    .terminal-cursor {
      opacity: 0.7;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  // GSAP entrance animation — stagger in the elements
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.from('.error-number-wrap', { opacity: 0, scale: 0.85, duration: 1.0 })
      .from('.error-content', { opacity: 0, y: 30, duration: 0.8 }, '-=0.5')
      .from('.error-actions', { opacity: 0, y: 20, duration: 0.6 }, '-=0.4')
      .from('.error-terminal', { opacity: 0, duration: 0.4 }, '-=0.2');
  }
</script>
