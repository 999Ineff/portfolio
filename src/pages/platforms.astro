---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout
  title="Custom Platforms"
  description="Replace 10 disconnected tools with one system built for how you actually work. Dashboards, databases, AI assistants, and integrations — engineered to run your operations."
>
  <!-- Hero -->
  <section class="hero section-lg">
    <div class="container hero-inner">
      <SectionLabel text="Custom Platforms" />
      <h1 class="hero-title reveal" data-delay="0.1">
        Replace 10 Disconnected Tools<br />
        <span class="text-gold">With One System That Works</span>
      </h1>
      <p class="hero-sub reveal" data-delay="0.2">
        Your CRM doesn't talk to your spreadsheets. Your spreadsheets don't talk to your accounting.
        Your accounting doesn't talk to anything. I build the system that connects all of it.
      </p>
      <div class="hero-actions reveal" data-delay="0.3">
        <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">
          Schedule a Discovery Session
        </a>
        <a href="#case-bce" class="btn btn-secondary">See a Platform</a>
      </div>
    </div>
  </section>

  <!-- Narrative Animation: Disconnected → Connected Systems -->
  <section class="section narrative-section" id="animation">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="The Architecture" color="cyan" />
        <h2 class="text-heading reveal">From scattered tools to unified system</h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 600px;">
          Watch disconnected silos connect into a single source of truth. Data flows. Decisions accelerate.
        </p>
      </div>

      <div class="narrative-stage reveal" data-delay="0.2" id="platform-animation">
        <svg
          class="narrative-svg"
          viewBox="0 0 800 380"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Animation showing scattered disconnected tools connecting into a unified platform dashboard"
          role="img"
        >
          <rect width="800" height="380" fill="#0a0a12"/>

          <!-- BEFORE: Scattered disconnected tools -->
          <g id="scattered-tools">
            <!-- CRM box (top left, disconnected) -->
            <g id="tool-crm">
              <rect x="30" y="30" width="110" height="60" rx="6" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1" stroke-dasharray="4 2"/>
              <text x="85" y="55" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">CRM</text>
              <text x="85" y="70" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">Salesforce</text>
              <text x="85" y="81" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">$150/mo</text>
            </g>

            <!-- Email box (top center-left) -->
            <g id="tool-email">
              <rect x="180" y="15" width="110" height="60" rx="6" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1" stroke-dasharray="4 2"/>
              <text x="235" y="40" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">EMAIL</text>
              <text x="235" y="55" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">Mailchimp</text>
              <text x="235" y="66" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">$75/mo</text>
            </g>

            <!-- Spreadsheet (top right) -->
            <g id="tool-sheets">
              <rect x="330" y="25" width="110" height="60" rx="6" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1" stroke-dasharray="4 2"/>
              <text x="385" y="50" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">SHEETS</text>
              <text x="385" y="65" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">Manual entry</text>
              <text x="385" y="76" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">error-prone</text>
            </g>

            <!-- Accounting (bottom left) -->
            <g id="tool-accounting">
              <rect x="30" y="190" width="110" height="60" rx="6" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1" stroke-dasharray="4 2"/>
              <text x="85" y="215" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">ACCOUNTING</text>
              <text x="85" y="230" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">QuickBooks</text>
              <text x="85" y="241" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">$60/mo</text>
            </g>

            <!-- Project mgmt (bottom center-left) -->
            <g id="tool-pm">
              <rect x="180" y="205" width="110" height="60" rx="6" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1" stroke-dasharray="4 2"/>
              <text x="235" y="230" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">PROJECTS</text>
              <text x="235" y="245" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">Asana</text>
              <text x="235" y="256" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">$50/mo</text>
            </g>

            <!-- Analytics (bottom right) -->
            <g id="tool-analytics">
              <rect x="330" y="195" width="110" height="60" rx="6" fill="#141420" stroke="rgba(255,71,87,0.3)" stroke-width="1" stroke-dasharray="4 2"/>
              <text x="385" y="220" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#ff4757">ANALYTICS</text>
              <text x="385" y="235" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">Multiple tools</text>
              <text x="385" y="246" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4a4a5c">no single view</text>
            </g>

            <!-- Cost total label -->
            <text x="220" y="300" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#ff4757">$335–$500+/mo, 6 logins, no unified view</text>
          </g>

          <!-- CENTER: Platform hub (hidden initially) -->
          <g id="platform-hub" opacity="0">
            <!-- Connection lines flowing to center -->
            <line id="line-crm" x1="140" y1="60" x2="480" y2="190" stroke="#ffc13b" stroke-width="1" stroke-dasharray="0" opacity="0"/>
            <line id="line-email" x1="290" y1="45" x2="480" y2="190" stroke="#00e5ff" stroke-width="1" stroke-dasharray="0" opacity="0"/>
            <line id="line-sheets" x1="385" y1="85" x2="480" y2="190" stroke="#00ff88" stroke-width="1" stroke-dasharray="0" opacity="0"/>
            <line id="line-accounting" x1="140" y1="220" x2="480" y2="190" stroke="#ffc13b" stroke-width="1" stroke-dasharray="0" opacity="0"/>
            <line id="line-pm" x1="290" y1="235" x2="480" y2="190" stroke="#00e5ff" stroke-width="1" stroke-dasharray="0" opacity="0"/>
            <line id="line-analytics" x1="385" y1="225" x2="480" y2="190" stroke="#00ff88" stroke-width="1" stroke-dasharray="0" opacity="0"/>

            <!-- Data flow dots on lines -->
            <circle id="dot1" cx="140" cy="60" r="4" fill="#ffc13b" opacity="0"/>
            <circle id="dot2" cx="290" cy="45" r="4" fill="#00e5ff" opacity="0"/>
            <circle id="dot3" cx="385" cy="85" r="4" fill="#00ff88" opacity="0"/>
          </g>

          <!-- RIGHT: Unified Dashboard Panel -->
          <g id="dashboard" opacity="0">
            <rect x="460" y="20" width="320" height="320" rx="8" fill="#141420" stroke="rgba(0,229,255,0.2)" stroke-width="1"/>
            <rect x="460" y="20" width="320" height="40" rx="8" fill="#0f0f1a"/>
            <rect x="460" y="48" width="320" height="12" rx="0" fill="#0f0f1a"/>
            <text x="476" y="45" font-family="JetBrains Mono, monospace" font-size="10" fill="#ffc13b">Ineffable Platform</text>
            <text x="750" y="45" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">LIVE</text>
            <circle cx="760" cy="41" r="4" fill="#00ff88" opacity="0.8"/>

            <!-- Metric cards row -->
            <rect x="468" y="68" width="90" height="50" rx="4" fill="#0a0a12" stroke="rgba(255,193,59,0.15)" stroke-width="0.5"/>
            <text x="513" y="86" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#6b7280">REVENUE</text>
            <text x="513" y="103" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="12" fill="#ffc13b" font-weight="700">$84K</text>
            <text x="513" y="113" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#00ff88">+12% MoM</text>

            <rect x="566" y="68" width="90" height="50" rx="4" fill="#0a0a12" stroke="rgba(0,229,255,0.15)" stroke-width="0.5"/>
            <text x="611" y="86" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#6b7280">LEADS</text>
            <text x="611" y="103" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="12" fill="#00e5ff" font-weight="700">247</text>
            <text x="611" y="113" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#00e5ff">this month</text>

            <rect x="664" y="68" width="90" height="50" rx="4" fill="#0a0a12" stroke="rgba(0,255,136,0.15)" stroke-width="0.5"/>
            <text x="709" y="86" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#6b7280">TASKS</text>
            <text x="709" y="103" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="12" fill="#00ff88" font-weight="700">94%</text>
            <text x="709" y="113" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#00ff88">on time</text>

            <!-- Mini chart -->
            <rect x="468" y="126" width="286" height="70" rx="4" fill="#0a0a12"/>
            <text x="476" y="140" font-family="JetBrains Mono, monospace" font-size="8" fill="#6b7280">REVENUE TREND</text>
            <polyline points="476,185 510,178 544,172 578,165 612,170 646,158 680,150 714,142 748,135" stroke="#ffc13b" stroke-width="1.5" fill="none" opacity="0.8"/>
            <polyline points="476,185 510,178 544,172 578,165 612,170 646,158 680,150 714,142 748,135 748,195 476,195" fill="rgba(255,193,59,0.06)" stroke="none"/>

            <!-- AI Query box -->
            <rect x="468" y="204" width="286" height="36" rx="4" fill="#0a0a12" stroke="rgba(0,229,255,0.15)" stroke-width="0.5"/>
            <text x="478" y="217" font-family="JetBrains Mono, monospace" font-size="8" fill="#00e5ff">&#x2BA7; AI</text>
            <text x="500" y="217" font-family="JetBrains Mono, monospace" font-size="8" fill="#a0a8bb">What was revenue last quarter?</text>
            <text x="478" y="232" font-family="JetBrains Mono, monospace" font-size="8" fill="#00ff88">$73,200 — up 18% vs Q3. Top client: Acme Corp ($14K)</text>

            <!-- Recent activity -->
            <rect x="468" y="248" width="286" height="80" rx="4" fill="#0a0a12"/>
            <text x="476" y="262" font-family="JetBrains Mono, monospace" font-size="8" fill="#6b7280">RECENT ACTIVITY</text>
            <text x="476" y="276" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">&#x2022; Lead from website — auto-added to CRM</text>
            <text x="476" y="289" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">&#x2022; Invoice #447 paid — QuickBooks synced</text>
            <text x="476" y="302" font-family="JetBrains Mono, monospace" font-size="7" fill="#a0a8bb">&#x2022; Monthly report generated — sent to owner</text>
            <text x="476" y="315" font-family="JetBrains Mono, monospace" font-size="7" fill="#00ff88">&#x2022; 0 manual steps required</text>
          </g>
        </svg>

        <div class="animation-labels">
          <div class="anim-label">
            <span class="anim-label-dot" style="background: var(--red);"></span>
            <span class="font-mono">6 disconnected tools, 6 logins</span>
          </div>
          <div class="anim-label">
            <span class="anim-label-dot" style="background: var(--cyan);"></span>
            <span class="font-mono">One platform, real-time, AI-queryable</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's a Platform? -->
  <section class="section-lg" id="what-is">
    <div class="container">
      <div class="section-header">
        <SectionLabel text="The Difference" color="cyan" />
        <h2 class="text-heading reveal">A website shows. A platform <span class="text-cyan">does.</span></h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 700px;">
          Most businesses get a website and call it done. But a platform connects your people,
          data, and workflows into one system that runs the business behind the scenes.
        </p>
      </div>

      <div class="platform-grid">
        {[
          { icon: '&#9633;', color: 'gold', title: 'Dashboard', desc: 'Real-time visibility into operations, finances, and KPIs — no spreadsheet required' },
          { icon: '&#9638;', color: 'cyan', title: 'Database', desc: 'Structured data storage with relationships, search, and automated sync' },
          { icon: '&#9672;', color: 'green', title: 'AI Assistant', desc: 'Natural language queries, smart categorization, pattern recognition' },
          { icon: '&#8644;', color: 'gold', title: 'API Integrations', desc: 'Connect to the tools you already use — no manual rekeying ever' },
          { icon: '&#9775;', color: 'cyan', title: 'User Management', desc: 'Roles, permissions, and team-based access control at every level' },
          { icon: '&#9707;', color: 'green', title: 'Automated Reporting', desc: 'Scheduled reports that build themselves from live data and send themselves' },
        ].map((item, i) => (
          <div class={`platform-item card reveal`} data-delay={`${i * 0.06}`}>
            <div class={`platform-icon text-${item.color}`} set:html={item.icon}></div>
            <h3 class="platform-item-title">{item.title}</h3>
            <p class="platform-item-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Problem: The Tool Sprawl Pain (D16 loss aversion) -->
  <section class="section-lg problem-section">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="The Real Cost" />
        <h2 class="text-heading reveal">
          Tool sprawl is <span class="text-red">bleeding you dry</span>
        </h2>
        <p class="section-subtext text-body reveal" data-delay="0.1" style="max-width: 650px;">
          The average SMB pays for 8–12 SaaS tools that don't talk to each other. The cost isn't just the subscriptions — it's the time lost to switching, reconciling, and re-entering data.
        </p>
      </div>

      <div class="problems-grid">
        <div class="problem-card card reveal" data-delay="0">
          <div class="problem-cost font-mono text-red">$500–$2,000/mo</div>
          <h4 class="problem-title">Tool Subscription Sprawl</h4>
          <p class="problem-desc">CRM + email + project management + analytics + accounting + invoicing + communication. Each one "just $50/month" — until you add them up.</p>
          <div class="problem-loss"><span class="font-mono text-dim">Year cost:</span> <span class="font-mono text-red">$6K–$24K — for tools that don't talk</span></div>
        </div>
        <div class="problem-card card reveal" data-delay="0.08">
          <div class="problem-cost font-mono text-red">3–5 hrs/week</div>
          <h4 class="problem-title">Data Reconciliation</h4>
          <p class="problem-desc">Your CRM says one thing. Your accounting says another. Your spreadsheet says something else. Someone spends Friday reconciling them. Every week.</p>
          <div class="problem-loss"><span class="font-mono text-dim">Year cost:</span> <span class="font-mono text-red">200+ hrs of high-value time on data janitor work</span></div>
        </div>
        <div class="problem-card card reveal" data-delay="0.16">
          <div class="problem-cost font-mono text-red">No single truth</div>
          <h4 class="problem-title">Decisions Made Blind</h4>
          <p class="problem-desc">To answer "how's the business doing?" you need to open 4 tabs, pull 3 reports, and do manual math. That's not a dashboard — that's detective work.</p>
          <div class="problem-loss"><span class="font-mono text-dim">Real cost:</span> <span class="font-mono text-red">Slow decisions + missed opportunities</span></div>
        </div>
        <div class="problem-card card reveal" data-delay="0.24">
          <div class="problem-cost font-mono text-red">6–10 logins</div>
          <h4 class="problem-title">Context Switching Tax</h4>
          <p class="problem-desc">Every time you jump between tools, you lose 23 minutes of focus. Multiply that by your team. Multiply that by a workday. That's the invisible productivity drain.</p>
          <div class="problem-loss"><span class="font-mono text-dim">Team cost:</span> <span class="font-mono text-red">Hours of lost focus per person per day</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study: BCE Owner Dashboard -->
  <section class="section-lg case-section" id="case-bce">
    <div class="container">
      <div class="section-header">
        <SectionLabel text="Case Study" color="gold" />
        <h2 class="text-heading reveal">Owner Operations Dashboard</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 750px;">
          Complete operational infrastructure for a service company — replacing disconnected spreadsheets,
          manual tracking, and guesswork with a single source of truth.
        </p>
      </div>

      <div class="case-showcase reveal" data-delay="0.2">
        <div class="case-media">
          <picture>
            <source
              type="image/webp"
              srcset="/assets/screenshots/bce-dashboard.webp"
            />
            <img
              src="/assets/screenshots/BCE Owner DashBoard.png"
              alt="BCE Owner Operations Dashboard showing financial metrics and AI assistant"
              loading="lazy"
              decoding="async"
              class="case-image"
            />
          </picture>
        </div>

        <div class="case-details">
          <h3 class="case-details-title">What the platform does</h3>
          <ul class="case-features">
            <li class="case-feature">
              <span class="feature-marker text-gold font-mono">//</span>
              <span>AI assistant for instant business queries and data lookup — ask in plain English</span>
            </li>
            <li class="case-feature">
              <span class="feature-marker text-gold font-mono">//</span>
              <span>Financial dashboards with real-time revenue and expense tracking</span>
            </li>
            <li class="case-feature">
              <span class="feature-marker text-gold font-mono">//</span>
              <span>CRM automation — client lifecycle from lead to recurring service</span>
            </li>
            <li class="case-feature">
              <span class="feature-marker text-gold font-mono">//</span>
              <span>SOP management for standardized team operations</span>
            </li>
            <li class="case-feature">
              <span class="feature-marker text-gold font-mono">//</span>
              <span>Owner reporting with drill-down insights and trend analysis</span>
            </li>
          </ul>

          <div class="case-stats">
            <div class="case-stat">
              <span class="case-stat-value text-gold font-mono">500+</span>
              <span class="case-stat-label font-mono">Classification Rules</span>
            </div>
            <div class="case-stat">
              <span class="case-stat-value text-cyan font-mono">85%</span>
              <span class="case-stat-label font-mono">Faster Processing</span>
            </div>
            <div class="case-stat">
              <span class="case-stat-value text-green font-mono">130+</span>
              <span class="case-stat-label font-mono">Hours Saved/Year</span>
            </div>
          </div>

          <div class="case-tags">
            <span class="tag">Python</span>
            <span class="tag tag-cyan">AI</span>
            <span class="tag">Dashboard</span>
            <span class="tag tag-cyan">CRM</span>
            <span class="tag tag-green">Automation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study: Receipt Tool → Office Platform -->
  <section class="section-lg journey-section" id="case-receipt">
    <div class="container">
      <div class="section-header">
        <SectionLabel text="Small to Big" color="cyan" />
        <h2 class="text-heading reveal">From Photo Tool to Office Platform</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 700px;">
          Most platforms start as one small pain point solved properly. Then they grow. This is how that happens.
        </p>
      </div>

      <div class="journey-layout reveal" data-delay="0.1">
        <div class="journey-story">
          <div class="journey-step card">
            <span class="journey-number font-mono text-gold">01</span>
            <h3 class="journey-step-title">The Ask</h3>
            <p class="journey-step-desc">
              "Can you make it so I take a photo of a receipt and it saves to a Google Sheet?"
            </p>
            <span class="journey-tag font-mono text-dim">30-min automation</span>
          </div>

          <div class="journey-arrow">
            <span class="journey-arrow-line"></span>
            <span class="journey-arrow-text font-mono text-gold">evolved into</span>
            <span class="journey-arrow-line"></span>
          </div>

          <div class="journey-step card journey-step-big">
            <span class="journey-number font-mono text-cyan">02</span>
            <h3 class="journey-step-title">The Platform</h3>
            <p class="journey-step-desc">
              A complete office tool with login, employee dashboards, team management,
              categorized expense tracking, and admin controls.
            </p>
            <span class="journey-tag font-mono text-cyan">Full office platform</span>
          </div>
        </div>

        <div class="journey-video">
          <div class="video-wrapper">
            <div class="journey-video-wrap">
              <iframe
                src="https://www.youtube-nocookie.com/embed/7ejI_nq4-tc?rel=0&modestbranding=1&iv_load_policy=3&playsinline=1"
                title="Telegram Receipt Scanner Demo"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="journey-demo-video"
              ></iframe>
            </div>
          </div>
          <p class="video-caption font-mono text-dim">The original receipt scanner in action — Telegram photo → AI extraction → database</p>
        </div>
      </div>

      <div class="journey-lesson reveal" data-delay="0.2">
        <p class="text-body" style="font-size: var(--text-lg); max-width: 700px;">
          This is how most platforms start — one pain point, solved properly, then expanded
          into a system. <strong class="text-gold">The small fix proves the value. The platform captures it.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Tiers & Pricing -->
  <section class="section-lg" id="tiers">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <SectionLabel text="Pricing" color="gold" />
        <h2 class="text-heading reveal">Platform pricing. No mystery.</h2>
        <p class="text-body reveal" data-delay="0.1" style="max-width: 650px;">
          Platform builds are scoped to your needs. These ranges are starting points — I'll build a proposal after understanding your specific system.
        </p>
      </div>

      <div class="platform-tiers">
