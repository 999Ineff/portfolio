<script>
  // Platform animation: scattered tools connect to dashboard
  (function() {
    const stage = document.getElementById('platform-animation');
    if (!stage) return;

    let animated = false;

    function runAnimation() {
      if (animated) return;
      animated = true;

      const gsap = (window as any).gsap;
      if (!gsap) return;

      const tl = gsap.timeline();

      // Phase 1: Tool nodes flash red (signal they're isolated)
      tl.to('#scattered-tools', { opacity: 0.7, duration: 0.3 }, 0.3);

      // Phase 2: Platform hub & lines appear
      tl.to('#platform-hub', { opacity: 1, duration: 0.4, ease: 'power2.out' }, 0.8);

      // Phase 3: Connection lines draw in
      tl.to(['#line-crm', '#line-email', '#line-sheets', '#line-accounting', '#line-pm', '#line-analytics'], {
        opacity: 0.6,
        duration: 0.3,
        stagger: 0.1,
        ease: 'power2.out',
      }, 1.2);

      // Phase 4: Data dots flow
      const dots = ['#dot1', '#dot2', '#dot3'];
      dots.forEach((d, i) => {
        tl.to(d, {
          attr: { cx: 480, cy: 190, opacity: 0.9 },
          duration: 0.6,
          ease: 'power1.inOut',
          delay: i * 0.15,
        }, 1.6);
        tl.to(d, { opacity: 0, duration: 0.2 }, '+=0.1');
      });

      // Phase 5: Dashboard appears
      tl.to('#dashboard', { opacity: 1, duration: 0.7, ease: 'power3.out' }, 2.3);

      // Phase 6: Scattered tools fade to secondary
      tl.to('#scattered-tools', { opacity: 0.2, duration: 0.5, ease: 'power2.out' }, 2.6);
    }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runAnimation();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      observer.observe(stage);
    } else {
      setTimeout(runAnimation, 1000);
    }
  })();
</script>
