<script>
// Premium word-by-word masked text reveal (SplitText-style)
// Each word wraps in overflow:hidden container — text slides up from below mask
function splitAndReveal(el: HTMLElement, gsap: any, baseDelay: number = 0) {
  // Wrap each word in overflow:hidden mask for slide-up reveal.
  // Elements with gradient text (background-clip: text) are treated as atomic —
  // wrapping their internals in inline-block children breaks the gradient rendering.
  const wrapWords = (node: Node): string => {
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.textContent || '';
      return text.split(/(\s+)/).map(chunk => {
        if (/^\s+$/.test(chunk)) return chunk;
        if (!chunk) return '';
        return `<span class="word-mask" style="overflow:hidden;display:inline-block;vertical-align:bottom;"><span class="word-inner" style="display:inline-block;">${chunk}</span></span>`;
      }).join('');
    } else if (node.nodeType === Node.ELEMENT_NODE) {
      const elem = node as HTMLElement;
      const tag = elem.tagName.toLowerCase();
      // Void elements like <br> pass through untouched — wrapping them breaks layout
      if (tag === 'br' || tag === 'hr' || tag === 'img') return `<${tag}>`;
      const style = elem.getAttribute('style') || '';
      const attribs = Array.from(elem.attributes).map(a => `${a.name}="${a.value}"`).join(' ');
      // If element has gradient text styles, split words individually and copy
      // the gradient styles to each word-inner span. This preserves the gradient
      // rendering (no inline-block parent/child break) AND keeps word-level flow.
      if (style.includes('background-clip') || style.includes('text-fill-color')) {
        const text = elem.textContent || '';
        return text.split(/(\s+)/).map(chunk => {
          if (/^\s+$/.test(chunk)) return chunk;
          if (!chunk) return '';
          return `<span class="word-mask" style="overflow:hidden;display:inline-block;vertical-align:bottom;"><span class="word-inner" style="display:inline-block;${style}">${chunk}</span></span>`;
        }).join('');
      }
      const inner = Array.from(elem.childNodes).map(wrapWords).join('');
      return `<${tag} ${attribs}><span class="word-mask" style="overflow:hidden;display:inline-block;vertical-align:bottom;"><span class="word-inner" style="display:inline-block;">${inner}</span></span></${tag}>`;
    }
    return '';
  };

  const wrapped = Array.from(el.childNodes).map(wrapWords).join('');
  el.innerHTML = wrapped;

  const words = el.querySelectorAll<HTMLElement>('.word-inner');
  gsap.set(words, { y: '110%' });
  gsap.to(words, {
    y: '0%',
    duration: 0.9,
    ease: 'power4.out',
    stagger: 0.045,
    delay: baseDelay,
  });
}

// Hero animations — premium masked word reveals + orb float
function initHero() {
  if (typeof window === 'undefined') return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const gsap = (window as any).gsap;
  if (!gsap) return;

  // Word-by-word masked reveal on H1
  const h1 = document.querySelector('.hero-h1') as HTMLElement;
  if (h1) {
    splitAndReveal(h1, gsap, 0.05);
  }

  // Staggered entrance for hero sub + elements (using existing .reveal system)
  // CSS sets hero .reveal to opacity:1 as a no-JS fallback.
  // gsap.set() overrides that back to hidden so GSAP can animate them in.
  // Stagger-reveal all hero elements EXCEPT the H1 (handled by splitAndReveal above)
  const heroReveals = document.querySelectorAll<HTMLElement>('.hero .reveal, .hero .reveal-scale');
  heroReveals.forEach(el => {
    // Skip H1 — splitAndReveal already owns its animation
    if (el.classList.contains('hero-h1')) return;
    if (el.classList.contains('reveal-scale')) {
      gsap.set(el, { opacity: 0, scale: 0.9 });
    } else {
      gsap.set(el, { opacity: 0, y: 20 });
    }
  });
  heroReveals.forEach(el => {
    if (el.classList.contains('hero-h1')) return;
    const delay = parseFloat(el.dataset.delay || '0');
    if (el.classList.contains('reveal-scale')) {
      gsap.to(el, { opacity: 1, scale: 1, duration: 0.8, ease: 'power3.out', delay: delay + 0.2 });
    } else {
      gsap.to(el, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', delay: delay + 0.2 });
    }
  });

  // Floating orbs
  const floats = document.querySelectorAll<HTMLElement>('.hero-float');
  floats.forEach((el, i) => {
    gsap.to(el, {
      y: `${i % 2 === 0 ? '-' : ''}20px`,
      x: `${i % 2 === 0 ? '' : '-'}10px`,
      duration: 3 + i,
      ease: 'sine.inOut',
      repeat: -1,
      yoyo: true,
    });
  });

  // Mouse-parallax on hero visual (subtle tilt) — desktop only
  const heroVisual = document.querySelector<HTMLElement>('.hero-visual');
  if (heroVisual && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    document.addEventListener('mousemove', (e) => {
      const xPct = (e.clientX / window.innerWidth - 0.5) * 8;
      const yPct = (e.clientY / window.innerHeight - 0.5) * 4;
      gsap.to(heroVisual, { rotateY: xPct, rotateX: -yPct, duration: 1.2, ease: 'power2.out' });
    });
  }
}

// FAQ smooth toggle
function initFAQ() {
  const details = document.querySelectorAll<HTMLDetailsElement>('.faq-item');
  details.forEach((detail) => {
    const summary = detail.querySelector('summary');
    if (!summary) return;
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (detail.open) {
        detail.removeAttribute('open');
      } else {
        // Close others
        details.forEach(d => { if (d !== detail) d.removeAttribute('open'); });
        detail.setAttribute('open', '');
      }
    });
  });
}

// ═══ 3D REALITY CAROUSEL ═══════════════════════════════════
function initCarousel() {
  const gsap = (window as any).gsap;
  if (!gsap) {
    // GSAP not loaded yet — poll until it's ready (BaseLayout sets window.gsap)
    let attempts = 0;
    const poll = setInterval(() => {
      attempts++;
      if ((window as any).gsap) { clearInterval(poll); initCarousel(); }
      else if (attempts > 60) clearInterval(poll);
    }, 50);
    return;
  }

  const panels = [document.getElementById('rc-panel-compare'), document.getElementById('rc-panel-roi')];
  const dots = [document.getElementById('rc-dot-0'), document.getElementById('rc-dot-1')];
  const navLabels = [document.getElementById('rc-label-compare'), document.getElementById('rc-label-roi')];
  const glowEl = document.getElementById('rc-glow');
  const stageEl = document.getElementById('rc-carousel');
  const roiCond = document.getElementById('rc-roi-condensed');
  const roiExp = document.getElementById('rc-roi-expanded');
  const exploreBtn = document.getElementById('rc-roi-explore-btn');
  const collapseBtn = document.getElementById('rc-roi-collapse-btn');

  if (!panels[0] || !panels[1] || !stageEl) return;

  let activeIdx = 0;
  let locked = false;
  let expanded = false;
  let autoT: any = null;
  let floatTw: any = null;
  const AUTO_MS = 8000;

  let focused = false; // true when user clicked the active panel to "lock in"
  let tableExpanded = false; // true when comparison table is expanded for reading

  // ─── Mobile-aware helpers ────────────────────────────────
  const isMobile = () => window.innerWidth <= 768;
  const getBehX = () => isMobile() ? Math.min(180, window.innerWidth * 0.35) : 260;
  const getCompactH = () => {
    if (isMobile()) {
      // Measure actual active panel height + nav
      const act = panels[activeIdx];
      if (act) return Math.max(380, act.scrollHeight + 60);
      return 420;
    }
    return 520;
  };
  const get3D = () => !isMobile(); // disable 3D rotation on mobile

  // ─── IntersectionObserver for auto-rotation ───────────────
  let carouselVisible = true;
  const observer = new IntersectionObserver(([entry]) => {
    carouselVisible = entry.isIntersecting;
  }, { threshold: 0.3 });
  observer.observe(stageEl);

  function posPanel(idx: number, anim = true) {
    if (expanded) return;
    const act = panels[idx]!;
    const beh = panels[1 - idx]!;
    if (floatTw) { floatTw.kill(); floatTw = null; }
    gsap.killTweensOf(panels);
    focused = false;
    tableExpanded = false;
    const d = anim ? 1.1 : 0;
    const e = 'power2.inOut';
    const compactH = getCompactH();
    gsap.to(stageEl, { height: compactH, duration: d, ease: e });
    // Active: centered, still, then start gentle float after settling
    gsap.to(act, { x: 0, y: 0, rotateY: 0, rotateX: 0, scale: 1, opacity: 1, force3D: true, duration: d, ease: e,
      onComplete: () => {
        if (!locked && !expanded && !focused) {
          // Gentle float — force3D:true keeps text on GPU layer = crisp
          floatTw = gsap.to(act, { y: -6, duration: 3, ease: 'sine.inOut', yoyo: true, repeat: -1, force3D: true });
        }
      }
    });
    // Behind: pushed to the side (responsive offset)
    const behX = idx === 0 ? getBehX() : -getBehX();
    const use3D = get3D();
    gsap.to(beh, { x: behX, y: use3D ? 30 : 15, rotateY: use3D ? (idx === 0 ? -18 : 18) : 0, rotateX: use3D ? 2 : 0, scale: isMobile() ? 0.88 : 0.82, opacity: 0.7, force3D: true, duration: d, ease: e });
    act.classList.add('active'); act.classList.remove('behind');
    beh.classList.add('behind'); beh.classList.remove('active');
    dots.forEach((dd, i) => dd!.classList.toggle('active', i === idx));
    navLabels.forEach((l, i) => l!.classList.toggle('active', i === idx));
    glowEl!.classList.toggle('panel-roi', idx === 1);
    activeIdx = idx;
  }

  // Initial position — set immediately with gsap.set so behind panel is offset from the start
  function initPositions() {
    const act = panels[0]!;
    const beh = panels[1]!;
    const compactH = getCompactH();
    const behX = getBehX();
    const use3D = get3D();
    gsap.set(act, { x: 0, y: 0, rotateY: 0, rotateX: 0, scale: 1, opacity: 1, force3D: true });
    gsap.set(beh, { x: behX, y: use3D ? 30 : 15, rotateY: use3D ? -18 : 0, rotateX: use3D ? 2 : 0, scale: isMobile() ? 0.88 : 0.82, opacity: 0.7, force3D: true });
    gsap.set(stageEl, { height: compactH });
    act.classList.add('active'); act.classList.remove('behind');
    beh.classList.add('behind'); beh.classList.remove('active');
    dots[0]!.classList.add('active'); dots[1]!.classList.remove('active');
    navLabels[0]!.classList.add('active'); navLabels[1]!.classList.remove('active');
    glowEl!.classList.remove('panel-roi');
    activeIdx = 0;
    // Start float after a beat
    setTimeout(() => {
      if (!locked && !expanded && !focused) {
        floatTw = gsap.to(act, { y: -6, duration: 3, ease: 'sine.inOut', yoyo: true, repeat: -1, force3D: true });
      }
    }, 500);
  }

  function switchPanel(idx: number) {
    if (idx === activeIdx && !expanded) return;
    if (expanded) collapseROI(() => posPanel(idx, true));
    else posPanel(idx, true);
  }

  function startAuto() {
    stopAuto();
    (window as any)._rcAutoStarted = true;
    autoT = setInterval(() => {
      (window as any)._rcTickCount = ((window as any)._rcTickCount || 0) + 1;
      (window as any)._rcTickState = { locked, expanded, focused, tableExpanded, activeIdx };
      if (!locked && !expanded && !focused && !tableExpanded && carouselVisible) switchPanel(1 - activeIdx);
    }, AUTO_MS);
    (window as any)._rcAutoInterval = autoT;
  }
  function stopAuto() { if (autoT) { clearInterval(autoT); autoT = null; } }

  function expandROI() {
    if (expanded) return;
    expanded = true; locked = true;
    stopAuto();
    if (floatTw) { floatTw.kill(); floatTw = null; }
    gsap.killTweensOf(panels);
    syncCondToExp();
    roiCond!.style.display = 'none';
    roiExp!.classList.add('visible');
    const eh = panels[1]!.scrollHeight;
    gsap.to(panels[1]!, { x: 0, y: 0, rotateY: 0, rotateX: 0, scale: 1, opacity: 1, duration: 0.7, ease: 'power3.inOut' });
    gsap.to(stageEl, { height: eh, duration: 0.7, ease: 'power3.inOut' });
    const expandBehX = isMobile() ? -(getBehX() + 20) : -280;
    const use3D = get3D();
    gsap.to(panels[0]!, { x: expandBehX, scale: 0.85, opacity: 0.5, y: 20, rotateY: use3D ? 15 : 0, rotateX: use3D ? 2 : 0, duration: 0.7, ease: 'power3.inOut' });
    panels[1]!.classList.add('active'); panels[1]!.classList.remove('behind');
    panels[0]!.classList.add('behind'); panels[0]!.classList.remove('active');
    dots[0]!.classList.remove('active'); dots[1]!.classList.add('active');
    navLabels[0]!.classList.remove('active'); navLabels[1]!.classList.add('active');
    glowEl!.classList.add('panel-roi');
    activeIdx = 1;
  }

  function collapseROI(cb?: () => void) {
    if (!expanded) { cb?.(); return; }
    expanded = false;
    syncExpToCond();
    roiExp!.classList.remove('visible');
    roiCond!.style.display = '';
    posPanel(activeIdx, true);
    setTimeout(() => { locked = false; focused = false; startAuto(); cb?.(); }, 850);
  }

  // Click handlers
  panels.forEach((p, i) => {
    p!.addEventListener('click', (ev: MouseEvent) => {
      const t = ev.target as HTMLElement;
      if (p!.classList.contains('active') && (t.tagName === 'INPUT' || t.tagName === 'SELECT' || t.closest('input') || t.closest('select') || t.closest('button'))) return;
      if (p!.classList.contains('behind')) {
        if (expanded) collapseROI(() => posPanel(i, true));
        else { switchPanel(i); locked = true; setTimeout(() => { if (!expanded) { locked = false; startAuto(); } }, 10000); }
      } else if (p!.classList.contains('active') && i === 0 && !tableExpanded) {
        // Click on comparison table — expand for better reading
        focused = true;
        tableExpanded = true;
        locked = true;
        stopAuto();
        if (floatTw) { floatTw.kill(); floatTw = null; }
        gsap.killTweensOf(p!);
        gsap.to(p!, { scale: isMobile() ? 1.02 : 1.06, y: 0, duration: 0.4, ease: 'power2.out', force3D: true });
        // Push behind panel further out (responsive)
        const tableExpandX = isMobile() ? getBehX() + 40 : 320;
        gsap.to(panels[1]!, { x: tableExpandX, scale: 0.78, opacity: 0.5, duration: 0.4, ease: 'power2.out', force3D: true });
      } else if (p!.classList.contains('active') && i === 0 && tableExpanded) {
        // Click again to un-expand comparison table
        tableExpanded = false;
        focused = false;
        gsap.to(p!, { scale: 1, duration: 0.4, ease: 'power2.out', force3D: true });
        gsap.to(panels[1]!, { x: getBehX(), scale: isMobile() ? 0.88 : 0.82, opacity: 0.7, duration: 0.4, ease: 'power2.out', force3D: true });
        locked = false;
        startAuto();
        // Restart float
        floatTw = gsap.to(p!, { y: -6, duration: 3, ease: 'sine.inOut', yoyo: true, repeat: -1, force3D: true, delay: 0.5 });
      }
    });
  });

  exploreBtn!.addEventListener('click', (ev: MouseEvent) => {
    ev.stopPropagation();
    if (panels[1]!.classList.contains('behind')) { switchPanel(1); setTimeout(expandROI, 850); }
    else expandROI();
  });

  collapseBtn!.addEventListener('click', (ev: MouseEvent) => { ev.stopPropagation(); collapseROI(); });

  dots.forEach((d, i) => d!.addEventListener('click', () => { switchPanel(i); locked = true; setTimeout(() => { if (!expanded) { locked = false; startAuto(); } }, 10000); }));
  navLabels[0]!.addEventListener('click', () => switchPanel(0));
  navLabels[1]!.addEventListener('click', () => switchPanel(1));

  // No hover pause — auto-rotation runs until user clicks a panel

  // Prevent click-through on inputs
  stageEl.querySelectorAll('input[type="range"], select').forEach((el: Element) => {
    el.addEventListener('click', (e: Event) => e.stopPropagation());
    el.addEventListener('mousedown', (e: Event) => e.stopPropagation());
  });

  // ─── Calculator logic ───────────────────────────────────
  const PRESETS: Record<string, {hours: number; cost: number; pct: number}> = {
    custom: { hours: 10, cost: 50, pct: 60 },
    data_entry: { hours: 8, cost: 45, pct: 75 },
    report_gen: { hours: 6, cost: 55, pct: 80 },
    email_followups: { hours: 5, cost: 50, pct: 70 },
    invoice: { hours: 4, cost: 40, pct: 85 },
    file_org: { hours: 3, cost: 35, pct: 90 },
  };
  let timePeriod = 'annual';

  const $ = (id: string) => document.getElementById(id);

  function fK(n: number) { return n >= 10000 ? '$' + (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : n >= 1000 ? '$' + Math.round(n).toLocaleString() : '$' + Math.round(n); }
  function fH(n: number) { const r = Math.round(n * 10) / 10; return r === 1 ? '1 hr' : r.toFixed(1).replace(/\.0$/, '') + ' hrs'; }

  function updateCond() {
    const h = +($('rcc-hours') as HTMLInputElement).value;
    const c = +($('rcc-cost') as HTMLInputElement).value;
    const pct = 60;
    const hP = ((h - 1) / 39) * 100;
    ($('rcc-hours') as HTMLInputElement).style.background = `linear-gradient(90deg, #ffc13b ${hP}%, rgba(255,255,255,0.08) ${hP}%)`;
    const cP = ((c - 15) / 185) * 100;
    ($('rcc-cost') as HTMLInputElement).style.background = `linear-gradient(90deg, #00e5ff ${cP}%, rgba(255,255,255,0.08) ${cP}%)`;
    $('rcc-hours-val')!.textContent = h + ' hrs';
    $('rcc-cost-val')!.textContent = '$' + c + '/hr';
    const hoursSaved = h * (pct / 100);
    const weeklySaved = hoursSaved * c;
    const annual = weeklySaved * 52;
    $('rcc-annual')!.textContent = '$' + Math.round(annual).toLocaleString();
    const pw = weeklySaved > 0 ? 525 / weeklySaved : 99;
    $('rcc-payback')!.textContent = pw < 1 ? '< 1 week' : Math.ceil(pw) + ' week' + (Math.ceil(pw) === 1 ? '' : 's');
    $('rcc-hours-freed')!.textContent = fH(hoursSaved);
    $('rcc-weekly')!.textContent = fK(weeklySaved);
    const mult = annual > 0 ? Math.round(annual / 525) : 0;
    $('rcc-roi-mult')!.textContent = mult + 'x';
    $('rc-table-savings')!.textContent = fK(annual);
  }

  function updateExp() {
    const h = +($('rce-hours') as HTMLInputElement).value;
    const c = +($('rce-cost') as HTMLInputElement).value;
    const p = +($('rce-pct') as HTMLInputElement).value;
    const f = p / 100;
    const hP = ((h - 1) / 39) * 100;
    ($('rce-hours') as HTMLInputElement).style.background = `linear-gradient(90deg, #ffc13b ${hP}%, rgba(255,255,255,0.08) ${hP}%)`;
    const cP = ((c - 15) / 185) * 100;
    ($('rce-cost') as HTMLInputElement).style.background = `linear-gradient(90deg, #00e5ff ${cP}%, rgba(255,255,255,0.08) ${cP}%)`;
    const pP = ((p - 20) / 70) * 100;
    ($('rce-pct') as HTMLInputElement).style.background = `linear-gradient(90deg, #00ff88 ${pP}%, rgba(255,255,255,0.08) ${pP}%)`;
    $('rce-hours-val')!.textContent = h + ' hrs';
    $('rce-cost-val')!.textContent = '$' + c;
    $('rce-pct-val')!.textContent = p + '%';
    const hs = h * f, hl = h - hs, wk = hs * c, dy = wk / 5, mo = wk * 4.33, yr = mo * 12;
    const aP = h > 0 ? Math.round((hl / h) * 100) : 100;
    const sP = 100 - aP;
    $('rce-bar-before')!.textContent = h + ' hrs/wk manual';
    ($('rce-bar-after') as HTMLElement).style.width = aP + '%';
    ($('rce-bar-saved') as HTMLElement).style.width = sP + '%';
    $('rce-bar-after-text')!.textContent = fH(hl) + ' left';
    $('rce-bar-saved-text')!.textContent = '-' + fH(hs) + ' freed';
    $('rce-m-hours')!.textContent = fH(hs);
    ($('rce-m-hours-sub') as HTMLElement).textContent = p + '% of ' + h + ' hrs/week';
    const pv: Record<string, number> = { daily: dy, weekly: wk, monthly: mo, annual: yr };
    const pl: Record<string, string> = { daily: 'per day', weekly: 'per week', monthly: 'per month', annual: 'per year' };
    const ps: Record<string, string> = { daily: '÷ 5 workdays', weekly: '4.33 wks/mo', monthly: '4.33 × weekly', annual: 'Conservative floor' };
    $('rce-m-savings-label')!.textContent = 'Savings ' + pl[timePeriod];
    $('rce-m-savings')!.textContent = fK(pv[timePeriod]);
    $('rce-m-savings-sub')!.textContent = ps[timePeriod];
    $('rce-m-annual')!.textContent = fK(yr);
    const pbw = wk > 0 ? 525 / wk : 99;
    $('rce-m-payback')!.textContent = pbw < 1 ? '< 1 wk' : Math.ceil(pbw) + ' wk' + (Math.ceil(pbw) === 1 ? '' : 's');
    $('rce-a-manual')!.innerHTML = fK(yr) + '<small>/yr</small>';
    const roi = yr > 0 ? Math.round((yr / 525) * 100) : 0;
    $('rce-a-roi')!.textContent = roi.toLocaleString() + '%';
    $('rce-callout-hours')!.textContent = fH(hs) + '/week';
    const pw2: Record<string, string> = { daily: 'day', weekly: 'week', monthly: 'month', annual: 'year' };
    $('rce-callout-savings')!.textContent = fK(pv[timePeriod]) + '/' + pw2[timePeriod];
    $('rc-table-savings')!.textContent = fK(yr);
    if (expanded) gsap.to(stageEl, { height: panels[1]!.scrollHeight, duration: 0.3, ease: 'power2.out' });
  }

  function syncCondToExp() {
    ($('rce-hours') as HTMLInputElement).value = ($('rcc-hours') as HTMLInputElement).value;
    ($('rce-cost') as HTMLInputElement).value = ($('rcc-cost') as HTMLInputElement).value;
    ($('rce-pct') as HTMLInputElement).value = '60';
    ($('rce-preset') as HTMLSelectElement).value = 'custom';
    updateExp();
  }

  function syncExpToCond() {
    ($('rcc-hours') as HTMLInputElement).value = ($('rce-hours') as HTMLInputElement).value;
    ($('rcc-cost') as HTMLInputElement).value = ($('rce-cost') as HTMLInputElement).value;
    updateCond();
  }

  // Condensed slider listeners
  $('rcc-hours')!.addEventListener('input', (e: Event) => { e.stopPropagation(); updateCond(); });
  $('rcc-cost')!.addEventListener('input', (e: Event) => { e.stopPropagation(); updateCond(); });

  // Expanded slider listeners
  $('rce-hours')!.addEventListener('input', (e: Event) => { e.stopPropagation(); ($('rce-preset') as HTMLSelectElement).value = 'custom'; updateExp(); });
  $('rce-cost')!.addEventListener('input', (e: Event) => { e.stopPropagation(); ($('rce-preset') as HTMLSelectElement).value = 'custom'; updateExp(); });
  $('rce-pct')!.addEventListener('input', (e: Event) => { e.stopPropagation(); ($('rce-preset') as HTMLSelectElement).value = 'custom'; updateExp(); });

  $('rce-preset')!.addEventListener('change', (e: Event) => {
    e.stopPropagation();
    const key = ($('rce-preset') as HTMLSelectElement).value;
    const pr = PRESETS[key];
    if (pr) {
      ($('rce-hours') as HTMLInputElement).value = String(pr.hours);
      ($('rce-cost') as HTMLInputElement).value = String(pr.cost);
      ($('rce-pct') as HTMLInputElement).value = String(pr.pct);
      updateExp();
    }
  });

  $('rce-time-toggle')!.addEventListener('click', (e: Event) => {
    e.stopPropagation();
    const btn = (e.target as HTMLElement).closest('.rc-roi-e-time-btn') as HTMLElement | null;
    if (!btn) return;
    timePeriod = btn.dataset.period || 'annual';
    stageEl.querySelectorAll('.rc-roi-e-time-btn').forEach((b: Element) => b.classList.toggle('active', b === btn));
    updateExp();
  });

  // ─── Touch swipe support ──────────────────────────────────
  let swipeStartX = 0;
  let swipeStartY = 0;
  let swiping = false;
  stageEl.addEventListener('touchstart', (e: TouchEvent) => {
    if (expanded) return;
    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    swiping = true;
  }, { passive: true });
  stageEl.addEventListener('touchend', (e: TouchEvent) => {
    if (!swiping || expanded) return;
    swiping = false;
    const dx = e.changedTouches[0].clientX - swipeStartX;
    const dy = e.changedTouches[0].clientY - swipeStartY;
    // Only trigger if horizontal swipe > 50px and more horizontal than vertical
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
      const nextIdx = dx < 0 ? 1 : 0; // swipe left = panel 1, swipe right = panel 0
      if (nextIdx !== activeIdx) {
        switchPanel(nextIdx);
        locked = true;
        setTimeout(() => { if (!expanded) { locked = false; startAuto(); } }, 10000);
      }
    }
  }, { passive: true });

  // ─── Resize handler — recalculate positions on orientation change ───
  let resizeTimer: any = null;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (!expanded) posPanel(activeIdx, false);
    }, 200);
  });

  // Init — start auto-rotation FIRST, then update calculators
  initPositions();
  startAuto();
  try { updateCond(); } catch(_) {}
  try { updateExp(); } catch(_) {}
}

initHero();
initFAQ();
initCarousel();
document.addEventListener('astro:after-swap', () => {
  initHero();
  initFAQ();
  initCarousel();
});
</script>
