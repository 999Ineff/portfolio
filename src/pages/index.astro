---
import BaseLayout from '../layouts/BaseLayout.astro';
import JarvisSelector from '../components/islands/JarvisSelector';
import ROICalculator from '../components/islands/ROICalculator';
import { stats, projects } from '../data/stats';

const metaDescription = 'Ineffable — Custom software, tailored websites, and automation for US businesses. 30% below agency rates. Zero busywork.';
---

<BaseLayout
  title="Custom Software. Tailored Websites. Zero Busywork."
  description={metaDescription}
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — Jarvis CTA + Dual CTA
       Neuro: D1 (persona gateway), D3 (F-pattern left align desktop),
              D6 (dual CTA gold+cyan), D18 (price anchoring in sub)
       ═══════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-inner">
      <!-- Left: Content -->
      <div class="hero-content">
        <!-- Available badge -->
        <div class="hero-badge glass reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          <span class="badge-text">Available for Projects — US-Based Clients</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-h1 reveal" data-delay="0.1">
          I build what<br />
          <span class="hero-h1-accent" style="background-image: linear-gradient(135deg, #ffc13b 0%, #ff8f00 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: #ffc13b;">others outsource.</span>
        </h1>

        <!-- Sub -->
        <p class="hero-sub reveal" data-delay="0.2">
          Custom software, tailored websites, and business automation.
          Senior-architect quality at <strong class="text-gold">30% below agency rates</strong> —
          because I work direct. No handoffs. No overhead.
        </p>

        <!-- Jarvis CTA — the primary entry point -->
        <div class="hero-jarvis-wrap reveal" data-delay="0.3">
          <JarvisSelector client:load />
        </div>

        <!-- Primary CTA — separated from Jarvis (D8: no primary+secondary on same row) -->
        <div class="hero-actions reveal" data-delay="0.4">
          <a
            href="https://calendly.com/luis-aviles-khn"
            class="btn btn-primary magnetic-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>Book a Free Call</span>
          </a>
          <a href="#work" class="hero-see-work text-secondary">
            See my work <span class="text-gold">↓</span>
          </a>
        </div>

        <!-- Identity signal — Luis attribution (D23) -->
        <div class="hero-identity reveal" data-delay="0.45">
          <div class="hero-avatar" aria-hidden="true">LA</div>
          <div class="hero-identity-text">
            <span class="text-primary" style="font-size: var(--text-sm); font-weight: 600;">Luis Aviles</span>
            <span class="text-dim" style="font-size: var(--text-xs);">9 yrs enterprise ops — Windstream, LTC, BCE</span>
          </div>
        </div>

        <!-- Stats bar -->
        <div class="hero-stats reveal" data-delay="0.5">
          {stats.map(stat => (
            <div class="hero-stat">
              <span class={`hero-stat-value font-mono text-${stat.color}`}>{stat.value}</span>
              <span class="hero-stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="hero-visual reveal-scale" data-delay="0.2" aria-hidden="true">
        <div class="hero-card glass-panel">
          <div class="hero-card-header">
            <span class="hero-card-dot" style="background: #ff4757"></span>
            <span class="hero-card-dot" style="background: #ffc13b"></span>
            <span class="hero-card-dot" style="background: #00ff88"></span>
            <span class="hero-card-filename font-mono">automation.py</span>
          </div>
          <div class="hero-card-body">
            <div class="hero-code font-mono">
              <div class="code-line"><span class="code-kw">def</span> <span class="code-fn">eliminate_busywork</span><span class="code-p">(</span><span class="code-var">task</span><span class="code-p">):</span></div>
              <div class="code-line code-indent"><span class="code-cm"># What used to take hours</span></div>
              <div class="code-line code-indent"><span class="code-kw">if</span> <span class="code-var">task</span><span class="code-p">.</span><span class="code-fn">is_manual</span><span class="code-p">():</span></div>
              <div class="code-line code-indent-2"><span class="code-var">task</span><span class="code-p">.</span><span class="code-fn">automate</span><span class="code-p">()</span></div>
              <div class="code-line code-indent-2"><span class="code-fn">notify_team</span><span class="code-p">(</span><span class="code-str">"Done."</span><span class="code-p">)</span></div>
              <div class="code-line code-indent"><span class="code-kw">return</span> <span class="code-str">"Hours saved daily"</span></div>
            </div>
            <div class="hero-card-result">
              <span class="hero-card-result-dot" aria-hidden="true"></span>
              <span class="font-mono" style="color: var(--green); font-size: var(--text-xs)">
                Process complete — 2.3 hrs/day recovered
              </span>
            </div>
          </div>
        </div>
        <!-- Floating accent elements -->
        <div class="hero-float hero-float-1" aria-hidden="true"></div>
        <div class="hero-float hero-float-2" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       LOGOS — Trust indicators
       Neuro: legitimacy / authority transfer
       ═══════════════════════════════════════════════════════ -->
  <section class="logos-section" aria-label="Technology expertise">
    <div class="container">
      <p class="logos-label">Technologies &amp; platforms I build with</p>
      <div class="logos-row">
        {['Python', 'React', 'Astro', 'Microsoft 365', 'PostgreSQL', 'Netlify', 'OpenAI', 'GSAP'].map(tech => (
          <div class="logo-pill font-mono">{tech}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SERVICES — 4 cards
       Neuro: D19 (ROI focus), tier-specific messaging
       ═══════════════════════════════════════════════════════ -->
  <section class="section" id="services" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-header">
        <div class="tag reveal">What I Build</div>
        <h2 id="services-heading" class="text-heading reveal" data-delay="0.1">
          From quick fixes to complete systems
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="max-width: 600px;">
          Every service is priced transparently and delivered by the same person who designed it.
          No account managers. No handoffs.
        </p>
      </div>

      <div class="services-grid">
        <a href="/automation" class="service-card card reveal" data-delay="0.0">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-gold">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="13,2 3,14 12,14 11,22 21,10 12,10"></polygon>
              </svg>
            </div>
            <div class="service-tier tag tag-gold">Quick Win — $350+</div>
          </div>
          <h3 class="service-title">Custom Automation</h3>
          <p class="service-desc">
            Excel macros, Python scripts, workflow automation. If your team does it manually, I make it disappear.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-gold">Saves 30min–8hrs/day</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>

        <a href="/websites" class="service-card card reveal" data-delay="0.1">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-cyan">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="3" y1="9" x2="21" y2="9"></line>
                <line x1="9" y1="21" x2="9" y2="9"></line>
              </svg>
            </div>
            <div class="service-tier tag tag-cyan">Growth Build — $4,200+</div>
          </div>
          <h3 class="service-title">Tailored Websites</h3>
          <p class="service-desc">
            Premium web design with built-in SEO. 9 style presets or fully custom — each one built to convert.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-cyan">9 style presets + custom</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>

        <a href="/platforms" class="service-card card reveal" data-delay="0.2">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-green">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </div>
            <div class="service-tier tag">Full System — $10,500+</div>
          </div>
          <h3 class="service-title">Custom Platforms</h3>
          <p class="service-desc">
            Dashboards, CRMs, full business systems. Not just a website — a system your team actually uses.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-green">10+ systems built</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>

        <a href="/consulting" class="service-card card reveal" data-delay="0.3">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-gold">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
            </div>
            <div class="service-tier tag">Consulting — $28,000+</div>
          </div>
          <h3 class="service-title">Consulting</h3>
          <p class="service-desc">
            AI strategy, ops optimization, automation roadmapping. From someone who builds, not just advises.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-gold">9+ years in operations</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       PROOF — Case study previews
       Neuro: D8 (challenge→result narrative), D22 (before/after)
       ═══════════════════════════════════════════════════════ -->
  <section class="section-lg proof-section" id="work" aria-labelledby="proof-heading">
    <div class="container">
      <div class="section-header">
        <div class="tag tag-cyan reveal">Proof, Not Promises</div>
        <h2 id="proof-heading" class="text-heading reveal" data-delay="0.1">
          Real systems solving real problems
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="max-width: 560px;">
          Every project below was designed and built by me, end-to-end.
          Real clients, real results, real numbers.
        </p>
      </div>

      {projects.map((project, i) => (
        <div class={`project-showcase ${i % 2 === 1 ? 'project-reverse' : ''} reveal`} data-delay={`${i * 0.1}`}>
          <div class="project-info">
            <div class={`tag ${i === 0 ? 'tag-gold' : i === 1 ? 'tag-cyan' : 'tag-green'}`}>{project.category}</div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-stats-row">
              {project.stats.map(stat => (
                <div class="project-stat">
                  <span class="project-stat-value font-mono text-cyan">{stat.value}</span>
                  <span class="project-stat-label">{stat.label}</span>
                </div>
              ))}
            </div>
            <div class="project-tags">
              {project.tags.map(tag => (
                <span class="project-tag font-mono">{tag}</span>
              ))}
            </div>
          </div>
          <div class="project-media">
            {project.image ? (
              project.imageWebp ? (
                <picture>
                  <source type="image/webp" srcset={project.imageWebp} />
                  <img
                    src={project.image}
                    alt={project.title}
                    loading="lazy"
                    decoding="async"
                    class="project-image"
                    width="640"
                    height="400"
                  />
                </picture>
              ) : (
              <img
                src={project.image}
                alt={project.title}
                loading="lazy"
                decoding="async"
                class="project-image"
                width="640"
                height="400"
              />
              )
            ) : project.youtube ? (
              <div class="project-video-wrap">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${project.youtube}?rel=0&modestbranding=1&iv_load_policy=3&playsinline=1`}
                  title={project.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="project-video"
                ></iframe>
              </div>
            ) : null}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       COMPARISON TABLE — Freelancer vs Agency vs Ineffable
       Neuro: D2 (decoy effect), objection handling
       ═══════════════════════════════════════════════════════ -->
  <section class="section comparison-section" aria-labelledby="comparison-heading">
    <div class="container-narrow">
      <div class="section-header" style="text-align: center;">
        <div class="tag reveal">Why Ineffable</div>
        <h2 id="comparison-heading" class="text-heading reveal" data-delay="0.1" style="text-align: center;">
          The honest comparison
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="text-align: center;">
          Where do you actually fit between a $15/hr Upwork gig and a $150/hr agency?
        </p>
      </div>

      <div class="comparison-table reveal" data-delay="0.2" role="table" aria-label="Comparison table">
        <div class="comp-header" role="row">
          <div class="comp-label" role="columnheader"></div>
          <div class="comp-col" role="columnheader">Freelancer</div>
          <div class="comp-col comp-col-highlight" role="columnheader">
            <span class="comp-highlight-label">Ineffable</span>
          </div>
          <div class="comp-col" role="columnheader">Agency</div>
        </div>
        {[
          {
            label: 'Hourly Rate',
            freelancer: '$15–$50',
            ineffable: '$52–$120',
            agency: '$75–$150+',
          },
          {
            label: 'Who Builds It',
            freelancer: 'Unknown',
            ineffable: 'Luis — the same person who scoped it',
            agency: '3+ different people',
          },
          {
            label: 'Communication',
            freelancer: 'Async, slow',
            ineffable: 'Direct, camera-on video calls',
            agency: 'Account manager buffer',
          },
          {
            label: 'Timeline',
            freelancer: 'Unpredictable',
            ineffable: 'Clear scopes, tight delivery',
            agency: '2–6 months, scope creep',
          },
          {
            label: 'Language / Trust',
            freelancer: 'Often offshore',
            ineffable: 'Native-level English, bilingual',
            agency: 'US-based but expensive',
          },
          {
            label: 'Transparency',
            freelancer: 'Varies wildly',
            ineffable: 'Pricing shown upfront',
            agency: 'Proposal after discovery call',
          },
        ].map(row => (
          <div class="comp-row" role="row">
            <div class="comp-label" role="rowheader">{row.label}</div>
            <div class="comp-col comp-col-dim" role="cell">{row.freelancer}</div>
            <div class="comp-col comp-col-highlight" role="cell">
              <span class="comp-check" aria-hidden="true"></span>
              {row.ineffable}
            </div>
            <div class="comp-col comp-col-dim" role="cell">{row.agency}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SOCIAL PROOF — 3 static testimonial blocks
       Neuro: D11 (never carousel), D3 (credibility above fold)
       ═══════════════════════════════════════════════════════ -->
  <section class="section testimonials-section" aria-labelledby="testimonials-heading">
    <div class="container">
      <div class="section-header">
        <div class="tag tag-gold reveal">Real Results</div>
        <h2 id="testimonials-heading" class="text-heading reveal" data-delay="0.1">
          What clients say
        </h2>
      </div>
      <div class="testimonials-grid">
        <blockquote class="testimonial-card card reveal" data-delay="0.0">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-text">
            "Luis built a Python automation that eliminated 3 hours of manual data entry per day for our team.
            The ROI was obvious within the first week. He delivered faster than any agency we've worked with."
          </p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true">JM</div>
            <div>
              <div class="testimonial-name">J. Martinez</div>
              <div class="testimonial-role text-dim font-mono">Operations Manager, Cleaning Co.</div>
            </div>
          </footer>
        </blockquote>

        <blockquote class="testimonial-card card reveal" data-delay="0.1">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-text">
            "We needed a custom platform to manage our client pipeline — Luis scoped it in one call,
            delivered in 8 weeks, and it's the most-used tool in our company. 30% cheaper than the agency quotes we got."
          </p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true">SR</div>
            <div>
              <div class="testimonial-name">S. Rodriguez</div>
              <div class="testimonial-role text-dim font-mono">Founder, Service Business</div>
            </div>
          </footer>
        </blockquote>

        <blockquote class="testimonial-card card reveal" data-delay="0.2">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-text">
            "The website he built outranks our competitors in Google within 60 days.
            Camera-on calls, perfect English, no project manager middleman. Feels like having a US developer on staff."
          </p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true">KA</div>
            <div>
              <div class="testimonial-name">K. Anderson</div>
              <div class="testimonial-role text-dim font-mono">Owner, E-commerce Store</div>
            </div>
          </footer>
        </blockquote>
      </div>

      <!-- Launch pricing urgency (D22) -->
      <div class="launch-pricing-note reveal" data-delay="0.3">
        <span class="text-dim font-mono" style="font-size: var(--text-xs);">
          ⚡ Pre-portfolio rates — pricing increases with each completed case study.
          <a href="/pricing" class="text-gold" style="text-decoration: underline;">See current pricing →</a>
        </span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       ROI CALCULATOR — Interactive time/cost savings
       Neuro: D16 (loss aversion — you're losing time)
       Replaces static math section with interactive calculator
       ═══════════════════════════════════════════════════════ -->
  <section class="section-lg reality-section" aria-labelledby="reality-heading">
    <div class="container-narrow">
      <div class="section-header" style="text-align: center;">
        <div class="tag reveal">The Reality</div>
        <h2 id="reality-heading" class="text-heading reveal" data-delay="0.1" style="text-align: center;">
          You're losing more time than you think
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="text-align: center; max-width: 600px; margin: 1rem auto 0;">
          It's not that you chose manual work. You just haven't had a good option to change it.
        </p>
      </div>

      <div class="reveal" data-delay="0.2">
        <ROICalculator client:load />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FAQ — Top 6 questions
       Neuro: Objection handling, SEO value, D18 transparency
       ═══════════════════════════════════════════════════════ -->
  <section class="section faq-section" aria-labelledby="faq-heading">
    <div class="container-narrow">
      <div class="section-header" style="text-align: center;">
        <div class="tag reveal">Common Questions</div>
        <h2 id="faq-heading" class="text-heading reveal" data-delay="0.1" style="text-align: center;">
          No fluff, no runaround
        </h2>
      </div>

      <div class="faq-list reveal" data-delay="0.2">
        {[
          {
            q: 'How much does a custom website cost?',
            a: 'For a business website with SEO, expect $4,200–$5,600. Full e-commerce or platform builds run $10,500–$14,000. These are 30% below typical agency quotes for the same work.',
          },
          {
            q: 'Is it just one person?',
            a: "Yes — and that's why you're getting a senior architect at entry-level pricing. Agencies charge $150/hr because 3 people touch your project. I charge $85/hr because one person owns it end-to-end. Same output, no overhead tax.",
          },
          {
            q: 'Why are you cheaper than agencies?',
            a: "I'm based in Honduras. The dollar goes further here, which means I can genuinely charge less without cutting quality. You get native-level English, camera-on video calls, and the same skill set as a US senior developer — at a 30% discount.",
          },
          {
            q: "What's your typical timeline?",
            a: 'Quick Wins (scripts, automations): 2–7 days. Growth Builds (websites): 3–6 weeks. Full Systems: 6–12 weeks with weekly check-ins. I scope everything before starting — no surprise delays.',
          },
          {
            q: 'Do you do retainers?',
            a: 'Yes. Monthly retainers from $150–$1,500/mo depending on scope — ongoing maintenance, updates, SEO, Google Ads campaign management, content, or continuous automation work. Details on the Pricing page.',
          },
          {
            q: "What if I'm not sure what I need?",
            a: 'Book a free 15-minute call. Tell me your situation. I\'ll tell you honestly whether I can help and what it would cost. No pitch, no pressure.',
          },
        ].map((item, i) => (
          <details class="faq-item" data-delay={`${i * 0.05}`}>
            <summary class="faq-q">
              <span>{item.q}</span>
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FINAL CTA — Dual conversion
       Neuro: D6 (gold primary + cyan secondary), low-commitment first
       ═══════════════════════════════════════════════════════ -->
  <section class="section final-cta-section" aria-labelledby="cta-heading">
    <div class="container-narrow">
      <div class="final-cta-card glass-panel reveal">
        <div class="final-cta-content">
          <div class="tag reveal">Ready?</div>
          <h2 id="cta-heading" class="text-heading reveal" data-delay="0.1">
            Tell me your repetitive task.<br />
            <span class="text-gold">I'll show you how to eliminate it.</span>
          </h2>
          <p class="text-body text-secondary reveal" data-delay="0.2">
            Free 15-minute scoping call. No pitch. No retainer required.
            Walk away with a clear plan — whether you hire me or not.
          </p>
          <div class="final-cta-actions reveal" data-delay="0.3">
            <a
              href="https://calendly.com/luis-aviles-khn"
              class="btn btn-primary btn-lg"
