<style>
/* ─── Hero ────────────────────────────────────────────────── */
.hero {
  min-height: 100vh;
  padding-top: calc(var(--nav-height) + 4rem);
  padding-bottom: var(--space-2xl);
  display: flex;
  align-items: center;
