---
import BaseLayout from '../layouts/BaseLayout.astro';
import JarvisSelector from '../components/islands/JarvisSelector';
import { stats, projects } from '../data/stats';

const metaDescription = 'Ineffable — Custom software, tailored websites, and automation for US businesses. 30% below agency rates. Zero busywork.';
---

<BaseLayout
  title="Custom Software. Tailored Websites. Zero Busywork."
  description={metaDescription}
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — Jarvis CTA + Dual CTA
       Neuro: D1 (persona gateway), D3 (F-pattern left align desktop),
              D6 (dual CTA gold+cyan), D18 (price anchoring in sub)
       ═══════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Hero">
    <div class="container hero-inner">
      <!-- Left: Content -->
      <div class="hero-content">
        <!-- Available badge -->
        <div class="hero-badge glass reveal">
          <span class="badge-dot" aria-hidden="true"></span>
          <span class="badge-text">Available for Projects — US-Based Clients</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-h1 reveal" data-delay="0.1">
          I build what<br />
          <span class="hero-h1-accent" style="background-image: linear-gradient(135deg, #ffc13b 0%, #ff8f00 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: #ffc13b;">others outsource.</span>
        </h1>

        <!-- Sub -->
        <p class="hero-sub reveal" data-delay="0.2">
          Custom software, tailored websites, and business automation.
          Senior-architect quality at <strong class="text-gold">30% below agency rates</strong> —
          because I work direct. No handoffs. No overhead.
        </p>

        <!-- Jarvis CTA — the primary entry point -->
        <div class="hero-jarvis-wrap reveal" data-delay="0.3">
          <JarvisSelector client:load />
        </div>

        <!-- Primary CTA — separated from Jarvis (D8: no primary+secondary on same row) -->
        <div class="hero-actions reveal" data-delay="0.4">
          <a
            href="https://calendly.com/luis-aviles-khn"
            class="btn btn-primary magnetic-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>Book a Free Call</span>
          </a>
          <a href="#work" class="hero-see-work text-secondary">
            See my work <span class="text-gold">↓</span>
          </a>
        </div>

        <!-- Identity signal — Luis attribution (D23) -->
        <div class="hero-identity reveal" data-delay="0.45">
          <div class="hero-avatar" aria-hidden="true">LA</div>
          <div class="hero-identity-text">
            <span class="text-primary" style="font-size: var(--text-sm); font-weight: 600;">Luis Aviles</span>
            <span class="text-dim" style="font-size: var(--text-xs);">9 yrs enterprise ops — from telecom to restaurant groups</span>
          </div>
        </div>

        <!-- Stats bar -->
        <div class="hero-stats reveal" data-delay="0.5">
          {stats.map(stat => (
            <div class="hero-stat">
              <span class={`hero-stat-value font-mono text-${stat.color}`}>{stat.value}</span>
              <span class="hero-stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="hero-visual reveal-scale" data-delay="0.2" aria-hidden="true">
        <div class="hero-card glass-panel">
          <div class="hero-card-header">
            <span class="hero-card-dot" style="background: #ff4757"></span>
            <span class="hero-card-dot" style="background: #ffc13b"></span>
            <span class="hero-card-dot" style="background: #00ff88"></span>
            <span class="hero-card-filename font-mono">automation.py</span>
          </div>
          <div class="hero-card-body">
            <div class="hero-code font-mono">
              <div class="code-line"><span class="code-kw">def</span> <span class="code-fn">eliminate_busywork</span><span class="code-p">(</span><span class="code-var">task</span><span class="code-p">):</span></div>
              <div class="code-line code-indent"><span class="code-cm"># What used to take hours</span></div>
              <div class="code-line code-indent"><span class="code-kw">if</span> <span class="code-var">task</span><span class="code-p">.</span><span class="code-fn">is_manual</span><span class="code-p">():</span></div>
              <div class="code-line code-indent-2"><span class="code-var">task</span><span class="code-p">.</span><span class="code-fn">automate</span><span class="code-p">()</span></div>
              <div class="code-line code-indent-2"><span class="code-fn">notify_team</span><span class="code-p">(</span><span class="code-str">"Done."</span><span class="code-p">)</span></div>
              <div class="code-line code-indent"><span class="code-kw">return</span> <span class="code-str">"Hours saved daily"</span></div>
            </div>
            <div class="hero-card-result">
              <span class="hero-card-result-dot" aria-hidden="true"></span>
              <span class="font-mono" style="color: var(--green); font-size: var(--text-xs)">
                Process complete — 2.3 hrs/day recovered
              </span>
            </div>
          </div>
        </div>
        <!-- Floating accent elements -->
        <div class="hero-float hero-float-1" aria-hidden="true"></div>
        <div class="hero-float hero-float-2" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       LOGOS — Trust indicators
       Neuro: legitimacy / authority transfer
       ═══════════════════════════════════════════════════════ -->
  <div class="tech-marquee-strip" aria-label="Technology expertise">
    <div class="tech-marquee-track">
      {[...Array(4)].flatMap(() => ['Python', 'React', 'Astro', 'Node.js', 'PostgreSQL', 'Docker', 'OpenAI', 'GSAP', 'Selenium', 'Microsoft 365', 'Netlify', 'MCP'].map(tech => (
        <span class="tech-marquee-item font-mono">{tech}</span>
      )))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       SERVICES — 4 cards
       Neuro: D19 (ROI focus), tier-specific messaging
       ═══════════════════════════════════════════════════════ -->
  <section class="section" id="services" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-header">
        <div class="tag reveal">What I Build</div>
        <h2 id="services-heading" class="text-heading reveal" data-delay="0.1">
          From quick fixes to complete systems
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="max-width: 600px;">
          Every service is priced transparently and delivered by the same person who designed it.
          No account managers. No handoffs.
        </p>
      </div>

      <div class="services-grid">
        <a href="/automation" class="service-card card reveal" data-delay="0.0">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-gold">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="13,2 3,14 12,14 11,22 21,10 12,10"></polygon>
              </svg>
            </div>
            <div class="service-tier tag tag-gold">Quick Win — $350+</div>
          </div>
          <h3 class="service-title">Custom Automation</h3>
          <p class="service-desc">
            Excel macros, Python scripts, workflow automation. If your team does it manually, I make it disappear.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-gold">Saves 30min–8hrs/day</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>

        <a href="/websites" class="service-card card reveal" data-delay="0.1">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-cyan">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="3" y1="9" x2="21" y2="9"></line>
                <line x1="9" y1="21" x2="9" y2="9"></line>
              </svg>
            </div>
            <div class="service-tier tag tag-cyan">Growth Build — $4,200+</div>
          </div>
          <h3 class="service-title">Tailored Websites</h3>
          <p class="service-desc">
            Premium web design with built-in SEO. 9 style presets or fully custom — each one built to convert.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-cyan">9 style presets + custom</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>

        <a href="/platforms" class="service-card card reveal" data-delay="0.2">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-green">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </div>
            <div class="service-tier tag">Full System — $10,500+</div>
          </div>
          <h3 class="service-title">Custom Platforms</h3>
          <p class="service-desc">
            Dashboards, CRMs, full business systems. Not just a website — a system your team actually uses.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-green">10+ systems built</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>

        <a href="/consulting" class="service-card card reveal" data-delay="0.3">
          <div class="service-card-top">
            <div class="service-icon-wrap service-icon-gold">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
            </div>
            <div class="service-tier tag">Consulting — $28,000+</div>
          </div>
          <h3 class="service-title">Consulting</h3>
          <p class="service-desc">
            AI strategy, ops optimization, automation roadmapping. From someone who builds, not just advises.
          </p>
          <div class="service-footer">
            <span class="service-stat font-mono text-gold">9+ years in operations</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       PROOF — Case study previews
       Neuro: D8 (challenge→result narrative), D22 (before/after)
       ═══════════════════════════════════════════════════════ -->
  <section class="section-lg proof-section" id="work" aria-labelledby="proof-heading">
    <div class="container">
      <div class="section-header">
        <div class="tag tag-cyan reveal">Proof, Not Promises</div>
        <h2 id="proof-heading" class="text-heading reveal" data-delay="0.1">
          Real systems solving real problems
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="max-width: 560px;">
          Every project below was designed and built by me, end-to-end.
          Real clients, real results, real numbers.
        </p>
      </div>

      {projects.map((project, i) => (
        <div class={`project-showcase ${i % 2 === 1 ? 'project-reverse' : ''} reveal`} data-delay={`${i * 0.1}`}>
          <div class="project-info">
            <div class={`tag ${i === 0 ? 'tag-gold' : i === 1 ? 'tag-cyan' : 'tag-green'}`}>{project.category}</div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-stats-row">
              {project.stats.map(stat => (
                <div class="project-stat">
                  <span class="project-stat-value font-mono text-cyan">{stat.value}</span>
                  <span class="project-stat-label">{stat.label}</span>
                </div>
              ))}
            </div>
            <div class="project-tags">
              {project.tags.map(tag => (
                <span class="project-tag font-mono">{tag}</span>
              ))}
            </div>
          </div>
          <div class="project-media">
            {project.image ? (
              project.imageWebp ? (
                <picture>
                  <source type="image/webp" srcset={project.imageWebp} />
                  <img
                    src={project.image}
                    alt={project.title}
                    loading="lazy"
                    decoding="async"
                    class="project-image"
                    width="640"
                    height="400"
                  />
                </picture>
              ) : (
              <img
                src={project.image}
                alt={project.title}
                loading="lazy"
                decoding="async"
                class="project-image"
                width="640"
                height="400"
              />
              )
            ) : project.youtube ? (
              <div class="project-video-wrap">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${project.youtube}?rel=0&modestbranding=1&iv_load_policy=3&playsinline=1`}
                  title={project.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="project-video"
                ></iframe>
              </div>
            ) : null}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       THE REALITY — 3D Carousel: Comparison + ROI Calculator
       Neuro: D2 (decoy), D16 (loss aversion), D19 (ROI focus)
       ═══════════════════════════════════════════════════════ -->
  <section class="section-lg reality-carousel-section" aria-labelledby="reality-heading">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <div class="tag reveal">The Reality</div>
        <h2 id="reality-heading" class="text-heading reveal" data-delay="0.1" style="text-align: center;">
          You're losing more time than you think
        </h2>
        <p class="text-body text-secondary reveal" data-delay="0.2" style="text-align: center; max-width: 550px; margin: 1rem auto 0;">
          Two views, one truth. Click to explore — or let them rotate.
        </p>
      </div>

      <div class="rc-stage" id="rc-carousel">
        <div class="rc-glow" id="rc-glow"></div>

        <!-- Panel 1: Comparison Table -->
        <div class="rc-panel active" id="rc-panel-compare" data-index="0">
          <div class="rc-panel-tab"><span>&#9878;</span> How We Compare</div>
          <div class="rc-comp-body">
            <div class="rc-comp-row rc-comp-header">
              <div class="rc-comp-cell"></div>
              <div class="rc-comp-cell rc-col-f">Freelancer</div>
              <div class="rc-comp-cell rc-col-i">Ineffable</div>
              <div class="rc-comp-cell rc-col-a">Agency</div>
            </div>
            <div class="rc-comp-row">
              <div class="rc-comp-cell rc-comp-label">Who builds it</div>
              <div class="rc-comp-cell rc-col-f">Unknown</div>
              <div class="rc-comp-cell rc-col-i"><span class="rc-check"></span> One person, end to end</div>
              <div class="rc-comp-cell rc-col-a">3+ people</div>
            </div>
            <div class="rc-comp-row">
              <div class="rc-comp-cell rc-comp-label">Communication</div>
              <div class="rc-comp-cell rc-col-f">Async, slow</div>
              <div class="rc-comp-cell rc-col-i"><span class="rc-check"></span> Direct, camera-on</div>
              <div class="rc-comp-cell rc-col-a">Account manager</div>
            </div>
            <div class="rc-comp-row">
              <div class="rc-comp-cell rc-comp-label">Timeline</div>
              <div class="rc-comp-cell rc-col-f">Unpredictable</div>
              <div class="rc-comp-cell rc-col-i"><span class="rc-check"></span> Scoped, tight delivery</div>
              <div class="rc-comp-cell rc-col-a">2–6 months</div>
            </div>
            <div class="rc-comp-row">
              <div class="rc-comp-cell rc-comp-label">Pricing</div>
              <div class="rc-comp-cell rc-col-f">Varies wildly</div>
              <div class="rc-comp-cell rc-col-i"><span class="rc-check"></span> Shown upfront</div>
              <div class="rc-comp-cell rc-col-a">After discovery call</div>
            </div>
            <div class="rc-comp-row">
              <div class="rc-comp-cell rc-comp-label">Language</div>
              <div class="rc-comp-cell rc-col-f">Often offshore</div>
              <div class="rc-comp-cell rc-col-i"><span class="rc-check"></span> Native English, bilingual</div>
              <div class="rc-comp-cell rc-col-a">US-based, expensive</div>
            </div>
            <div class="rc-comp-row rc-comp-savings">
              <div class="rc-comp-cell rc-comp-label" style="color:var(--green);font-weight:700">Annual savings</div>
              <div class="rc-comp-cell rc-col-f" style="font-size:0.68rem">Still paying hourly</div>
              <div class="rc-comp-cell rc-col-i"><span class="rc-savings-num" id="rc-table-savings">$15.6k</span><span style="font-size:0.6rem;color:var(--green);margin-left:0.2rem">/yr</span></div>
              <div class="rc-comp-cell rc-col-a" style="font-size:0.68rem">Similar, but 5–10x cost</div>
            </div>
          </div>
          <span class="rc-click-hint">Click to view</span>
        </div>

        <!-- Panel 2: ROI Calculator -->
        <div class="rc-panel behind" id="rc-panel-roi" data-index="1" style="transform: translateX(260px) translateY(30px) rotateY(-18deg) rotateX(2deg) scale(0.82); opacity: 0.7;">
          <div class="rc-panel-tab"><span>&#9881;</span> Calculate Your ROI</div>

          <!-- CONDENSED VIEW -->
          <div class="rc-roi-condensed" id="rc-roi-condensed">
            <div class="rc-roi-c-slider-group">
              <div class="rc-roi-c-slider-header">
                <span class="rc-roi-c-slider-label">Hours wasted per week</span>
                <span class="rc-roi-c-slider-val" id="rcc-hours-val">10 hrs</span>
              </div>
              <input type="range" class="rc-roi-c-range" id="rcc-hours" min="1" max="40" value="10" step="1">
            </div>
            <div class="rc-roi-c-slider-group">
              <div class="rc-roi-c-slider-header">
                <span class="rc-roi-c-slider-label">Effective hourly cost</span>
                <span class="rc-roi-c-slider-val rc-cyan" id="rcc-cost-val">$50/hr</span>
              </div>
              <input type="range" class="rc-roi-c-range rc-cyan-slider" id="rcc-cost" min="15" max="200" value="50" step="5">
            </div>
            <div class="rc-roi-c-big-savings">
              <div class="rc-roi-c-big-savings-label">Annual savings</div>
              <div class="rc-roi-c-big-savings-value" id="rcc-annual">$15,600</div>
              <div class="rc-roi-c-big-savings-sub">Payback in <span id="rcc-payback">2 weeks</span></div>
            </div>
            <div class="rc-roi-c-stats">
              <div class="rc-roi-c-stat">
                <div class="rc-roi-c-stat-value" id="rcc-hours-freed" style="color:var(--gold)">6 hrs</div>
                <div class="rc-roi-c-stat-label">Freed / week</div>
              </div>
              <div class="rc-roi-c-stat">
                <div class="rc-roi-c-stat-value" id="rcc-weekly" style="color:var(--cyan)">$300</div>
                <div class="rc-roi-c-stat-label">Saved / week</div>
              </div>
              <div class="rc-roi-c-stat">
                <div class="rc-roi-c-stat-value" id="rcc-roi-mult" style="color:var(--green)">30x</div>
                <div class="rc-roi-c-stat-label">ROI</div>
              </div>
            </div>
            <div class="rc-roi-c-explore" id="rc-roi-explore-btn">
              Explore full calculator
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>

          <!-- EXPANDED VIEW -->
          <div class="rc-roi-expanded" id="rc-roi-expanded">
            <div class="rc-roi-e-layout">
              <div class="rc-roi-e-input">
                <div class="rc-roi-e-preset-group">
                  <label class="rc-roi-e-preset-label">Task type</label>
                  <select class="rc-roi-e-preset-select" id="rce-preset">
                    <option value="custom">Custom (adjust manually)</option>
                    <option value="data_entry">Data entry &amp; spreadsheets</option>
                    <option value="report_gen">Report generation</option>
                    <option value="email_followups">Email follow-ups</option>
                    <option value="invoice">Invoice processing</option>
                    <option value="file_org">File organization</option>
                  </select>
                </div>
                <div class="rc-roi-e-slider-group">
                  <div class="rc-roi-e-slider-header">
                    <span class="rc-roi-e-slider-label">Manual hours per week</span>
                    <span class="rc-roi-e-slider-val" id="rce-hours-val" style="color:var(--gold)">10 hrs</span>
                  </div>
                  <span class="rc-roi-e-slider-hint">Time on repetitive work you'd love to eliminate</span>
                  <input type="range" class="rc-roi-e-range" id="rce-hours" min="1" max="40" value="10" step="1">
                  <div class="rc-roi-e-bounds"><span>1 hr</span><span>40 hrs</span></div>
                </div>
                <div class="rc-roi-e-slider-group">
                  <div class="rc-roi-e-slider-header">
                    <span class="rc-roi-e-slider-label">Effective hourly cost</span>
                    <span class="rc-roi-e-slider-val" id="rce-cost-val" style="color:var(--cyan)">$50</span>
                  </div>
                  <span class="rc-roi-e-slider-hint">Salary + overhead, or your billing rate</span>
                  <input type="range" class="rc-roi-e-range rc-range-cyan" id="rce-cost" min="15" max="200" value="50" step="5">
                  <div class="rc-roi-e-bounds"><span>$15</span><span>$200</span></div>
                </div>
                <div class="rc-roi-e-slider-group">
                  <div class="rc-roi-e-slider-header">
                    <span class="rc-roi-e-slider-label">Automatable percentage</span>
                    <span class="rc-roi-e-slider-val" id="rce-pct-val" style="color:var(--green)">60%</span>
                  </div>
                  <span class="rc-roi-e-slider-hint">Most repetitive tasks: 50–80% can be eliminated</span>
                  <input type="range" class="rc-roi-e-range rc-range-green" id="rce-pct" min="20" max="90" value="60" step="10">
                  <div class="rc-roi-e-bounds"><span>20%</span><span>90%</span></div>
                </div>
                <div class="rc-roi-e-bar">
                  <div class="rc-roi-e-bar-row">
                    <span class="rc-roi-e-bar-label">Now</span>
                    <div class="rc-roi-e-bar-track"><div class="rc-roi-e-bar-fill rc-bar-before"><span class="rc-bar-text" id="rce-bar-before">10 hrs/wk manual</span></div></div>
                  </div>
                  <div class="rc-roi-e-bar-row">
                    <span class="rc-roi-e-bar-label">After</span>
                    <div class="rc-roi-e-bar-track">
