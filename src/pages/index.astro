  .hero-actions .btn { width: 100%; justify-content: center; }
  .final-cta-actions { flex-direction: column; width: 100%; }
  .final-cta-actions .btn { width: 100%; justify-content: center; }
  .services-grid { grid-template-columns: 1fr; }
  .comp-header, .comp-row { grid-template-columns: 1fr 1.2fr; }
  .comp-col-dim:last-child { display: none; }
}
</style>

<script>
// Premium word-by-word masked text reveal (SplitText-style)
// Each word wraps in overflow:hidden container — text slides up from below mask
function splitAndReveal(el: HTMLElement, gsap: any, baseDelay: number = 0) {
  // Wrap each word in overflow:hidden mask for slide-up reveal.
  // Elements with gradient text (background-clip: text) are treated as atomic —
  // wrapping their internals in inline-block children breaks the gradient rendering.
  const wrapWords = (node: Node): string => {
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.textContent || '';
      return text.split(/(\s+)/).map(chunk => {
        if (/^\s+$/.test(chunk)) return chunk;
        if (!chunk) return '';
        return `<span class="word-mask" style="overflow:hidden;display:inline-block;vertical-align:bottom;"><span class="word-inner" style="display:inline-block;">${chunk}</span></span>`;
      }).join('');
    } else if (node.nodeType === Node.ELEMENT_NODE) {
      const elem = node as HTMLElement;
      const tag = elem.tagName.toLowerCase();
      // Void elements like <br> pass through untouched — wrapping them breaks layout
      if (tag === 'br' || tag === 'hr' || tag === 'img') return `<${tag}>`;
      const style = elem.getAttribute('style') || '';
      const attribs = Array.from(elem.attributes).map(a => `${a.name}="${a.value}"`).join(' ');
      // If element has gradient text styles, split words individually and copy
      // the gradient styles to each word-inner span. This preserves the gradient
      // rendering (no inline-block parent/child break) AND keeps word-level flow.
      if (style.includes('background-clip') || style.includes('text-fill-color')) {
        const text = elem.textContent || '';
        return text.split(/(\s+)/).map(chunk => {
          if (/^\s+$/.test(chunk)) return chunk;
          if (!chunk) return '';
          return `<span class="word-mask" style="overflow:hidden;display:inline-block;vertical-align:bottom;"><span class="word-inner" style="display:inline-block;${style}">${chunk}</span></span>`;
        }).join('');
      }
      const inner = Array.from(elem.childNodes).map(wrapWords).join('');
      return `<${tag} ${attribs}><span class="word-mask" style="overflow:hidden;display:inline-block;vertical-align:bottom;"><span class="word-inner" style="display:inline-block;">${inner}</span></span></${tag}>`;
    }
    return '';
  };

  const wrapped = Array.from(el.childNodes).map(wrapWords).join('');
  el.innerHTML = wrapped;

  const words = el.querySelectorAll<HTMLElement>('.word-inner');
  gsap.set(words, { y: '110%' });
  gsap.to(words, {
    y: '0%',
    duration: 0.9,
    ease: 'power4.out',
    stagger: 0.045,
    delay: baseDelay,
  });
}

// Hero animations — premium masked word reveals + orb float
function initHero() {
  if (typeof window === 'undefined') return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const gsap = (window as any).gsap;
  if (!gsap) return;

  // Word-by-word masked reveal on H1
  const h1 = document.querySelector('.hero-h1') as HTMLElement;
  if (h1) {
    splitAndReveal(h1, gsap, 0.05);
  }

  // Staggered entrance for hero sub + elements (using existing .reveal system)
  // CSS sets hero .reveal to opacity:1 as a no-JS fallback.
  // gsap.set() overrides that back to hidden so GSAP can animate them in.
  // Stagger-reveal all hero elements EXCEPT the H1 (handled by splitAndReveal above)
  const heroReveals = document.querySelectorAll<HTMLElement>('.hero .reveal, .hero .reveal-scale');
  heroReveals.forEach(el => {
    // Skip H1 — splitAndReveal already owns its animation
    if (el.classList.contains('hero-h1')) return;
    if (el.classList.contains('reveal-scale')) {
      gsap.set(el, { opacity: 0, scale: 0.9 });
    } else {
      gsap.set(el, { opacity: 0, y: 20 });
    }
  });
  heroReveals.forEach(el => {
    if (el.classList.contains('hero-h1')) return;
    const delay = parseFloat(el.dataset.delay || '0');
    if (el.classList.contains('reveal-scale')) {
      gsap.to(el, { opacity: 1, scale: 1, duration: 0.8, ease: 'power3.out', delay: delay + 0.2 });
    } else {
      gsap.to(el, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', delay: delay + 0.2 });
    }
  });

  // Floating orbs
  const floats = document.querySelectorAll<HTMLElement>('.hero-float');
  floats.forEach((el, i) => {
    gsap.to(el, {
      y: `${i % 2 === 0 ? '-' : ''}20px`,
      x: `${i % 2 === 0 ? '' : '-'}10px`,
      duration: 3 + i,
      ease: 'sine.inOut',
      repeat: -1,
      yoyo: true,
    });
  });

  // Mouse-parallax on hero visual (subtle tilt)
  const heroVisual = document.querySelector<HTMLElement>('.hero-visual');
  if (heroVisual) {
    document.addEventListener('mousemove', (e) => {
      const xPct = (e.clientX / window.innerWidth - 0.5) * 8;
      const yPct = (e.clientY / window.innerHeight - 0.5) * 4;
      gsap.to(heroVisual, { rotateY: xPct, rotateX: -yPct, duration: 1.2, ease: 'power2.out' });
    });
  }
}

// FAQ smooth toggle
function initFAQ() {
  const details = document.querySelectorAll<HTMLDetailsElement>('.faq-item');
  details.forEach((detail) => {
    const summary = detail.querySelector('summary');
    if (!summary) return;
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (detail.open) {
        detail.removeAttribute('open');
      } else {
        // Close others
        details.forEach(d => { if (d !== detail) d.removeAttribute('open'); });
        detail.setAttribute('open', '');
      }
    });
  });
}

initHero();
initFAQ();
document.addEventListener('astro:after-swap', () => {
  initHero();
  initFAQ();
});
</script>
