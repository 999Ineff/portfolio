.hero-float-1 {
  width: 120px;
  height: 120px;
  background: rgba(255, 193, 59, 0.12);
  top: -20px;
  right: -30px;
}
.hero-float-2 {
  width: 80px;
  height: 80px;
  background: rgba(0, 229, 255, 0.1);
  bottom: 20px;
  left: -20px;
}

/* ─── Tech Marquee Strip (thin animated band) ───────────── */
.tech-marquee-strip {
  overflow: hidden;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: rgba(15, 15, 26, 0.4);
  padding: 0.625rem 0;
}

.tech-marquee-track {
  display: flex;
  gap: 2.5rem;
  width: max-content;
  animation: tech-scroll 40s linear infinite;
}

.tech-marquee-strip:hover .tech-marquee-track {
  animation-play-state: paused;
}

.tech-marquee-item {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  white-space: nowrap;
  transition: color 0.2s;
}

.tech-marquee-item:hover {
  color: var(--gold);
}

@keyframes tech-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-25%); }
}

/* ─── Services grid ──────────────────────────────────────── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.service-card {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  text-decoration: none;
  padding: 2rem;
  border-radius: var(--radius-xl);
  transition: transform 0.35s var(--ease-spring), box-shadow 0.35s var(--ease-out);
}

.service-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg), var(--shadow-glow-gold);
}

.service-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.service-icon-wrap {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  flex-shrink: 0;
}

.service-icon-gold { color: var(--gold); background: var(--gold-subtle); border-color: rgba(255, 193, 59, 0.15); }
.service-icon-cyan { color: var(--cyan); background: var(--cyan-subtle); border-color: rgba(0, 229, 255, 0.12); }
.service-icon-green { color: var(--green); background: rgba(0, 255, 136, 0.06); border-color: rgba(0, 255, 136, 0.12); }

.service-tier { font-size: var(--text-xs); white-space: nowrap; }
.service-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; }
.service-desc { font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.65; flex: 1; }

.service-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}

.service-stat { font-size: var(--text-xs); }
.service-arrow { color: var(--text-muted); font-size: 1.2rem; transition: all 0.25s; }
.service-card:hover .service-arrow { color: var(--gold); transform: translateX(4px); }

/* ─── Proof / projects ───────────────────────────────────── */
.proof-section { background: transparent; }

.project-showcase {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 0;
  align-items: center;
  margin-bottom: var(--space-2xl);
  position: relative;
}

.project-showcase.project-reverse {
  grid-template-columns: 1.2fr 1fr;
  direction: rtl;
}

.project-showcase.project-reverse > * { direction: ltr; }

.project-info {
  z-index: 2;
  padding: 2.5rem;
  border-radius: var(--radius-xl);
  background: rgba(10, 10, 18, 0.7);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-lg);
  transform: translateX(2.5rem);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.project-showcase.project-reverse .project-info {
  transform: translateX(-2.5rem);
}

.project-title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  line-height: 1.15;
}

.project-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: 1.65;
}

.project-stats-row {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--border);
}

.project-stat { display: flex; flex-direction: column; gap: 0.25rem; }
.project-stat-value { font-size: var(--text-lg); font-weight: 700; }
.project-stat-label {
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.project-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.project-tag {
  font-size: 0.65rem;
  padding: 0.3rem 0.8rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border);
  color: var(--text-dim);
  letter-spacing: 0.05em;
  border-radius: var(--radius-pill);
}

.project-media {
  border-radius: var(--radius-xl);
  border: 1px solid var(--border);
  overflow: hidden;
  background: rgba(20, 20, 32, 0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transform: scale(0.95);
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
  transition: transform 0.5s var(--ease-out);
}

.project-showcase:hover .project-media { transform: scale(0.97); }
.project-image { width: 100%; display: block; filter: brightness(0.92) contrast(1.05); transition: filter 0.4s; }
.project-showcase:hover .project-image { filter: brightness(1) contrast(1.05); }

.project-video-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; }
.project-video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }

/* ─── The Reality — 3D Carousel ──────────────────────────── */
.reality-carousel-section { background: rgba(15, 15, 26, 0.4); }

.rc-stage {
  perspective: 1400px;
  perspective-origin: 50% 45%;
  position: relative;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  transition: height 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  height: 520px;
  overflow: hidden;
}

.rc-panel {
  position: absolute;
  width: 100%;
  max-width: 780px;
  left: 0;
  right: 0;
  margin: 0 auto;
  top: 0;
  transform-style: preserve-3d;
  border-radius: var(--radius-xl);
  border: 1px solid var(--border);
  background: var(--bg-card, #0f0f1a);
  overflow: hidden;
  cursor: pointer;
  will-change: transform, opacity;
  transition: box-shadow 0.4s ease;
}
.rc-panel.active {
  z-index: 2;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 40px rgba(255,193,59,0.04);
}
.rc-panel.behind {
  z-index: 1;
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}
.rc-panel.behind::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(10, 10, 18, 0.35);
  border-radius: var(--radius-xl);
  z-index: 10;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.rc-panel.behind:hover::after { opacity: 0.15; }

.rc-click-hint {
  position: absolute;
  bottom: 14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(10, 10, 18, 0.85);
  padding: 0.35rem 1rem;
  border-radius: 100px;
  border: 1px solid rgba(255, 193, 59, 0.2);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.rc-panel.behind:hover .rc-click-hint { opacity: 1; }
@media (hover: none) { .rc-panel.behind .rc-click-hint { opacity: 0.85; } }

.rc-panel-tab {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.25rem;
  background: rgba(255, 255, 255, 0.02);
  border-bottom: 1px solid var(--border);
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}
.rc-panel.active .rc-panel-tab {
  color: var(--gold);
  background: rgba(255, 193, 59, 0.04);
  border-bottom-color: rgba(255, 193, 59, 0.1);
}

/* Nav */
.rc-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  margin-top: 0.75rem;
  position: relative;
  z-index: 5;
}
.rc-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  border: 1.5px solid var(--text-dim);
  background: transparent;
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 0;
  /* 44px touch target via transparent hit area */
  position: relative;
}
.rc-dot::before {
  content: '';
  position: absolute;
  inset: -17px;
  border-radius: 50%;
}
.rc-dot.active {
  background: var(--gold);
  border-color: var(--gold);
  box-shadow: 0 0 12px rgba(255, 193, 59, 0.3);
  transform: scale(1.15);
}
.rc-dot:hover:not(.active) { border-color: var(--gold); }
.rc-nav-label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  text-transform: uppercase;
  min-width: 100px;
  cursor: pointer;
}
.rc-nav-label-left { text-align: right; }
.rc-nav-label-right { text-align: left; }
.rc-nav-label.active { color: var(--gold); }

.rc-glow {
  position: absolute;
  width: 500px; height: 400px;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.06;
  pointer-events: none;
  z-index: 0;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: var(--gold);
  transition: background 0.8s ease, opacity 0.8s ease;
}
.rc-glow.panel-roi { background: var(--cyan); opacity: 0.04; }

.rc-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.65rem;
  margin-top: 0.75rem;
  text-align: center;
  position: relative;
  z-index: 5;
}
.rc-cta-note { font-size: var(--text-xs); letter-spacing: 0.05em; }

/* ─── Comparison Table (carousel panel) ─────────────────── */
.rc-comp-body { padding: 0; }
.rc-comp-row {
  display: grid;
  grid-template-columns: 1.3fr 1fr 1.2fr 1fr;
  border-bottom: 1px solid var(--border);
}
.rc-comp-row:last-child { border-bottom: none; }
.rc-comp-cell {
  padding: 0.6rem 0.85rem;
  font-size: 0.78rem;
  display: flex;
  align-items: center;
  gap: 0.3rem;
}
.rc-comp-header .rc-comp-cell {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding: 0.55rem 0.85rem;
  background: rgba(255, 255, 255, 0.015);
}
.rc-comp-label { font-weight: 600; color: var(--text-secondary); font-size: 0.72rem; }
.rc-col-f { background: rgba(100, 140, 200, 0.02); color: var(--text-dim); }
.rc-col-i {
  background: rgba(255, 193, 59, 0.035);
  border-left: 1px solid rgba(255, 193, 59, 0.08);
  border-right: 1px solid rgba(255, 193, 59, 0.08);
  color: var(--text-primary);
  font-weight: 500;
}
.rc-col-a { background: rgba(160, 120, 180, 0.02); color: var(--text-dim); }
.rc-comp-header .rc-col-i {
  color: var(--gold);
  font-weight: 700;
  font-family: var(--font-display);
  font-size: 0.72rem;
  letter-spacing: 0.04em;
}
.rc-comp-savings {
  background: rgba(0, 255, 136, 0.025);
  border-top: 1px solid rgba(0, 255, 136, 0.08);
}
.rc-comp-savings .rc-col-i {
  background: rgba(0, 255, 136, 0.04);
  border-left-color: rgba(0, 255, 136, 0.1);
  border-right-color: rgba(0, 255, 136, 0.1);
}
.rc-savings-num {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--green);
  text-shadow: 0 0 15px rgba(0, 255, 136, 0.25);
}
.rc-check {
  display: inline-block;
  width: 12px; height: 12px;
  background: var(--gold);
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}
.rc-check::after {
  content: '';
  position: absolute;
  left: 3.5px; top: 1.5px;
  width: 3px; height: 6px;
  border: 1.5px solid #0a0a12;
  border-top: none; border-left: none;
  transform: rotate(45deg);
}

/* ─── ROI Condensed ─────────────────────────────────────── */
.rc-roi-condensed { padding: 1rem 1.5rem 1.125rem; }
.rc-roi-c-slider-group { margin-bottom: 0.625rem; }
.rc-roi-c-slider-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem; }
.rc-roi-c-slider-label { font-size: 0.78rem; font-weight: 600; color: var(--text-secondary); }
.rc-roi-c-slider-val { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 700; color: var(--gold); }
.rc-roi-c-slider-val.rc-cyan { color: var(--cyan); }
.rc-roi-c-range {
  -webkit-appearance: none; appearance: none;
  width: 100%; height: 4px; border-radius: 2px;
  outline: none; cursor: pointer;
}
.rc-roi-c-range, .rc-roi-e-range { touch-action: none; }
.rc-roi-c-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--gold);
  border: 2.5px solid var(--bg);
  box-shadow: 0 0 0 3px rgba(255, 193, 59, 0.2), 0 2px 6px rgba(0,0,0,0.4);
  cursor: pointer;
  transition: transform 0.15s ease;
}
.rc-roi-c-range::-webkit-slider-thumb:hover { transform: scale(1.15); }
.rc-roi-c-range.rc-cyan-slider::-webkit-slider-thumb {
  background: var(--cyan);
  box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.2), 0 2px 6px rgba(0,0,0,0.4);
}
.rc-roi-c-big-savings { text-align: center; padding: 0.875rem 0 0.35rem; border-top: 1px solid var(--border); margin-top: 0.5rem; }
.rc-roi-c-big-savings-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 0.25rem; }
.rc-roi-c-big-savings-value { font-family: var(--font-mono); font-size: 2rem; font-weight: 700; color: var(--green); text-shadow: 0 0 30px rgba(0, 255, 136, 0.3); line-height: 1; }
.rc-roi-c-big-savings-sub { font-size: 0.68rem; color: var(--text-muted); margin-top: 0.25rem; }
.rc-roi-c-stats { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
.rc-roi-c-stat { flex: 1; text-align: center; padding: 0.5rem 0.25rem; background: rgba(255,255,255,0.025); border: 1px solid var(--border); border-radius: 8px; }
.rc-roi-c-stat-value { font-family: var(--font-mono); font-weight: 700; font-size: 0.95rem; line-height: 1; margin-bottom: 0.2rem; }
.rc-roi-c-stat-label { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }
.rc-roi-c-explore {
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  margin-top: 0.75rem; padding: 0.65rem;
  background: rgba(255, 193, 59, 0.04);
  border: 1px solid rgba(255, 193, 59, 0.1);
  border-radius: 8px;
  font-family: var(--font-mono); font-size: 0.68rem; font-weight: 600;
  color: var(--gold); letter-spacing: 0.04em; cursor: pointer;
  transition: background 0.2s ease, border-color 0.2s ease;
}
.rc-roi-c-explore:hover { background: rgba(255, 193, 59, 0.08); border-color: rgba(255, 193, 59, 0.25); }

/* ─── ROI Expanded ──────────────────────────────────────── */
.rc-roi-expanded { display: none; padding: 1.5rem; }
.rc-roi-expanded.visible { display: block; }
.rc-roi-e-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start; }
.rc-roi-e-input { display: flex; flex-direction: column; gap: 1.25rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem; }
.rc-roi-e-preset-group { display: flex; flex-direction: column; gap: 0.3rem; }
.rc-roi-e-preset-label { font-size: 0.78rem; font-weight: 600; color: var(--text-primary); }
.rc-roi-e-preset-select {
  -webkit-appearance: none; appearance: none; width: 100%;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px; color: var(--text-primary);
  font-family: var(--font-body); font-size: 0.8rem; font-weight: 500;
  padding: 0.55rem 0.875rem; cursor: pointer; outline: none;
  transition: border-color 0.2s;
}
.rc-roi-e-preset-select:hover { border-color: rgba(255, 193, 59, 0.3); }
.rc-roi-e-preset-select:focus { border-color: var(--cyan); box-shadow: 0 0 0 2px rgba(0,229,255,0.15); }
.rc-roi-e-preset-select option { background: #141420; }
.rc-roi-e-slider-group { display: flex; flex-direction: column; gap: 0.35rem; }
.rc-roi-e-slider-header { display: flex; justify-content: space-between; align-items: baseline; }
.rc-roi-e-slider-label { font-size: 0.78rem; font-weight: 600; color: var(--text-primary); }
.rc-roi-e-slider-hint { font-size: 0.68rem; color: var(--text-dim); }
.rc-roi-e-slider-val { font-family: var(--font-mono); font-size: 0.88rem; font-weight: 700; }
.rc-roi-e-range {
  -webkit-appearance: none; appearance: none;
  width: 100%; height: 4px; border-radius: 2px; outline: none; cursor: pointer;
}
.rc-roi-e-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--gold); border: 2.5px solid var(--bg);
  box-shadow: 0 0 0 3px rgba(255, 193, 59, 0.2), 0 2px 6px rgba(0,0,0,0.4);
  cursor: pointer; transition: transform 0.15s ease;
}
.rc-roi-e-range::-webkit-slider-thumb:hover { transform: scale(1.15); }
.rc-roi-e-range.rc-range-cyan::-webkit-slider-thumb { background: var(--cyan); box-shadow: 0 0 0 3px rgba(0,229,255,0.2), 0 2px 6px rgba(0,0,0,0.4); }
.rc-roi-e-range.rc-range-green::-webkit-slider-thumb { background: var(--green); box-shadow: 0 0 0 3px rgba(0,255,136,0.2), 0 2px 6px rgba(0,0,0,0.4); }
.rc-roi-e-bounds { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-muted); margin-top: 0.15rem; }
.rc-roi-e-bar { display: flex; flex-direction: column; gap: 0.5rem; border-top: 1px solid var(--border); padding-top: 1rem; }
.rc-roi-e-bar-row { display: flex; align-items: center; gap: 0.6rem; }
.rc-roi-e-bar-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); width: 2.2rem; flex-shrink: 0; }
.rc-roi-e-bar-track { flex: 1; height: 24px; background: rgba(255,255,255,0.04); border-radius: 5px; overflow: hidden; display: flex; }
.rc-roi-e-bar-fill { display: flex; align-items: center; padding: 0 0.4rem; border-radius: 5px; transition: width 0.4s cubic-bezier(0.16,1,0.3,1); min-width: 0; overflow: hidden; }
.rc-bar-before { background: rgba(255,71,87,0.22); border: 1px solid rgba(255,71,87,0.3); width: 100%; }
.rc-bar-after { background: rgba(255,71,87,0.1); border: 1px solid rgba(255,71,87,0.15); }
.rc-bar-saved { background: rgba(0,255,136,0.12); border: 1px solid rgba(0,255,136,0.25); }
.rc-bar-text { font-family: var(--font-mono); font-size: 0.62rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-secondary); }
.rc-bar-text-green { color: var(--green); }
.rc-roi-e-results { display: flex; flex-direction: column; gap: 1rem; }
.rc-roi-e-time-toggle { display: flex; gap: 0.2rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 100px; padding: 0.2rem; }
.rc-roi-e-time-btn {
  padding: 0.275rem 0.75rem; border-radius: 100px; border: none;
  background: transparent; color: var(--text-dim);
  font-family: var(--font-body); font-size: 0.7rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s; letter-spacing: 0.03em;
}
.rc-roi-e-time-btn:hover { color: var(--text-secondary); }
.rc-roi-e-time-btn.active { background: rgba(255,193,59,0.12); color: var(--gold); box-shadow: 0 0 0 1px rgba(255,193,59,0.2); }
.rc-roi-e-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.rc-roi-e-metric {
  background: rgba(255,255,255,0.02); border: 1px solid var(--border);
  border-radius: 10px; padding: 0.875rem;
  display: flex; flex-direction: column; gap: 0.25rem; transition: border-color 0.2s;
}
