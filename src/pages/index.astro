/* Hero elements must be visible immediately — don't depend on GSAP for above-fold content.
   If JS fails or ScrollTrigger doesn't fire, the hero stays readable.
   GSAP's initHero() will gsap.set() these back to hidden before animating. */
.hero .reveal,
.hero .reveal-scale {
  opacity: 1;
  transform: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
