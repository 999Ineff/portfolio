---
import BaseLayout from '../layouts/BaseLayout.astro';
const lastUpdated = '2026-03-05';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy Policy for Ineffable — how we collect, use, and protect your information."
>
  <article class="legal-page section">
    <div class="container-text">
      <header class="legal-header">
        <span class="tag tag-cyan">Legal</span>
        <h1 class="legal-title" id="legal-h1">Privacy Policy</h1>
        <p class="legal-meta">Last Updated: {lastUpdated}</p>
        <p class="legal-intro reveal">
          Ineffable Solutions ("we," "us," or "our") operates ineffablesolutions.net. This Privacy
          Policy explains how we collect, use, and safeguard your information when you visit our
          website or contact us about our services.
        </p>

        <!-- Trust badge — neuromarketing: reduce anxiety at the top of a legal page -->
        <div class="legal-trust-badge reveal">
          <span class="trust-badge-icon" aria-hidden="true">✓</span>
          <span class="trust-badge-text">Privacy-first: no tracking cookies, no data selling, no cookie banner needed.</span>
        </div>
      </header>

      <!-- Table of contents — UX: long document navigation -->
      <nav class="legal-toc reveal" aria-label="Contents">
        <p class="toc-label">On this page</p>
        <ol class="toc-list">
          <li><a href="#section-1">1. Information We Collect</a></li>
          <li><a href="#section-2">2. How We Use Your Information</a></li>
          <li><a href="#section-3">3. Cookies</a></li>
          <li><a href="#section-4">4. Third-Party Services</a></li>
          <li><a href="#section-5">5. Data Retention</a></li>
          <li><a href="#section-6">6. Your Rights</a></li>
          <li><a href="#section-7">7. Security</a></li>
          <li><a href="#section-8">8. Children's Privacy</a></li>
          <li><a href="#section-9">9. Changes</a></li>
          <li><a href="#section-10">10. Contact</a></li>
        </ol>
      </nav>

      <div class="legal-body">
        <section class="legal-section reveal" id="section-1">
          <h2>1. Information We Collect</h2>
          <h3>Information You Provide Directly</h3>
          <p>
            When you fill out a contact form, subscribe to our newsletter, or inquire about a
            project, you may provide your name, email address, company name, project description,
            and budget range. We only collect what you voluntarily submit.
          </p>
          <h3>Usage Data</h3>
          <p>
            We use Plausible Analytics — a privacy-first analytics tool — to understand how visitors
            use our site. Plausible does not use cookies, does not track individuals across sites,
            and does not collect personally identifiable information. Data is aggregated and
            anonymous. You are not tracked.
          </p>
          <h3>Form Submissions</h3>
          <p>
            Forms on this site are processed by Netlify Forms (operated by Netlify, Inc.). When you
            submit a form, your submission is stored on Netlify's servers. Netlify's privacy policy
            governs that data.
          </p>
        </section>

        <section class="legal-section reveal" id="section-2">
          <h2>2. How We Use Your Information</h2>
          <ul>
            <li>To respond to your inquiries and discuss potential projects</li>
            <li>To send you resources or newsletters you have subscribed to</li>
            <li>To understand aggregate site traffic and improve the user experience</li>
            <li>To fulfill contractual obligations when you engage our services</li>
            <li>To comply with applicable law</li>
          </ul>
          <p>
            We do not sell your data. We do not use it for advertising. We do not share it with
            third parties except as described in Section 4.
          </p>
        </section>

        <section class="legal-section reveal" id="section-3">
          <h2>3. Cookies</h2>
          <p>
            <strong>We do not use tracking cookies.</strong> Plausible Analytics is cookieless by
            design. The only data stored on your device is localStorage values used for site
            functionality (for example, whether you have visited before, to prevent the intro
            animation from replaying). These are functional, not tracking-related, and do not
            identify you.
          </p>
          <p>
            No cookie consent banner is displayed because no consent-requiring cookies are set.
          </p>
        </section>

        <section class="legal-section reveal" id="section-4">
          <h2>4. Third-Party Services</h2>
          <p>This site uses the following third-party services, each with its own privacy policy:</p>
          <ul>
            <li>
              <strong>Netlify</strong> — Hosting and form processing. Netlify processes server
              logs and form submissions.
              <a href="https://www.netlify.com/privacy/" target="_blank" rel="noopener">Netlify Privacy Policy</a>
            </li>
            <li>
              <strong>Plausible Analytics</strong> — Privacy-first, cookieless analytics. No PII
              collected. Data is EU-hosted.
              <a href="https://plausible.io/privacy" target="_blank" rel="noopener">Plausible Privacy Policy</a>
            </li>
            <li>
              <strong>Fontshare / Google Fonts</strong> — Typeface delivery. These services may
              log IP addresses as part of CDN operation.
            </li>
            <li>
              <strong>Calendly</strong> — When you book a call via our Calendly link, Calendly
              collects the information you provide during booking.
              <a href="https://calendly.com/privacy" target="_blank" rel="noopener">Calendly Privacy Policy</a>
            </li>
          </ul>
        </section>

        <section class="legal-section reveal" id="section-5">
          <h2>5. Data Retention</h2>
          <p>
            Contact form submissions and newsletter subscriptions are retained in Netlify until
            manually deleted or until we migrate to our own email infrastructure. If you want your
            data removed, contact us and we will delete it within 5 business days.
          </p>
        </section>

        <section class="legal-section reveal" id="section-6">
          <h2>6. Your Rights</h2>
          <p>Regardless of your location, you may:</p>
          <ul>
            <li>Request to know what personal data we hold about you</li>
            <li>Request correction of inaccurate data</li>
            <li>Request deletion of your data</li>
            <li>Withdraw newsletter consent at any time (unsubscribe link in every email)</li>
          </ul>
          <p>
            <strong>California residents (CCPA):</strong> You have the right to know, delete, and
            opt out of any sale of personal information. We do not sell personal information.
          </p>
          <p>
            <strong>EEA residents (GDPR):</strong> Your legal basis for processing is consent
            (form submissions, newsletter) and legitimate interest (aggregate analytics). You may
            contact us to exercise any GDPR rights.
          </p>
          <p>
            To exercise any rights, email us at
            <a href="mailto:luisaviles@ineffablesolutions.net">luisaviles@ineffablesolutions.net</a>.
            We respond within 5 business days.
          </p>
        </section>

        <section class="legal-section reveal" id="section-7">
          <h2>7. Security</h2>
          <p>
            We use industry-standard security practices including HTTPS, Netlify's infrastructure
            security, and minimal data collection by design. No method of internet transmission is
            100% secure. We collect the minimum data necessary.
          </p>
        </section>

        <section class="legal-section reveal" id="section-8">
          <h2>8. Children's Privacy</h2>
          <p>
            This site is not directed to children under 13. We do not knowingly collect information
            from children. If you believe a child has submitted information, contact us and we will
            delete it immediately.
          </p>
        </section>

        <section class="legal-section reveal" id="section-9">
          <h2>9. Changes to This Policy</h2>
          <p>
            We may update this policy from time to time. The "Last Updated" date at the top reflects
            the most recent revision. Continued use of the site after changes constitutes acceptance
            of the revised policy.
          </p>
        </section>

        <section class="legal-section reveal" id="section-10">
          <h2>10. Contact</h2>
          <address class="legal-contact">
            <strong>Ineffable Solutions</strong><br>
            Luis Aviles<br>
            Tegucigalpa, Col. San Ignacio<br>
            Honduras 11101<br>
            <a href="mailto:luisaviles@ineffablesolutions.net">luisaviles@ineffablesolutions.net</a>
          </address>
        </section>
      </div>

      <div class="legal-disclaimer reveal">
        <p>
          <em>This policy was drafted by the site owner. It is not a substitute for legal advice.
          If your use case involves regulated data (healthcare, finance, minors), consult a
          licensed attorney.</em>
        </p>
      </div>

      <!-- Conversion CTA — neuromarketing: legal pages are not dead ends -->
      <div class="legal-cta reveal">
        <p class="legal-cta-heading">Ready to work together?</p>
        <p class="legal-cta-sub">Questions about privacy or data handling? Or ready to start a project? Either way — I respond within one business day.</p>
        <div class="legal-cta-actions">
          <a href="https://calendly.com/luis-aviles-khn" class="btn btn-primary" target="_blank" rel="noopener">Book a Free Call</a>
          <a href="mailto:luisaviles@ineffablesolutions.net" class="btn btn-ghost">Email Directly</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .legal-page {
    padding-top: calc(var(--nav-height) + var(--space-2xl));
    padding-bottom: var(--space-3xl);
  }

  .legal-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .legal-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--text-primary);
    margin: var(--space-sm) 0 var(--space-xs);
    letter-spacing: -0.02em;
  }

  .legal-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-dim);
    margin-bottom: var(--space-md);
  }

  .legal-intro {
    font-size: var(--text-md);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .legal-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .legal-section {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .legal-section:last-child {
    border-bottom: none;
  }

  .legal-section h2 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--gold);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .legal-section h3 {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--space-md) 0 var(--space-xs);
  }

  .legal-section p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-sm);
  }

  .legal-section p:last-child {
    margin-bottom: 0;
  }

  .legal-section ul {
    list-style: disc;
    padding-left: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .legal-section li {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .legal-section a {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s var(--ease-out);
  }

  .legal-section a:hover {
    color: var(--text-primary);
  }

  .legal-contact {
    font-style: normal;
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.9;
    background: rgba(20, 20, 32, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  .legal-contact a {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s var(--ease-out);
  }

  .legal-contact a:hover {
    color: var(--text-primary);
  }

  .legal-disclaimer {
    margin-top: var(--space-xl);
    padding: var(--space-md);
    background: rgba(15, 15, 26, 0.4);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--gold-dim);
  }

  .legal-disclaimer p {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: 1.7;
  }

  strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* ── Trust Badge ─────────────────────────────────────────── */
  .legal-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-md);
    padding: 0.5rem 1rem;
    background: rgba(0, 255, 136, 0.06);
    border: 1px solid rgba(0, 255, 136, 0.2);
    border-radius: var(--radius-pill);
  }

  .trust-badge-icon {
    color: var(--green);
    font-weight: 700;
    font-size: var(--text-sm);
  }

  .trust-badge-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* ── Table of Contents ──────────────────────────────────── */
  .legal-toc {
    margin: var(--space-xl) 0;
    padding: var(--space-md) var(--space-lg);
    background: rgba(20, 20, 32, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold-dim);
    border-radius: var(--radius-md);
  }

  .toc-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: var(--space-sm);
  }

  .toc-list {
    list-style: decimal;
    padding-left: 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem 2rem;
  }

  .toc-list li {
    font-size: var(--text-sm);
    color: var(--text-dim);
  }

  .toc-list a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s var(--ease-out);
  }

  .toc-list a:hover {
    color: var(--cyan);
  }

  @media (max-width: 600px) {
    .toc-list {
      grid-template-columns: 1fr;
    }
  }

  /* ── Conversion CTA ──────────────────────────────────────── */
  .legal-cta {
    margin-top: var(--space-2xl);
    padding: var(--space-xl) var(--space-xl);
    background: rgba(15, 15, 26, 0.4);
    border: 1px solid var(--border-active);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .legal-cta-heading {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xs);
  }

  .legal-cta-sub {
    font-size: var(--text-base);
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto var(--space-lg);
  }

  .legal-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── No-script fallback: make reveal visible without JS ─── */
  @media (scripting: none) {
    .reveal,
    .reveal-left,
    .reveal-right,
    .reveal-scale {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  // H1 character-by-character reveal on load
  const h1 = document.getElementById('legal-h1');
  if (h1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const text = h1.textContent || '';
    h1.textContent = '';
    h1.style.opacity = '1';
    const chars = text.split('').map(char => {
      const span = document.createElement('span');
      span.textContent = char === ' ' ? '\u00A0' : char;
      span.style.display = 'inline-block';
      span.style.opacity = '0';
      span.style.transform = 'translateY(20px)';
      h1.appendChild(span);
      return span;
    });

    gsap.to(chars, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power3.out',
      stagger: 0.025,
      delay: 0.1,
    });
  } else if (h1) {
    h1.style.opacity = '1';
  }
</script>
